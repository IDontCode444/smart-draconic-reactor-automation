  if isPercent then
    displayValue = string.format("%.1f%%", CONFIG[key])
  end

  writeAt(monitor, 2, y, label, colors.white, colors.black)
  writeAt(monitor, 20, y, tostring(displayValue), colors.yellow, colors.black)

  addButton(key .. "_mL", 30, y, 35, y+1, "-" .. tostring(stepLarge), colors.red, colors.white, function()
    CONFIG[key] = clamp(CONFIG[key] - stepLarge, minVal, maxVal)
  end)
  addButton(key .. "_mS", 37, y, 41, y+1, "-" .. tostring(stepSmall), colors.orange, colors.black, function()
    CONFIG[key] = clamp(CONFIG[key] - stepSmall, minVal, maxVal)
  end)
  addButton(key .. "_pS", 43, y, 47, y+1, "+" .. tostring(stepSmall), colors.lime, colors.black, function()
    CONFIG[key] = clamp(CONFIG[key] + stepSmall, minVal, maxVal)
  end)
  addButton(key .. "_pL", 49, y, 54, y+1, "+" .. tostring(stepLarge), colors.green, colors.black, function()
    CONFIG[key] = clamp(CONFIG[key] + stepLarge, minVal, maxVal)
  end)
end

local function drawTune()
  clearButtons()
  monitor.setBackgroundColor(colors.black)
  monitor.clear()

  writeAt(monitor, 2, 1, CONFIG.appName .. " v" .. CONFIG.version, colors.cyan, colors.black)
  writeAt(monitor, monW - 10, 1, "TUNE", colors.lightGray, colors.black)

  writeAt(monitor, 2, 4, "Tune live operating targets", colors.white, colors.black)
  writeAt(monitor, 2, 5, "Lower field/sat = harder push, less margin", colors.lightGray, colors.black)

  addTuneRow(8,  "targetTemp",       "Target Temp",       3000, 7900, 1, 10, false)
  addTuneRow(12, "targetField",      "Target Field",      20, 80, 1, 10, true)
  addTuneRow(16, "targetSaturation", "Target Saturation", 20, 95, 1, 10, true)

  addButton("back", 2, monH - 3, 14, monH - 2, "Back", colors.cyan, colors.black, function() uiPage = "main" end)
  addButton("charge", 16, monH - 3, 28, monH - 2, "Charge", colors.yellow, colors.black, chargeReactor)
  addButton("activate", 30, monH - 3, 44, monH - 2, "Activate", colors.lime, colors.black, activateReactor)
  addButton("scram", 46, monH - 3, 58, monH - 2, "SCRAM", colors.red, colors.white, function() scram("Operator SCRAM") end)

  for _, b in pairs(buttons) do
    drawButton(monitor, b)
  end
