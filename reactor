  drawTuneButtons(14, {
    { label = "-1", fn = function() adjustSetting("targets", "sat", -1, 5, 95) end },
    { label = "+1", fn = function() adjustSetting("targets", "sat",  1, 5, 95) end },
    { label = "-5", fn = function() adjustSetting("targets", "sat", -5, 5, 95) end, bg = colors.lightGray, fg = colors.black },
    { label = "+5", fn = function() adjustSetting("targets", "sat",  5, 5, 95) end, bg = colors.lightGray, fg = colors.black },
  })

  writeAt(3, 16, "Output Target:", colors.lightGray, colors.black)
  writeAt(18,16, fmtRF(settings.targets.output), colors.yellow, colors.black)
  drawTuneButtons(17, {
    { label = "-50k", fn = function() adjustSetting("targets", "output", -50000, 0, 10000000000) end },
    { label = "+50k", fn = function() adjustSetting("targets", "output",  50000, 0, 10000000000) end },
    { label = "-5M",  fn = function() adjustSetting("targets", "output", -5000000, 0, 10000000000) end, bg = colors.lightGray, fg = colors.black },
    { label = "+5M",  fn = function() adjustSetting("targets", "output",  5000000, 0, 10000000000) end, bg = colors.lightGray, fg = colors.black },
  })
  drawTuneButtons(18, {
    { label = "-100M", fn = function() adjustSetting("targets", "output", -100000000, 0, 10000000000) end, bg = colors.gray },
    { label = "+100M", fn = function() adjustSetting("targets", "output",  100000000, 0, 10000000000) end, bg = colors.gray },
    { label = "-1B",   fn = function() adjustSetting("targets", "output", -1000000000, 0, 10000000000) end, bg = colors.yellow, fg = colors.black },
    { label = "+1B",   fn = function() adjustSetting("targets", "output",  1000000000, 0, 10000000000) end, bg = colors.yellow, fg = colors.black },
  })

  addButton(2, h - 2, 10, 2, "HOME", colors.blue, colors.white, function()
    state.page = "main"
    state.message = "Back to main"
  end)

  addButton(14, h - 2, 10, 2, "SAVE", colors.green, colors.black, function()
    saveSettings(true)
    state.message = "Settings saved"
  end)

  addButton(26, h - 2, 12, 2, "UNSCRAM", colors.orange, colors.black, function()
    state.scrammed = false
    state.mode = "idle"
    resetPID()
    resetStartup()
    state.message = "SCRAM latch cleared"
  end)
end

local function render()
  if state.page == "tune" then
    drawTunePage()
  else
    drawMainPage()
  end
  flushScreen()
end

-------------------------
-- EVENTS              --
-------------------------
local function handleTouch(x, y)
  for i = 1, #state.buttons do
    local b = state.buttons[i]
    if x >= b.x1 and x <= b.x2 and y >= b.y1 and y <= b.y2 then
      local ok, err = pcall(b.onPress)
      if not ok then
        state.message = "Button error: " .. tostring(err)
      end
      return
    end
  end
end

local function controlLoop()
  while state.running do
    local ok, err = pcall(controlTick)
    if not ok then
      state.message = "Control error: " .. tostring(err)
    end
    sleep(settings.control.loopDelay)
  end
end

local function renderLoop()
  while state.running do
    local ok, err = pcall(render)
    if not ok then
      state.message = "Render error: " .. tostring(err)
    end
    sleep(settings.control.uiDelay)
  end
end

local function eventLoop()
  while state.running do
    local ev, p1, p2, p3 = os.pullEvent()
    if ev == "monitor_touch" then
      handleTouch(p2, p3)
    elseif ev == "peripheral" or ev == "peripheral_detach" then
      local ok, err = pcall(function()
        initPeripherals()
        initScreen()
        updateLiveReadings()
      end)
      if not ok then
        state.message = "Peripheral refresh failed: " .. tostring(err)
      end
    end
  end
end

-------------------------
-- BOOT                --
-------------------------
local function main()
  loadSettings()
  initPeripherals()
  initScreen()

  state.setpoints.input = getGateConfiguredFlow(inputGate)
  state.setpoints.output = getGateConfiguredFlow(outputGate)
  updateLiveReadings()

  state.message = "Ready"
  parallel.waitForAny(controlLoop, renderLoop, eventLoop)
end

local ok, err = pcall(main)
if not ok then
  print("Fatal error: " .. tostring(err))
  if monitor then
    pcall(function()
      monitor.setBackgroundColor(colors.black)
      monitor.setTextColor(colors.red)
      monitor.clear()
      monitor.setCursorPos(1, 1)
      monitor.write("Fatal error:")
      monitor.setCursorPos(1, 2)
      monitor.write(tostring(err):sub(1, 80))
    end)
  end
end
