-- Draconic Reactor Auto Controller for CC:Tweaked
-- ATM10 / Draconic Evolution reactor controller
--
-- Named peripherals expected:
--   reactor:     draconic_reactor_0
--   input gate:  flow_gate_0
--   output gate: flow_gate_1
--
-- Monitor is auto-detected.
--
-- UI:
--   Main screen: CHARGE / ACTIVATE / SCRAM / TUNING
--   Tuning screen: adjust Temp / Field / Saturation / Output targets
--
-- Notes:
-- - Buffered monitor rendering prevents flicker.
-- - Charging logic respects the reactor's 50% field + 50% saturation charge state.
-- - Output auto-regulates for highest stable output at lowest safe field input.

-------------------------
-- USER EDITABLE NAMES  --
-------------------------
local NAMED_REACTOR     = "draconic_reactor_0"
local NAMED_INPUT_GATE  = "flow_gate_0"
local NAMED_OUTPUT_GATE = "flow_gate_1"

-------------------------
-- DEFAULT SETTINGS    --
-------------------------
local CONFIG_FILE = "draconic_reactor_auto.cfg"

local defaults = {
  monitorTextScale = 0.5,

  targets = {
    temp   = 7800,        -- efficient target is near 8000C
    field  = 45,          -- running target %
    sat    = 25,          -- running target %
    output = 10000000,    -- 10M rf/t default cap
  },

  limits = {
    minFieldThrottle = 22,
    minFieldScram    = 10,
    minSatThrottle   = 8,
    minSatScram      = 3,
    maxTempThrottle  = 8050,
    maxTempScram     = 8400,
  },

  control = {
    loopDelay          = 0.25,
    uiDelay            = 0.10,
    chargeFlow         = 5000000,
    fieldSafetyMargin  = 1.10,
    fieldCorrection    = 0.12,
    outputRampFraction = 0.06,
    outputStepMin      = 10000,
    outputStepMax      = 5000000,
    saveEverySeconds   = 5,
  }
}

-------------------------
-- STATE               --
-------------------------
local reactor, inputGate, outputGate, monitor, monitorName
local settings = nil

local state = {
  page = "main",
  buttons = {},
  info = nil,
  lastSave = 0,
  running = true,
  scrammed = false,
  message = "Booting...",
  lastTouch = 0,
}

-------------------------
-- SMALL HELPERS       --
-------------------------
local function clamp(v, lo, hi)
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

local function round(n)
  if n >= 0 then return math.floor(n + 0.5) end
  return math.ceil(n - 0.5)
end

local function pct(part, whole)
  if not whole or whole == 0 then return 0 end
  return (part / whole) * 100
end

local function copyTable(t)
  local out = {}
  for k, v in pairs(t) do
    if type(v) == "table" then
      out[k] = copyTable(v)
    else
      out[k] = v
    end
  end
  return out
end

local function deepMerge(dst, src)
  for k, v in pairs(src) do
    if type(v) == "table" and type(dst[k]) == "table" then
      deepMerge(dst[k], v)
    else
      dst[k] = v
    end
  end
  return dst
end

local function fmtRF(n)
  n = tonumber(n) or 0
  local abs = math.abs(n)
  if abs >= 1000000000000 then
    return string.format("%.2fT", n / 1000000000000)
  elseif abs >= 1000000000 then
    return string.format("%.2fB", n / 1000000000)
  elseif abs >= 1000000 then
    return string.format("%.2fM", n / 1000000)
  elseif abs >= 1000 then
    return string.format("%.1fk", n / 1000)
  else
    return tostring(round(n))
  end
end

local function centerText(width, txt)
  if #txt >= width then return txt:sub(1, width) end
  local left = math.floor((width - #txt) / 2)
  return string.rep(" ", left) .. txt .. string.rep(" ", width - left - #txt)
end

local function hasMethod(obj, name)
  return obj and type(obj[name]) == "function"
end

-------------------------
-- CONFIG              --
-------------------------
local function loadSettings()
  settings = copyTable(defaults)

  if fs.exists(CONFIG_FILE) then
    local f = fs.open(CONFIG_FILE, "r")
    if f then
      local raw = f.readAll()
      f.close()
      local parsed = textutils.unserialize(raw)
      if type(parsed) == "table" then
        deepMerge(settings, parsed)
      end
    end
  end
end

local function saveSettings(force)
  local now = os.clock()
  if not force and (now - state.lastSave) < settings.control.saveEverySeconds then
    return
  end

  local f = fs.open(CONFIG_FILE, "w")
  if f then
    f.write(textutils.serialize(settings))
    f.close()
    state.lastSave = now
  end
end

-------------------------
-- PERIPHERALS         --
-------------------------
local function wrapRequired(name, fallbackType)
  local p = peripheral.wrap(name)
  if p then return p end

  if fallbackType then
    local found = peripheral.find(fallbackType)
    if found then return found end
  end

  error("Missing peripheral: " .. tostring(name))
end

local function findMonitor()
  local names = peripheral.getNames()
  for i = 1, #names do
    local n = names[i]
    if peripheral.getType(n) == "monitor" then
      return n, peripheral.wrap(n)
    end
  end
  error("No monitor found")
end

local function initPeripherals()
  reactor = wrapRequired(NAMED_REACTOR, "draconic_reactor")
  inputGate = wrapRequired(NAMED_INPUT_GATE, "flux_gate")
  outputGate = wrapRequired(NAMED_OUTPUT_GATE, "flux_gate")
  monitorName, monitor = findMonitor()

  if hasMethod(monitor, "setTextScale") then
    monitor.setTextScale(settings.monitorTextScale or 0.5)
  end

  if hasMethod(monitor, "setBackgroundColor") then
    monitor.setBackgroundColor(colors.black)
  end
  if hasMethod(monitor, "setTextColor") then
    monitor.setTextColor(colors.white)
  end
  if hasMethod(monitor, "clear") then
    monitor.clear()
  end

  if hasMethod(inputGate, "setOverrideEnabled") then
    pcall(inputGate.setOverrideEnabled, true)
  end
  if hasMethod(outputGate, "setOverrideEnabled") then
    pcall(outputGate.setOverrideEnabled, true)
  end
end

-------------------------
-- GATE COMPAT LAYER   --
-------------------------
local function setGateFlow(gate, value)
  value = math.max(0, round(tonumber(value) or 0))

  if hasMethod(gate, "setSignalLowFlow") then
    return gate.setSignalLowFlow(value)
  elseif hasMethod(gate, "setFlowOverride") then
    return gate.setFlowOverride(value)
  elseif hasMethod(gate, "setFlow") then
    return gate.setFlow(value)
  else
    error("Gate does not support a known set flow method")
  end
end

local function getGateFlow(gate)
  if hasMethod(gate, "getSignalLowFlow") then
    return tonumber(gate.getSignalLowFlow()) or 0
  elseif hasMethod(gate, "getFlowOverride") then
    return tonumber(gate.getFlowOverride()) or 0
  elseif hasMethod(gate, "getFlow") then
    return tonumber(gate.getFlow()) or 0
  else
    return 0
  end
end

-------------------------
-- REACTOR COMPAT      --
-------------------------
local function reactorInfo()
  if hasMethod(reactor, "getReactorInfo") then
    return reactor.getReactorInfo()
  end
  error("Reactor missing getReactorInfo()")
end

local function reactorCharge()
  if hasMethod(reactor, "chargeReactor") then
    return reactor.chargeReactor()
  end
  state.message = "chargeReactor() not available"
end

local function reactorActivate()
  if hasMethod(reactor, "activateReactor") then
    state.scrammed = false
    return reactor.activateReactor()
  end
  state.message = "activateReactor() not available"
end

local function reactorStop()
  if hasMethod(reactor, "stopReactor") then
    return reactor.stopReactor()
  end
  state.message = "stopReactor() not available"
end

-------------------------
-- REACTOR MATH        --
-------------------------
local function computeTempDrainFactor(temp)
  if temp > 8000 then
    return 1 + ((temp - 8000) ^ 2) * 0.0000025
  elseif temp > 2000 then
    return 1
  elseif temp > 1000 then
    return (temp - 1000) / 1000
  else
    return 0
  end
end

local function computeFieldDrainRate(info)
  local satPct01 = clamp((tonumber(info.energySaturation) or 0) / math.max(1, tonumber(info.maxEnergySaturation) or 1), 0, 1)
  local temp = tonumber(info.temperature) or 0
  local maxSat = tonumber(info.maxEnergySaturation) or 0

  local baseMaxRFt = (3 * maxSat) / 2000
  local drainMax = math.max(0.01, 1 - satPct01)
  local tempDrainFactor = computeTempDrainFactor(temp)

  return math.ceil(tempDrainFactor * drainMax * (baseMaxRFt / 10.923556))
end

local function normalizeInfo(raw)
  if type(raw) ~= "table" then return nil end

  local info = {}
  for k, v in pairs(raw) do info[k] = v end

  info.status = string.lower(tostring(info.status or "unknown"))
  info.temperature = tonumber(info.temperature) or 0
  info.fieldStrength = tonumber(info.fieldStrength) or 0
  info.maxFieldStrength = tonumber(info.maxFieldStrength) or 1
  info.energySaturation = tonumber(info.energySaturation) or 0
  info.maxEnergySaturation = tonumber(info.maxEnergySaturation) or 1
  info.generationRate = tonumber(info.generationRate) or 0
  info.fuelConversion = tonumber(info.fuelConversion) or 0
  info.maxFuelConversion = tonumber(info.maxFuelConversion) or 1
  info.fieldDrainRate = tonumber(info.fieldDrainRate) or 0

  if info.fieldDrainRate <= 0 then
    info.fieldDrainRate = computeFieldDrainRate(info)
  end

  info.fieldPct = pct(info.fieldStrength, info.maxFieldStrength)
  info.satPct = pct(info.energySaturation, info.maxEnergySaturation)
  info.fuelPct = 100 - pct(info.fuelConversion, info.maxFuelConversion)

  return info
end

local function isColdLike(status)
  return status == "cold" or status == "offline"
end

local function isRunningLike(status)
  return status == "running" or status == "online"
end

local function isChargingLike(status)
  return status == "charging" or status == "charged" or status == "warming_up"
end

local function isStoppingLike(status)
  return status == "stopping" or status == "cooling"
end

-------------------------
-- CONTROL LOGIC       --
-------------------------
local function calcWantedInput(info)
  local targetFieldPct = clamp(settings.targets.field, 20, 80)
  local targetField = info.maxFieldStrength * (targetFieldPct / 100)

  local fieldNegPct = 1 - (targetField / info.maxFieldStrength)
  fieldNegPct = math.max(0.01, fieldNegPct)

  local base = (info.fieldDrainRate / fieldNegPct) * settings.control.fieldSafetyMargin
  local correction = (targetField - info.fieldStrength) * settings.control.fieldCorrection
  local wanted = base + correction

  if info.temperature < 2500 and (isRunningLike(info.status) or isStoppingLike(info.status)) then
    wanted = wanted * 1.15
  end

  return math.max(0, wanted)
end

local function calcWantedOutput(info, currentOut)
  local targetTemp = clamp(settings.targets.temp, 2500, 8000)
  local targetSat = clamp(settings.targets.sat, 5, 95)
  local maxOut = math.max(0, settings.targets.output)

  local fieldTarget = clamp(settings.targets.field, 20, 80)
  local minFieldThrottle = math.max(settings.limits.minFieldThrottle, fieldTarget - 12)

  local score = 0
  score = score + ((info.satPct - targetSat) * 1.8)
  score = score + ((targetTemp - info.temperature) / 120)

  if info.fieldPct < fieldTarget then
    score = score - ((fieldTarget - info.fieldPct) * 4.0)
  else
    score = score + ((info.fieldPct - fieldTarget) * 0.4)
  end

  if info.fieldPct < minFieldThrottle then
    score = score - ((minFieldThrottle - info.fieldPct) * 10)
  end
  if info.satPct < settings.limits.minSatThrottle then
    score = score - ((settings.limits.minSatThrottle - info.satPct) * 12)
  end
  if info.temperature > settings.limits.maxTempThrottle then
    score = score - ((info.temperature - settings.limits.maxTempThrottle) / 15)
  end

  local step = math.max(
    settings.control.outputStepMin,
    math.min(settings.control.outputStepMax, math.max(100000, currentOut * settings.control.outputRampFraction))
  )

  local wanted = currentOut + (score * step)
  wanted = clamp(wanted, 0, maxOut)

  if info.fieldPct < minFieldThrottle or info.satPct < settings.limits.minSatThrottle or info.temperature > settings.limits.maxTempThrottle then
    wanted = math.min(wanted, currentOut * 0.70, info.generationRate * 1.05)
  end

  if info.temperature < 2200 then
    wanted = math.min(wanted, info.generationRate * 0.25)
  end

  return math.max(0, wanted)
end

local function hardScram(info, why)
  state.scrammed = true
  state.message = "SCRAM: " .. why
  pcall(reactorStop)

  local inFlow = calcWantedInput(info)
  local outFlow = math.max(getGateFlow(outputGate), info.generationRate)

  pcall(setGateFlow, inputGate, inFlow)
  pcall(setGateFlow, outputGate, outFlow)
end

local function controlTick()
  local raw = reactorInfo()
  local info = normalizeInfo(raw)
  state.info = info

  if not info then
    state.message = "No reactor info"
    return
  end

  if info.status == "beyond_hope" then
    hardScram(info, "reactor beyond hope")
    return
  end

  if info.fieldPct <= settings.limits.minFieldScram then
    hardScram(info, "field too low")
    return
  end

  if info.satPct <= settings.limits.minSatScram then
    hardScram(info, "saturation too low")
    return
  end

  if info.temperature >= settings.limits.maxTempScram then
    hardScram(info, "temperature too high")
    return
  end

  local currentIn = getGateFlow(inputGate)
  local currentOut = getGateFlow(outputGate)

  if state.scrammed then
    if isColdLike(info.status) then
      pcall(setGateFlow, inputGate, 0)
      pcall(setGateFlow, outputGate, 0)
      state.message = "SCRAM complete - reactor cold"
    else
      local inFlow = calcWantedInput(info)
      local outFlow = math.max(currentOut, info.generationRate)
      pcall(setGateFlow, inputGate, inFlow)
      pcall(setGateFlow, outputGate, outFlow)
      state.message = "SCRAM cooling sequence active"
    end
    return
  end

  if isColdLike(info.status) then
    pcall(setGateFlow, inputGate, 0)
    pcall(setGateFlow, outputGate, 0)
    state.message = "Reactor offline"
    return
  end

  -- Charging phase: field and saturation only need 50%
  if isChargingLike(info.status) and not isRunningLike(info.status) then
    local chargeReady = (info.fieldPct >= 50) and (info.satPct >= 50)

    if chargeReady then
      pcall(setGateFlow, inputGate, 0)
      pcall(setGateFlow, outputGate, 0)
      state.message = "Charge complete - ready to activate"
    else
      pcall(setGateFlow, outputGate, 0)
      pcall(setGateFlow, inputGate, settings.control.chargeFlow)
      state.message = "Charging reactor (need 50% field/sat)"
    end
    return
  end

  if isStoppingLike(info.status) then
    local inFlow = calcWantedInput(info)
    local outFlow = math.max(info.generationRate, currentOut)
    pcall(setGateFlow, inputGate, inFlow)
    pcall(setGateFlow, outputGate, outFlow)
    state.message = "Controlled shutdown"
    return
  end

  if isRunningLike(info.status) or info.status == "warming_up" then
    local wantedIn = calcWantedInput(info)
    local wantedOut = calcWantedOutput(info, currentOut)

    pcall(setGateFlow, inputGate, wantedIn)
    pcall(setGateFlow, outputGate, wantedOut)
    state.message = "Auto regulating"
    return
  end

  state.message = "Unhandled status: " .. tostring(info.status)
end

-------------------------
-- BUFFERED RENDERER   --
-------------------------
local screen = {
  w = 0,
  h = 0,
  rows = {},
  prev = {},
}

local function makeBlankRow(w, fg, bg)
  return {
    txt = string.rep(" ", w),
    fg = string.rep(colors.toBlit(fg or colors.white), w),
    bg = string.rep(colors.toBlit(bg or colors.black), w),
  }
end

local function initScreen()
  screen.w, screen.h = monitor.getSize()
  screen.rows = {}
  screen.prev = {}
  for y = 1, screen.h do
    screen.rows[y] = makeBlankRow(screen.w, colors.white, colors.black)
    screen.prev[y] = { txt = "", fg = "", bg = "" }
  end
end

local function clearFrame(bg)
  for y = 1, screen.h do
    screen.rows[y] = makeBlankRow(screen.w, colors.white, bg or colors.black)
  end
  state.buttons = {}
end

local function writeAt(x, y, text, fg, bg)
  if y < 1 or y > screen.h then return end
  if x > screen.w then return end
  if x < 1 then
    text = text:sub(2 - x)
    x = 1
  end
  if #text <= 0 then return end
  if x + #text - 1 > screen.w then
    text = text:sub(1, screen.w - x + 1)
  end

  local row = screen.rows[y]
  local beforeTxt = row.txt:sub(1, x - 1)
  local afterTxt = row.txt:sub(x + #text)
  row.txt = beforeTxt .. text .. afterTxt

  local fgch = colors.toBlit(fg or colors.white)
  local bgch = colors.toBlit(bg or colors.black)
  local fgStr = string.rep(fgch, #text)
  local bgStr = string.rep(bgch, #text)

  local beforeFg = row.fg:sub(1, x - 1)
  local afterFg = row.fg:sub(x + #text)
  row.fg = beforeFg .. fgStr .. afterFg

  local beforeBg = row.bg:sub(1, x - 1)
  local afterBg = row.bg:sub(x + #text)
  row.bg = beforeBg .. bgStr .. afterBg
end

local function drawHBar(x, y, w, valuePct, fillBg, emptyBg, label)
  valuePct = clamp(valuePct, 0, 100)
  local filled = math.floor((w * valuePct) / 100)
  if filled > 0 then
    writeAt(x, y, string.rep(" ", filled), colors.white, fillBg)
  end
  if filled < w then
    writeAt(x + filled, y, string.rep(" ", w - filled), colors.white, emptyBg)
  end

  if label and #label > 0 and w >= #label + 2 then
    local lx = x + math.floor((w - #label) / 2)
    writeAt(lx, y, label, colors.white, filled >= math.floor(w / 2) and fillBg or emptyBg)
  end
end

local function addButton(x, y, w, h, label, bg, fg, onPress)
  label = tostring(label)
  for yy = y, y + h - 1 do
    local line = string.rep(" ", w)
    writeAt(x, yy, line, fg, bg)
  end

  local ly = y + math.floor((h - 1) / 2)
  local shown = label
  if #shown > w - 2 then shown = shown:sub(1, w - 2) end
  writeAt(x + math.max(0, math.floor((w - #shown) / 2)), ly, shown, fg, bg)

  state.buttons[#state.buttons + 1] = {
    x1 = x, y1 = y, x2 = x + w - 1, y2 = y + h - 1,
    onPress = onPress
  }
end

local function flushScreen()
  for y = 1, screen.h do
    local row = screen.rows[y]
    local prev = screen.prev[y]
    if row.txt ~= prev.txt or row.fg ~= prev.fg or row.bg ~= prev.bg then
      monitor.setCursorPos(1, y)
      monitor.blit(row.txt, row.fg, row.bg)
      screen.prev[y] = {
        txt = row.txt,
        fg = row.fg,
        bg = row.bg,
      }
    end
  end
end

-------------------------
-- UI                  --
-------------------------
local function buttonColorForStatus(info)
  if not info then return colors.gray end
  if info.status == "beyond_hope" then return colors.red end
  if isRunningLike(info.status) then return colors.lime end
  if isChargingLike(info.status) then return colors.orange end
  if isStoppingLike(info.status) then return colors.yellow end
  return colors.gray
end

local function drawMainPage()
  clearFrame(colors.black)
  local info = state.info
  local w, h = screen.w, screen.h

  writeAt(1, 1, centerText(w, "DRACONIC REACTOR CONTROLLER"), colors.white, colors.blue)

  local status = info and info.status or "unknown"
  local statColor = buttonColorForStatus(info)
  writeAt(2, 3, "Status:", colors.lightGray, colors.black)
  writeAt(11, 3, status, colors.white, statColor)

  if info then
    writeAt(2, 5,  "Temp:", colors.lightGray, colors.black)
    writeAt(11, 5, tostring(round(info.temperature)) .. " C", colors.white, colors.black)

    writeAt(2, 6,  "Field:", colors.lightGray, colors.black)
    writeAt(11, 6, string.format("%.1f%%", info.fieldPct), colors.white, colors.black)

    writeAt(2, 7,  "Sat:", colors.lightGray, colors.black)
    writeAt(11, 7, string.format("%.1f%%", info.satPct), colors.white, colors.black)

    writeAt(2, 8,  "Gen:", colors.lightGray, colors.black)
    writeAt(11, 8, fmtRF(info.generationRate) .. "rf/t", colors.white, colors.black)

    writeAt(2, 9,  "In:", colors.lightGray, colors.black)
    writeAt(11, 9, fmtRF(getGateFlow(inputGate)) .. "rf/t", colors.white, colors.black)

    writeAt(2, 10, "Out:", colors.lightGray, colors.black)
    writeAt(11,10, fmtRF(getGateFlow(outputGate)) .. "rf/t", colors.white, colors.black)

    local barW = math.max(10, w - 24)
    drawHBar(22, 5, barW, clamp(info.temperature / math.max(settings.limits.maxTempScram, 1) * 100, 0, 100), colors.red, colors.gray, "TEMP")
    drawHBar(22, 7, barW, info.fieldPct, colors.lime, colors.gray, "FIELD")
    drawHBar(22, 9, barW, info.satPct, colors.cyan, colors.gray, "SAT")
    drawHBar(22,11, barW, info.fuelPct, colors.orange, colors.gray, "FUEL")
  else
    writeAt(2, 5, "Waiting for reactor data...", colors.yellow, colors.black)
  end

  writeAt(2, h - 4, "Targets: T=" .. settings.targets.temp
    .. "C F=" .. settings.targets.field
    .. "% S=" .. settings.targets.sat
    .. "% O=" .. fmtRF(settings.targets.output), colors.white, colors.black)

  writeAt(2, h - 3, state.message:sub(1, math.max(1, w - 2)), colors.lightGray, colors.black)

  local by = h - 1
  local bw = math.max(8, math.floor((w - 5) / 4))
  local gap = 1
  local x1 = 1
  local x2 = x1 + bw + gap
  local x3 = x2 + bw + gap
  local x4 = x3 + bw + gap

  addButton(x1, by - 1, bw, 2, "CHARGE", colors.orange, colors.black, function()
    state.scrammed = false
    pcall(reactorCharge)
    state.message = "Charge command sent"
  end)

  addButton(x2, by - 1, bw, 2, "ACTIVATE", colors.lime, colors.black, function()
    state.scrammed = false
    pcall(reactorActivate)
    state.message = "Activate command sent"
  end)

  addButton(x3, by - 1, bw, 2, "SCRAM", colors.red, colors.white, function()
    if state.info then
      hardScram(state.info, "manual scram")
    else
      state.scrammed = true
      pcall(reactorStop)
      state.message = "Manual SCRAM"
    end
  end)

  addButton(x4, by - 1, bw, 2, "TUNING", colors.blue, colors.white, function()
    state.page = "tune"
    state.message = "Tuning page"
  end)
end

local function adjustSetting(path1, path2, delta, lo, hi)
  settings[path1][path2] = clamp(settings[path1][path2] + delta, lo, hi)
  saveSettings(true)
end

local function drawTuneRow(y, label, value, buttons, valueColor)
  local w = screen.w
  writeAt(2, y, label, colors.lightGray, colors.black)
  writeAt(math.floor(w / 2) - 6, y, tostring(value), valueColor or colors.white, colors.black)

  local x = w - 1
  for i = #buttons, 1, -1 do
    local b = buttons[i]
    local bw = #b.label + 2
    x = x - bw + 1
    addButton(x, y, bw, 1, b.label, b.bg or colors.gray, b.fg or colors.white, b.fn)
    x = x - 1
  end
end

local function drawTunePage()
  clearFrame(colors.black)
  local w, h = screen.w, screen.h

  writeAt(1, 1, centerText(w, "TUNING"), colors.white, colors.blue)
  writeAt(2, 3, "Adjust reactor targets.", colors.white, colors.black)
  writeAt(2, 4, "Output target now supports multi-million and 100M jumps.", colors.lightGray, colors.black)

