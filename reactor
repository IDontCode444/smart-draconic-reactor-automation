-- BOOT
--========================================================--

term.clear()
term.setCursorPos(1, 1)
print(CONFIG.appName .. " v" .. CONFIG.version)
print("Initializing peripherals...")

initPeripherals()

print(" Reactor: " .. CONFIG.reactorName)
print(" Input:   " .. CONFIG.inputGateName)
print(" Output:  " .. CONFIG.outputGateName)
print(" Monitor: " .. monName)
print("")
print("Ready.")

setStatus("System ready", colors.lime)
parallel.waitForAny(controlLoop, uiLoop, eventLoop)
