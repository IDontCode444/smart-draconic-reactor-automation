-- Draconic Evolution Reactor Controller for CC:Tweaked / ATM10 6.2
-- Features:
--   - Separate PID for input and output
--   - Slow startup ramp
--   - Auto SCRAM with proper arming/disarming logic
--   - Live field target buttons: 45/50/55/60%
--   - Monitor autodetect + monitor touch support
--   - Large-monitor friendly UI
--   - Compatibility detection for common reactor/gate methods
--   - Retuned for safer ATM10 75x startup and sustained output

local CONFIG = {
  REACTOR_NAME = "draconic_reactor_0",
  INPUT_GATE_NAME = "flow_gate_0",
  OUTPUT_GATE_NAME = "flow_gate_1",

  LOOP_INTERVAL = 0.05,
  UI_REFRESH = 0.20,
  MONITOR_TEXT_SCALE = 0.5,

  TARGET_TEMP = 8000,
  TARGET_SAT = 0.42,
  FIELD_TARGET_OPTIONS = { 0.45, 0.50, 0.55, 0.60 },
  DEFAULT_FIELD_TARGET = 0.50,

  CHARGE_INFLOW = 300000000,
  CHARGE_RETRY_SECONDS = 2,

  CHARGE_READY_FIELD = 0.48,
  CHARGE_READY_SAT = 0.48,
  CHARGE_HOLD_INPUT = 300000000,

  STARTUP_PRIME_INPUT = 800000000,
  STARTUP_PUNCH_INPUT = 1200000000,
  STARTUP_PUNCH_SECONDS = 6,
  STARTUP_HOLD_SECONDS = 32,
  STARTUP_SCRAM_GRACE_SECONDS = 12,
  STARTUP_MIN_FIELD_FOR_ARM = 0.28,

  RAMP_SECONDS = 300,
  RAMP_START_FIELD = 0.58,
  RAMP_START_SAT = 0.78,

  SCRAM_TEMP = 8650,
  SCRAM_FIELD = 0.22,
  SCRAM_SAT = 0.10,
  SCRAM_NO_FUEL = 0.002,
  SCRAM_FIELD_RECOVERY = 0.75,
  SCRAM_COOLDOWN_OUTPUT = 0,

  TEMP_HIGH_BAND = 8250,
  TEMP_LOW_BAND = 7600,
  SAT_SOFT_LOW = 0.28,
  SAT_SOFT_HIGH = 0.85,

  MAX_INPUT = 1500000000,
  MAX_OUTPUT = 260000000,
  DRAW_SCALE = 1.0,

  PID_INPUT = {
    kp = 1.20, ki = 0.06, kd = 0.10,
    min = -250000000, max = 900000000,
    integralMin = -500000000, integralMax = 900000000,
  },

  PID_OUTPUT = {
    kp = 1.25, ki = 0.08, kd = 0.30,
    min = 0, max = 260000000,
    integralMin = -120000000, integralMax = 120000000,
  },
}

local reactor, gateIn, gateOut
local display = term.current()
local usingMonitor = false
local monitorName = nil

local api = {
  reactorInfo = nil,
  charge = nil,
  activate = nil,
  stop = nil,
  failSafe = nil,
  gateEnable = nil,
  gateFlow = nil,
}

local state = {
  mode = "IDLE", -- IDLE, CHARGING, READY, STARTING, RUNNING, STOPPING, SCRAM
  targetField = CONFIG.DEFAULT_FIELD_TARGET,
  manualOutputBias = 1.0,

  lastInfo = nil,
  lastLoopAt = os.clock(),
  rampStart = nil,
  holdUntil = nil,
  startupPunchUntil = nil,
  startupGraceUntil = nil,
  scramReason = nil,
  scramArmed = false,
  lastChargeAttempt = 0,

  inputOverride = 0,
  outputOverride = 0,

  buttons = {},
  log = {},

  displaySummary = "computer terminal",
  apiSummary = "detecting...",
}

local function now()
  return os.clock()
end

local function clamp(v, lo, hi)
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

local function round(v)
  return math.floor(v + 0.5)
end

local function pct(v)
  return math.floor(v * 1000 + 0.5) / 10
end

local function pushLog(msg)
  local stamp = textutils.formatTime(os.time(), true)
  table.insert(state.log, 1, ("[%s] %s"):format(stamp, msg))
  while #state.log > 12 do
    table.remove(state.log)
  end
end

local function safeCall(fn, ...)
  local ok, a, b, c = pcall(fn, ...)
  if ok then return true, a, b, c end
  return false, a
end

local function wrapPeripheral(name, expected)
  local p = peripheral.wrap(name)
  if not p then
    error(("Peripheral '%s' was not found"):format(name))
  end

  local t = peripheral.getType(name)
  if expected and t ~= expected then
    pushLog(("Warning: '%s' type '%s' (expected '%s')"):format(name, tostring(t), expected))
  end

  return p
end

local function getMethod(obj, candidates)
  for _, name in ipairs(candidates) do
    if type(obj[name]) == "function" then
      return name
    end
  end
  return nil
end

local function requireMethod(obj, candidates, label)
  local name = getMethod(obj, candidates)
  if not name then
    error(("Missing %s. Tried: %s"):format(label, table.concat(candidates, ", ")))
  end
  return name
end

local function detectAPIs()
  api.reactorInfo = requireMethod(reactor, {
    "getReactorInfo", "getInfo", "info"
  }, "reactor info method")

  api.charge = requireMethod(reactor, {
    "chargeReactor", "charge"
  }, "reactor charge method")

  api.activate = requireMethod(reactor, {
    "activateReactor", "activate", "startup", "startReactor"
  }, "reactor activate method")

  api.stop = requireMethod(reactor, {
    "stopReactor", "stop", "shutdown", "deactivateReactor"
  }, "reactor stop method")

  api.failSafe = getMethod(reactor, {
    "setFailSafe", "setFailsafe", "enableFailSafe", "enableFailsafe"
  })

  api.gateEnable = requireMethod(gateIn, {
    "setOverrideEnabled"
  }, "flow gate enable method")

  api.gateFlow = requireMethod(gateIn, {
    "setFlowOverride", "setFlow", "setTransferRate"
  }, "flow gate flow method")

  state.apiSummary = ("info=%s charge=%s start=%s stop=%s gateEnable=%s gateFlow=%s"):format(
    tostring(api.reactorInfo),
    tostring(api.charge),
    tostring(api.activate),
    tostring(api.stop),
    tostring(api.gateEnable),
    tostring(api.gateFlow)
  )

  pushLog("API detected")
end

local function callReactor(which, ...)
  local methodName = api[which]
  if not methodName then
    return false, "missing reactor method mapping: " .. tostring(which)
  end

  local fn = reactor[methodName]
  if type(fn) ~= "function" then
    return false, "reactor method not callable: " .. tostring(methodName)
  end

  return safeCall(fn, ...)
end

local function callGateEnable(gate, enabled)
  local fn = gate[api.gateEnable]
  if type(fn) ~= "function" then
    return false, "gate enable method not callable"
  end
  return safeCall(fn, enabled)
end

local function callGateFlow(gate, value)
  local fn = gate[api.gateFlow]
  if type(fn) ~= "function" then
    return false, "gate flow method not callable"
  end
  return safeCall(fn, value)
end

local function getBestMonitor()
  local bestName = nil
  local bestArea = -1

  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "monitor" then
      local mon = peripheral.wrap(name)
      local ok = pcall(function() mon.setTextScale(CONFIG.MONITOR_TEXT_SCALE) end)
      if ok then
        local w, h = mon.getSize()
        local area = w * h
        if area > bestArea then
          bestArea = area
          bestName = name
        end
      end
    end
  end

  return bestName
end

local function setupDisplay()
  local best = getBestMonitor()

  if best then
    monitorName = best
    display = peripheral.wrap(best)
    usingMonitor = true
    pcall(function() display.setTextScale(CONFIG.MONITOR_TEXT_SCALE) end)
    state.displaySummary = "monitor: " .. best
    pushLog("Using monitor: " .. best)
  else
    display = term.current()
    usingMonitor = false
    monitorName = nil
    state.displaySummary = "computer terminal"
    pushLog("Using computer terminal")
  end
end

local function clearDisplay()
  display.setBackgroundColor(colors.black)
  display.setTextColor(colors.white)
  display.clear()
  display.setCursorPos(1, 1)
end

local function getDisplaySize()
  return display.getSize()
end

local function writeAt(x, y, text, txt, bg)
  display.setCursorPos(x, y)
  display.setTextColor(txt or colors.white)
  display.setBackgroundColor(bg or colors.black)
  display.write(text)
end

local function centerText(y, text, txt, bg)
  local w = getDisplaySize()
  local x = math.max(1, math.floor((w - #text) / 2) + 1)
  writeAt(x, y, text, txt, bg)
end

local function progressBar(x, y, width, ratio, color, label)
  ratio = clamp(ratio, 0, 1)

  display.setCursorPos(x, y)
  display.setBackgroundColor(colors.gray)
  display.write(string.rep(" ", width))

  display.setCursorPos(x, y)
  display.setBackgroundColor(color)
  display.write(string.rep(" ", math.floor(width * ratio)))

  if width > 2 then
    label = tostring(label)
    if #label > width - 2 then
      label = label:sub(1, width - 2)
    end
    display.setCursorPos(x + 1, y)
    display.setBackgroundColor(colors.black)
    display.setTextColor(colors.white)
    display.write(label)
  end
end

local function button(name, x, y, w, label, bg, fg)
  if w < 4 then return end
  state.buttons[name] = { x = x, y = y, w = w, h = 1 }
  display.setCursorPos(x, y)
  display.setBackgroundColor(bg)
  display.setTextColor(fg or colors.white)
  local padded = " " .. label .. string.rep(" ", math.max(0, w - #label - 1))
  display.write(padded:sub(1, w))
end

local function hitButton(x, y)
  for name, b in pairs(state.buttons) do
    if x >= b.x and x < (b.x + b.w) and y >= b.y and y < (b.y + b.h) then
      return name
    end
  end
end

local function newPID(cfg)
  return {
    kp = cfg.kp, ki = cfg.ki, kd = cfg.kd,
    min = cfg.min, max = cfg.max,
    integralMin = cfg.integralMin, integralMax = cfg.integralMax,
    integral = 0,
    prevError = 0,
    first = true,
  }
end

local pidInput = newPID(CONFIG.PID_INPUT)
local pidOutput = newPID(CONFIG.PID_OUTPUT)

local function resetPID(pid)
  pid.integral = 0
  pid.prevError = 0
  pid.first = true
end

local function resetAllPIDs()
  resetPID(pidInput)
  resetPID(pidOutput)
end

local function stepPID(pid, err, dt)
  dt = math.max(dt, 0.001)

  pid.integral = clamp(pid.integral + err * dt, pid.integralMin, pid.integralMax)

  local derivative = 0
  if not pid.first then
    derivative = (err - pid.prevError) / dt
  end

  pid.first = false
  pid.prevError = err

  return clamp(pid.kp * err + pid.ki * pid.integral + pid.kd * derivative, pid.min, pid.max)
end

local function normalizeStatus(s)
  s = tostring(s or ""):lower()

  if s == "online" then return "running" end
  if s == "warming_up" or s == "warming" then return "starting" end
  if s == "stopping" then return "stopping" end
  if s == "cooling" then return "cooling" end
  if s == "cold" then return "cold" end
  if s == "charged" then return "charged" end
  if s == "running" then return "running" end

  return s
end

local function readInfo()
  local ok, info = callReactor("reactorInfo")
  if not ok then
    error("Reactor info failed: " .. tostring(info))
  end
  if not info then
    error("Reactor info returned nil")
  end

  local d = {}

  if type(info) == "table" and info.temperature ~= nil then
    d.temperature = tonumber(info.temperature) or 0
    d.fieldStrength = tonumber(info.fieldStrength) or 0
    d.maxFieldStrength = tonumber(info.maxFieldStrength) or 1
    d.energySaturation = tonumber(info.energySaturation) or 0
    d.maxEnergySaturation = tonumber(info.maxEnergySaturation) or 1
    d.fuelConversion = tonumber(info.fuelConversion) or 0
    d.maxFuelConversion = tonumber(info.maxFuelConversion) or 1
    d.generationRate = tonumber(info.generationRate) or 0
    d.fieldDrainRate = tonumber(info.fieldDrainRate) or 0
    d.fuelConversionRate = tonumber(info.fuelConversionRate) or 0
    d.status = normalizeStatus(info.status)
  elseif type(info) == "table" then
    d.temperature = tonumber(info[1]) or 0
    d.fieldStrength = tonumber(info[2]) or 0
    d.maxFieldStrength = tonumber(info[3]) or 1
    d.energySaturation = tonumber(info[4]) or 0
    d.maxEnergySaturation = tonumber(info[5]) or 1
    d.fuelConversion = tonumber(info[6]) or 0
    d.maxFuelConversion = tonumber(info[7]) or 1
    d.generationRate = tonumber(info[8]) or 0
    d.fieldDrainRate = tonumber(info[9]) or 0
    d.fuelConversionRate = tonumber(info[10]) or 0
    d.status = normalizeStatus(info[11])
  else
    error("Unsupported reactor info format")
  end

  d.fieldPct = (d.maxFieldStrength > 0) and (d.fieldStrength / d.maxFieldStrength) or 0
  d.satPct = (d.maxEnergySaturation > 0) and (d.energySaturation / d.maxEnergySaturation) or 0
  d.fuelPct = 1 - ((d.maxFuelConversion > 0) and (d.fuelConversion / d.maxFuelConversion) or 1)

  return d
end

local function setFlows(input, output)
  input = clamp(round(input), 0, CONFIG.MAX_INPUT)
  output = clamp(round(output), 0, CONFIG.MAX_OUTPUT)

  state.inputOverride = input
  state.outputOverride = output

  local ok1, err1 = callGateFlow(gateIn, input)
  local ok2, err2 = callGateFlow(gateOut, round(output * CONFIG.DRAW_SCALE))

  if not ok1 then pushLog("Input gate set failed: " .. tostring(err1)) end
  if not ok2 then pushLog("Output gate set failed: " .. tostring(err2)) end
end

local function calcFieldFeedForward(info, targetField)
  targetField = clamp(targetField, 0.01, 0.99)
  local drain = info.fieldDrainRate or 0
  local sustain = drain / math.max(0.02, (1 - targetField))
  return clamp(sustain, 0, CONFIG.MAX_INPUT)
end

local function getSoftFieldLow()
  return math.max(0.38, state.targetField - 0.06)
end

local function reactorIsChargeReady(info)
  if not info then return false end
  return info.fieldPct >= CONFIG.CHARGE_READY_FIELD
     and info.satPct >= CONFIG.CHARGE_READY_SAT
end

local function inStartupGrace()
  return state.mode == "STARTING" and state.startupGraceUntil and now() < state.startupGraceUntil
end

local function shouldScram(info)
  if not state.scramArmed then
    return false, nil
  end

  if info.temperature >= CONFIG.SCRAM_TEMP then
    return true, ("temperature %.1f >= %.0f"):format(info.temperature, CONFIG.SCRAM_TEMP)
  end

  if not inStartupGrace() and info.fieldPct <= CONFIG.SCRAM_FIELD then
    return true, ("field %.1f%% <= %.1f%%"):format(pct(info.fieldPct), pct(CONFIG.SCRAM_FIELD))
  end

  if info.temperature > 2500 and info.satPct <= CONFIG.SCRAM_SAT then
    return true, ("saturation %.1f%% <= %.1f%%"):format(pct(info.satPct), pct(CONFIG.SCRAM_SAT))
  end

  if info.temperature > 2500 and info.fuelPct <= CONFIG.SCRAM_NO_FUEL then
    return true, "fuel exhausted"
  end

  if info.temperature > 3000 and info.satPct >= 0.995 then
    return true, "saturation nearly full; runaway heat risk"
  end

  return false, nil
end

local function scram(reason)
  state.mode = "SCRAM"
  state.scramReason = reason
  state.scramArmed = true
  resetAllPIDs()

  callReactor("stop")
  setFlows(calcFieldFeedForward(state.lastInfo or { fieldDrainRate = 0 }, CONFIG.SCRAM_FIELD_RECOVERY), CONFIG.SCRAM_COOLDOWN_OUTPUT)
  pushLog("AUTO SCRAM: " .. reason)
end

local function stopReactorControlled()
  state.mode = "STOPPING"
  state.scramReason = nil
  state.scramArmed = true
  resetAllPIDs()
  callReactor("stop")
  pushLog("Stop requested")
end

local function getRampTargets()
  if not state.rampStart then
    return state.targetField, CONFIG.TARGET_SAT, 1
  end

  local t = clamp((now() - state.rampStart) / CONFIG.RAMP_SECONDS, 0, 1)
  local fieldTarget = CONFIG.RAMP_START_FIELD + (state.targetField - CONFIG.RAMP_START_FIELD) * t
  local satTarget = CONFIG.RAMP_START_SAT + (CONFIG.TARGET_SAT - CONFIG.RAMP_START_SAT) * t

  return fieldTarget, satTarget, t
end

local function updateCharging(info)
  state.scramReason = nil
  state.scramArmed = false
  setFlows(CONFIG.CHARGE_INFLOW, 0)

  if not reactorIsChargeReady(info) then
    if (now() - (state.lastChargeAttempt or 0)) >= CONFIG.CHARGE_RETRY_SECONDS then
      local ok, err = callReactor("charge")
      state.lastChargeAttempt = now()

      if ok then
        pushLog("Charge re-requested")
      else
        pushLog("Charge retry failed: " .. tostring(err))
      end
    end
    return
  end

  state.mode = "READY"
  setFlows(CONFIG.CHARGE_HOLD_INPUT, 0)
end

local function updateReady(info)
  state.scramReason = nil
  state.scramArmed = false

  local holdInput = CONFIG.CHARGE_HOLD_INPUT
  if info.fieldPct < CONFIG.CHARGE_READY_FIELD then
    holdInput = CONFIG.MAX_INPUT
  end

  setFlows(holdInput, 0)

  if not reactorIsChargeReady(info) then
    if (now() - (state.lastChargeAttempt or 0)) >= CONFIG.CHARGE_RETRY_SECONDS then
      local ok, err = callReactor("charge")
      state.lastChargeAttempt = now()

      if ok then
        pushLog("Charge touch-up requested")
      else
        pushLog("Charge touch-up failed: " .. tostring(err))
      end
    end
  end
end

local function updateStopping(info)
  state.scramArmed = true

  local sustain = calcFieldFeedForward(info, CONFIG.SCRAM_FIELD_RECOVERY)
  setFlows(sustain, 0)

  if info.status == "cold" or info.temperature < 2100 then
    state.scramArmed = false
    setFlows(0, 0)
    state.mode = "IDLE"
    pushLog("Reactor stopped")
  end
end

local function updateScram(info)
  state.scramArmed = true

  local sustain = calcFieldFeedForward(info, CONFIG.SCRAM_FIELD_RECOVERY)
  setFlows(sustain, 0)

  if info.status == "cold" or info.temperature < 2100 then
    state.scramArmed = false
    setFlows(0, 0)
  end
end

local function updateRunning(info, dt)
  local fieldTarget, satTarget, rampProgress = getRampTargets()

  if state.mode == "STARTING" then
    if inStartupGrace() then
      state.scramArmed = false

      local startupInput = CONFIG.STARTUP_PUNCH_INPUT
      if info.fieldPct < 0.20 then
        startupInput = CONFIG.MAX_INPUT
      elseif info.fieldPct < CONFIG.STARTUP_MIN_FIELD_FOR_ARM then
        startupInput = math.max(CONFIG.STARTUP_PUNCH_INPUT, CONFIG.STARTUP_PRIME_INPUT * 1.35)
      end

      setFlows(startupInput, 0)
      return
    end

    if info.fieldPct >= CONFIG.STARTUP_MIN_FIELD_FOR_ARM or (state.startupGraceUntil and now() >= state.startupGraceUntil) then
      state.scramArmed = true
    end

    if now() < (state.holdUntil or 0) then
      local startupField = math.max(fieldTarget, CONFIG.RAMP_START_FIELD)
      local startupInput = math.max(calcFieldFeedForward(info, startupField), CONFIG.STARTUP_PRIME_INPUT)

      if now() < (state.startupPunchUntil or 0) then
        startupInput = CONFIG.STARTUP_PUNCH_INPUT
      elseif info.fieldPct < 0.20 then
        startupInput = CONFIG.MAX_INPUT
      elseif info.fieldPct < 0.35 then
        startupInput = math.max(startupInput, CONFIG.STARTUP_PRIME_INPUT * 1.20)
      elseif info.fieldPct < 0.50 then
        startupInput = math.max(startupInput, CONFIG.STARTUP_PRIME_INPUT)
      end

      setFlows(startupInput, 0)
      return
    else
      state.mode = "RUNNING"
      state.scramArmed = true
      pushLog("Closed-loop control engaged")
    end
  else
    if (info.status == "running" or info.status == "starting" or info.temperature >= 2000 or info.fieldPct >= 0.10) then
      state.scramArmed = true
    end
  end

  local feedForward = calcFieldFeedForward(info, fieldTarget)
  local fieldError = fieldTarget - info.fieldPct
  local inputPidOut = stepPID(pidInput, fieldError, dt)
  local inputCmd = clamp(feedForward + inputPidOut, 0, CONFIG.MAX_INPUT)

  local satError = info.satPct - satTarget
  local outputCmd = stepPID(pidOutput, satError, dt)

  if info.temperature < CONFIG.TEMP_LOW_BAND then
    outputCmd = outputCmd * 0.10
  elseif info.temperature < CONFIG.TARGET_TEMP then
    outputCmd = outputCmd * clamp(
      (info.temperature - CONFIG.TEMP_LOW_BAND) / math.max(1, (CONFIG.TARGET_TEMP - CONFIG.TEMP_LOW_BAND)),
      0.10, 1.0
    )
  elseif info.temperature > CONFIG.TEMP_HIGH_BAND then
    local extra = (info.temperature - CONFIG.TEMP_HIGH_BAND) / math.max(1, (CONFIG.SCRAM_TEMP - CONFIG.TEMP_HIGH_BAND))
    outputCmd = clamp(outputCmd + extra * CONFIG.MAX_OUTPUT * 0.30, 0, CONFIG.MAX_OUTPUT)
  end

  if info.fieldPct < getSoftFieldLow() then
    outputCmd = outputCmd * 0.15
    inputCmd = math.max(inputCmd, calcFieldFeedForward(info, math.max(fieldTarget, 0.68)))
  end

  if info.fieldPct < 0.30 then
    outputCmd = 0
    inputCmd = math.max(inputCmd, calcFieldFeedForward(info, 0.75))
  elseif info.fieldPct < 0.40 then
    outputCmd = math.min(outputCmd, CONFIG.MAX_OUTPUT * 0.03)
    inputCmd = math.max(inputCmd, calcFieldFeedForward(info, 0.70))
  elseif info.fieldPct < 0.50 then
    outputCmd = math.min(outputCmd, CONFIG.MAX_OUTPUT * 0.12)
  elseif info.fieldPct < 0.60 then
    outputCmd = math.min(outputCmd, CONFIG.MAX_OUTPUT * 0.35)
  end

  if info.satPct < CONFIG.SAT_SOFT_LOW then
    outputCmd = outputCmd * 0.10
  elseif info.satPct < satTarget then
    local satScale = clamp(
      (info.satPct - CONFIG.SAT_SOFT_LOW) / math.max(0.01, (satTarget - CONFIG.SAT_SOFT_LOW)),
      0.12, 1.0
    )
    outputCmd = outputCmd * satScale
  elseif info.satPct > CONFIG.SAT_SOFT_HIGH then
    outputCmd = math.max(outputCmd, CONFIG.MAX_OUTPUT * 0.65)
  end

  if rampProgress < 0.20 then
    outputCmd = math.min(outputCmd, CONFIG.MAX_OUTPUT * 0.05)
  elseif rampProgress < 0.40 then
    outputCmd = math.min(outputCmd, CONFIG.MAX_OUTPUT * 0.18)
  elseif rampProgress < 0.60 then
    outputCmd = math.min(outputCmd, CONFIG.MAX_OUTPUT * 0.35)
  elseif rampProgress < 0.80 then
    outputCmd = math.min(outputCmd, CONFIG.MAX_OUTPUT * 0.60)
  end

  outputCmd = outputCmd * clamp(rampProgress, 0.05, 1.0) * state.manualOutputBias

  setFlows(inputCmd, outputCmd)
end

local function updateController()
  local info = readInfo()
  state.lastInfo = info

  if state.mode == "IDLE" or state.mode == "CHARGING" or state.mode == "READY" then
    state.scramArmed = false
  end

  if info.temperature < 2000 and info.fieldPct < 0.05 and info.satPct < 0.05 and info.status == "cold" then
    state.scramArmed = false
  end

  local t = now()
  local dt = math.max(0.02, t - state.lastLoopAt)
  state.lastLoopAt = t

  local kill, reason = shouldScram(info)
  if kill and state.mode ~= "SCRAM" then
    scram(reason)
    return
  end

  if state.mode == "CHARGING" then
    updateCharging(info)
  elseif state.mode == "READY" then
    updateReady(info)
  elseif state.mode == "STARTING" or state.mode == "RUNNING" then
    updateRunning(info, dt)
  elseif state.mode == "STOPPING" then
    updateStopping(info)
  elseif state.mode == "SCRAM" then
    updateScram(info)
  else
    setFlows(0, 0)
  end
end

local function drawFieldButtons(x, y)
  writeAt(x, y, "Field:", colors.lightGray)
  local bx = x + 7
  for i, v in ipairs(CONFIG.FIELD_TARGET_OPTIONS) do
    local active = math.abs(state.targetField - v) < 0.001
    button(
      "field_" .. i,
      bx, y, 6,
      ("%d%%"):format(round(v * 100)),
      active and colors.lime or colors.gray,
      active and colors.black or colors.white
    )
    bx = bx + 7
  end
end

local function drawControls(y1, y2)
  button("charge", 2,  y1, 12, "Charge", colors.blue)
  button("start",  16, y1, 12, "Start",  colors.green)
  button("stop",   30, y1, 12, "Stop",   colors.orange)
  button("scram",  44, y1, 12, "SCRAM",  colors.red)

  button("biasDown",  2,  y2, 12, "Draw -10%", colors.gray)
  button("biasUp",    16, y2, 12, "Draw +10%", colors.gray)
  button("biasReset", 30, y2, 12, "Draw 100%", colors.gray)
  writeAt(44, y2, ("Bias %.0f%%"):format(state.manualOutputBias * 100), colors.white)
end

local function drawUI()
  clearDisplay()
  state.buttons = {}

  local w, h = getDisplaySize()
  local info = state.lastInfo

  centerText(1, "Draconic Reactor PID Controller", colors.cyan)
  writeAt(2, 2, state.displaySummary, colors.gray)

  local modeColor = colors.yellow
  if state.mode == "RUNNING" then modeColor = colors.lime end
  if state.mode == "SCRAM" then modeColor = colors.red end
  if state.mode == "STOPPING" then modeColor = colors.orange end
  if state.mode == "STARTING" then modeColor = colors.orange end
  if state.mode == "CHARGING" then modeColor = colors.cyan end
  if state.mode == "READY" then modeColor = colors.lime end

  writeAt(2, 3, "Mode: ", colors.lightGray)
  writeAt(8, 3, state.mode, modeColor)
  writeAt(2, 4, "SCRAM armed: " .. (state.scramArmed and "YES" or "NO"), state.scramArmed and colors.red or colors.lime)

  if not info then
    writeAt(2, 6, "Waiting for reactor data...", colors.orange)
  else
    local leftX = 2
    local rightX = math.max(36, math.floor(w / 2))

    writeAt(leftX, 6, ("Status: %s"):format(tostring(info.status)), colors.white)
    writeAt(leftX, 7, ("Temp: %.1f C"):format(info.temperature), colors.white)
    writeAt(leftX, 8, ("Field: %.1f%%"):format(pct(info.fieldPct)), colors.white)
    writeAt(leftX, 9, ("Sat: %.1f%%"):format(pct(info.satPct)), colors.white)
    writeAt(leftX, 10, ("Fuel: %.2f%%"):format(info.fuelPct * 100), colors.white)
    writeAt(leftX, 11, ("Gen: %.0f RF/t"):format(info.generationRate or 0), colors.white)
    writeAt(leftX, 12, ("In:  %d RF/t"):format(state.inputOverride), colors.lightBlue)
    writeAt(leftX, 13, ("Out: %d RF/t"):format(state.outputOverride), colors.lightBlue)

    writeAt(rightX, 6, ("Target Temp: %.0f C"):format(CONFIG.TARGET_TEMP), colors.white)
    writeAt(rightX, 7, ("Target Field: %.1f%%"):format(pct(state.targetField)), colors.white)
    writeAt(rightX, 8, ("Target Sat: %.1f%%"):format(pct(CONFIG.TARGET_SAT)), colors.white)
    writeAt(rightX, 9, ("Drain: %.0f RF/t"):format(info.fieldDrainRate or 0), colors.white)
    writeAt(rightX, 10, ("Burn: %.6f/t"):format(info.fuelConversionRate or 0), colors.white)
    writeAt(rightX, 11, ("Bias: %.0f%%"):format(state.manualOutputBias * 100), colors.white)

    local barWidth = math.max(20, w - 4)
    progressBar(2, 15, barWidth, info.fieldPct, colors.blue, ("Field %.1f%%"):format(pct(info.fieldPct)))
    progressBar(2, 16, barWidth, info.satPct, colors.orange, ("Sat %.1f%%"):format(pct(info.satPct)))
    progressBar(2, 17, barWidth, clamp(info.temperature / CONFIG.SCRAM_TEMP, 0, 1), colors.red, ("Temp %.0f / %.0f"):format(info.temperature, CONFIG.SCRAM_TEMP))
  end

  drawFieldButtons(2, 19)

  if state.scramReason then
    writeAt(2, 21, "SCRAM reason: " .. state.scramReason, colors.red)
  elseif inStartupGrace() then
    writeAt(2, 21, ("Startup grace: %.1fs"):format(math.max(0, state.startupGraceUntil - now())), colors.orange)
  elseif state.mode == "READY" then
    writeAt(2, 21, "Charge ready - shield held - press Start", colors.lime)
  end

  local apiY = math.max(22, h - 6)
  if apiY < h - 3 then
    local s = state.apiSummary
    if #s > (w - 4) then
      s = s:sub(1, w - 7) .. "..."
    end
    writeAt(2, apiY, s, colors.gray)
  end

  if h >= 27 then
    drawControls(h - 3, h - 1)
  end

  local logY = math.max(23, apiY + 1)
  if logY < h - 4 then
    writeAt(2, logY, "Log:", colors.lightGray)
    local maxLines = h - logY - 4
    for i = 1, math.min(#state.log, maxLines) do
      writeAt(2, logY + i, state.log[i]:sub(1, w - 2), colors.lightGray)
    end
  end
end

local function doCharge()
  resetAllPIDs()
  state.scramReason = nil
  state.scramArmed = false
  state.mode = "CHARGING"
  state.rampStart = nil
  state.holdUntil = nil
  state.startupPunchUntil = nil
  state.startupGraceUntil = nil
  state.lastChargeAttempt = 0

  local ok, err = callReactor("charge")
  state.lastChargeAttempt = now()

  if ok then
    pushLog("Charge requested")
  else
    pushLog("Charge failed: " .. tostring(err))
  end
end

local function doStart()
  local info = state.lastInfo

  if not reactorIsChargeReady(info) then
    pushLog(("Start blocked: live charge too low (field %.1f%% sat %.1f%%)"):format(
      pct(info and info.fieldPct or 0), pct(info and info.satPct or 0)
    ))
    return
  end

  resetAllPIDs()
  state.scramReason = nil
  state.scramArmed = false
  state.mode = "STARTING"
  state.holdUntil = now() + CONFIG.STARTUP_HOLD_SECONDS
  state.startupPunchUntil = now() + CONFIG.STARTUP_PUNCH_SECONDS
  state.startupGraceUntil = now() + CONFIG.STARTUP_SCRAM_GRACE_SECONDS
  state.rampStart = now()

  setFlows(CONFIG.MAX_INPUT, 0)

  local ok, err = callReactor("activate")
  if ok then
    pushLog("Start requested")
  else
    pushLog("Start failed: " .. tostring(err))
  end
end

local function setFieldTarget(v)
  state.targetField = v
  resetAllPIDs()
  pushLog(("Field target set to %.0f%%"):format(v * 100))
end

local function handleButton(name)
  if not name then return end

  if name == "charge" then
    doCharge()
  elseif name == "start" then
    doStart()
  elseif name == "stop" then
    stopReactorControlled()
  elseif name == "scram" then
    scram("manual SCRAM button")
  elseif name == "biasDown" then
    state.manualOutputBias = clamp(state.manualOutputBias - 0.10, 0.5, 1.5)
    pushLog(("Draw bias %.0f%%"):format(state.manualOutputBias * 100))
  elseif name == "biasUp" then
    state.manualOutputBias = clamp(state.manualOutputBias + 0.10, 0.5, 1.5)
    pushLog(("Draw bias %.0f%%"):format(state.manualOutputBias * 100))
  elseif name == "biasReset" then
    state.manualOutputBias = 1.0
    pushLog("Draw bias reset")
  else
    for i, v in ipairs(CONFIG.FIELD_TARGET_OPTIONS) do
      if name == ("field_" .. i) then
        setFieldTarget(v)
        return
      end
    end
  end
end

local function setupPeripherals()
  reactor = wrapPeripheral(CONFIG.REACTOR_NAME, "draconic_reactor")
  gateIn = wrapPeripheral(CONFIG.INPUT_GATE_NAME, "flow_gate")
  gateOut = wrapPeripheral(CONFIG.OUTPUT_GATE_NAME, "flow_gate")

  detectAPIs()

  local ok1, err1 = callGateEnable(gateIn, true)
  local ok2, err2 = callGateEnable(gateOut, true)
  local ok3, err3 = callGateFlow(gateIn, 0)
  local ok4, err4 = callGateFlow(gateOut, 0)

  if not ok1 then pushLog("Input gate enable failed: " .. tostring(err1)) end
  if not ok2 then pushLog("Output gate enable failed: " .. tostring(err2)) end
  if not ok3 then pushLog("Input gate zero failed: " .. tostring(err3)) end
  if not ok4 then pushLog("Output gate zero failed: " .. tostring(err4)) end

  pushLog("Peripherals connected")
end

local function bootstrap()
  setupDisplay()
  clearDisplay()
  setupPeripherals()

  if api.failSafe and type(reactor[api.failSafe]) == "function" then
    local ok = safeCall(reactor[api.failSafe], true)
    if ok then
      pushLog("Reactor fail-safe enabled")
    end
  end

  pushLog("Targets: 8000C / variable field / 42% sat")
  pushLog("Default field target: 50%")
  pushLog("75x startup retune loaded")
  pushLog("READY mode holds start charge")
  if usingMonitor then
    pushLog("Monitor touch enabled")
  end
  pushLog("Ready")
end

local function uiLoop()
  local timer = os.startTimer(CONFIG.UI_REFRESH)

  while true do
    drawUI()
    local ev = { os.pullEvent() }

    if ev[1] == "mouse_click" then
      handleButton(hitButton(ev[3], ev[4]))
    elseif ev[1] == "monitor_touch" then
      if usingMonitor and ev[2] == monitorName then
        handleButton(hitButton(ev[3], ev[4]))
      end
    elseif ev[1] == "term_resize" then
      drawUI()
    elseif ev[1] == "peripheral" or ev[1] == "peripheral_detach" then
      local old = monitorName
      setupDisplay()
      if old ~= monitorName then
        pushLog("Display updated")
      end
      drawUI()
    elseif ev[1] == "timer" and ev[2] == timer then
      timer = os.startTimer(CONFIG.UI_REFRESH)
    end
  end
end

local function controlLoop()
  while true do
    local ok, err = pcall(updateController)
    if not ok then
      pushLog("Controller error: " .. tostring(err))
      pcall(function() setFlows(0, 0) end)
    end
    sleep(CONFIG.LOOP_INTERVAL)
  end
end

bootstrap()
parallel.waitForAny(controlLoop, uiLoop)
