--========================================================--
--  UTILS
--========================================================--

local function clamp(v, lo, hi)
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

local function round(v)
  if v >= 0 then return math.floor(v + 0.5) end
  return math.ceil(v - 0.5)
end

local function pct(part, total)
  if not total or total == 0 then return 0 end
  return (part / total) * 100
end

local function fmtInt(n)
  n = tonumber(n) or 0
  local neg = n < 0
  n = math.abs(math.floor(n))
  local s = tostring(n)
  local out = ""
  while #s > 3 do
    out = "," .. string.sub(s, -3) .. out
    s = string.sub(s, 1, #s - 3)
  end
  out = s .. out
  if neg then out = "-" .. out end
  return out
end

local function fmtPct(v)
  return string.format("%.1f%%", tonumber(v) or 0)
end

local function setStatus(msg, col)
  state.statusMsg = msg or ""
  state.statusColor = col or colors.white
end

local function safeCall(obj, method, ...)
  if not obj or not obj[method] then return false, nil end
  return pcall(function(...) return obj[method](...) end, obj, ...)
end

local function slew(current, target, upRate, downRate)
  upRate = upRate or math.huge
  downRate = downRate or upRate
  if target > current then
    return math.min(current + upRate, target)
  elseif target < current then
    return math.max(current - downRate, target)
  else
    return current
  end
end

--========================================================--
--  PID
--========================================================--

local function newPID(cfg)
  return {
    kp = cfg.kp, ki = cfg.ki, kd = cfg.kd,
    min = cfg.min, max = cfg.max,
    integral = 0,
    lastError = 0,
    initialized = false,
  }
end

local pidInField, pidInTemp, pidOutSat, pidOutTemp

local function resetPIDs()
  pidInField = newPID(CONFIG.pid.inputField)
  pidInTemp  = newPID(CONFIG.pid.inputTemp)
  pidOutSat  = newPID(CONFIG.pid.outputSat)
  pidOutTemp = newPID(CONFIG.pid.outputTemp)
end

local function pidUpdate(pid, err, dt)
  dt = math.max(dt or 0.05, 0.01)

  if not pid.initialized then
    pid.lastError = err
    pid.initialized = true
  end

  pid.integral = pid.integral + err * dt
  local deriv = (err - pid.lastError) / dt
  pid.lastError = err

  local out = pid.kp * err + pid.ki * pid.integral + pid.kd * deriv

  if out > pid.max then
    out = pid.max
    pid.integral = pid.integral - err * dt * 0.25
  elseif out < pid.min then
    out = pid.min
    pid.integral = pid.integral - err * dt * 0.25
  end

  return out
end

--========================================================--
--  PERIPHERALS
--========================================================--

local function requirePeripheral(name, expectedType)
  if not peripheral.isPresent(name) then
    error("Missing peripheral: " .. tostring(name))
  end

  local ty = peripheral.getType(name)
  if expectedType and ty ~= expectedType then
    error("Peripheral '" .. tostring(name) .. "' is type '" .. tostring(ty) ..
      "', expected '" .. tostring(expectedType) .. "'")
  end

  local p = peripheral.wrap(name)
  if not p then
    error("Failed to wrap peripheral: " .. tostring(name))
  end
  return p
end

local function findLargestMonitor()
  local best, bestName, bestW, bestH, bestArea = nil, nil, 0, 0, -1
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "monitor" then
      local m = peripheral.wrap(name)
      if m and m.getSize then
        pcall(m.setTextScale, CONFIG.monitorScale)
        local w, h = m.getSize()
        local area = w * h
        if area > bestArea then
          best, bestName, bestW, bestH, bestArea = m, name, w, h, area
        end
      end
    end
  end
  return best, bestName, bestW, bestH
end

local function initPeripherals()
  if CONFIG.inputGateName == CONFIG.outputGateName then
    error("inputGateName and outputGateName cannot be the same.")
  end

  reactor = requirePeripheral(CONFIG.reactorName, "draconic_reactor")
  gateIn  = requirePeripheral(CONFIG.inputGateName, "flow_gate")
  gateOut = requirePeripheral(CONFIG.outputGateName, "flow_gate")

  monitor, monName, monW, monH = findLargestMonitor()
  if not monitor then
    error("No monitor found.")
  end

  pcall(monitor.setTextScale, CONFIG.monitorScale)
  monW, monH = monitor.getSize()
end

local function gateSupportsOverride(g)
  return g and g.setOverrideEnabled and g.setFlowOverride
end

local function gateSet(g, rate)
  rate = clamp(round(rate or 0), 0, math.max(CONFIG.maxInput, CONFIG.maxOutput))

  if gateSupportsOverride(g) then
    pcall(g.setOverrideEnabled, true)
    pcall(g.setFlowOverride, rate)
    return
  end

  if g and g.setSignalLowFlow then
    pcall(g.setSignalLowFlow, rate)
    return
  end

  error("Unknown flow gate API.")
end

local function gateGet(g)
  if not g then return 0 end

  if g.getFlow then
    local ok, v = pcall(g.getFlow)
    if ok and type(v) == "number" then return v end
  end

  if g.getSignalLowFlow then
    local ok, v = pcall(g.getSignalLowFlow)
    if ok and type(v) == "number" then return v end
  end

  return 0
end

local function getInfo()
  if not reactor or not reactor.getReactorInfo then return nil end
  local ok, info = pcall(reactor.getReactorInfo)
  if ok and type(info) == "table" then
    return info
  end
  return nil
end

--========================================================--
--  REACTOR INFO HELPERS
--========================================================--

local function fieldPct(info)
  return pct(info.fieldStrength or 0, info.maxFieldStrength or 0)
end

local function saturationPct(info)
  return pct(info.energySaturation or 0, info.maxEnergySaturation or 0)
end

local function fuelPct(info)
  local maxFuel = info.maxFuelConversion or 0
  if maxFuel <= 0 then return 0 end
  return 100 - pct(info.fuelConversion or 0, maxFuel)
end

local function statusLabel(status)
  local map = {
    running    = "RUNNING",
    online     = "RUNNING",
    cold       = "OFFLINE",
    warming_up = "CHARGING",
    stopping   = "STOPPING",
    cooling    = "COOLING",
  }
  return map[status] or tostring(status or "UNKNOWN"):upper()
end

local function reactorStatusColor(status)
  if status == "running" or status == "online" then return colors.lime end
  if status == "warming_up" then return colors.yellow end
  if status == "stopping" then return colors.red end
  if status == "cooling" then return colors.orange end
  return colors.lightGray
end

local function isRunningStatus(status)
  return status == "running" or status == "online"
end

local function isWarmupStatus(status)
  return status == "warming_up"
end

local function chargeReady(info)
  return (info.temperature or 0) >= CONFIG.chargeReadyTemp
     and fieldPct(info) >= CONFIG.chargeReadyField
     and saturationPct(info) >= CONFIG.chargeReadySaturation
end

