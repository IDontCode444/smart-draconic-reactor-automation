    { id="tg_m1",  label="-1",  bg=colors.orange, fg=colors.black, fn=function() tuneAdjust("targetGain", -1, 25, 200) end },
    { id="tg_p1",  label="+1",  bg=colors.lime, fg=colors.black, fn=function() tuneAdjust("targetGain", 1, 25, 200) end },
