-- draconic_reactor_controller_all_in_one.lua
-- All-in-one Draconic Evolution reactor controller for CC: Tweaked
-- No external config file is created.
--
-- IMPORTANT:
--   Edit INPUT_GATE_NAME and OUTPUT_GATE_NAME below to match your setup.
--   Example: "flow_gate_0" and "flow_gate_1"
--
-- Notes:
--   * Reactor + monitor are auto-detected.
--   * Input/output flow gates are NOT auto-detected by design.
--   * Field and saturation warm-up logic respects the fact that both only
--     charge to ~50% before full activation.
--   * Includes Auto/Manual mode, Charge / Activate / SCRAM / Tuning UI.
--   * Tuning screen lets you change targets live while the script is running.
--   * No external cfg means all settings reset to defaults when restarted.

local VERSION = "3.0"

-- =========================
-- USER EDITABLE CONSTANTS
-- =========================
local INPUT_GATE_NAME = "flow_gate_0"
local OUTPUT_GATE_NAME = "flow_gate_1"

local SETTINGS = {
  mode = "auto",                -- "auto" or "manual"
  autoActivate = true,

  -- Warm-up / activation assumptions:
  -- Before activation, field and saturation can only reach ~50%.
  preActivateField = 48.5,
  preActivateSaturation = 48.5,
  preActivateTemp = 2000,

  -- Running targets:
  targetField = 45.0,
  minField = 28.0,
  targetSaturation = 55.0,
  minSaturation = 20.0,
  targetTemp = 7600,
  maxTemp = 7900,

  -- Flow limits:
  minInput = 0,
  maxInput = 20000000,
  minOutput = 0,
  maxOutput = 50000000,

  -- Smooth ramping:
  inputRampPerTick = 150000,
  outputRampPerTick = 150000,

  -- Warm-up:
  warmupInputBase = 2500000,
  warmupInputMax = 12000000,

  -- Manual mode targets:
  manualInput = 3000000,
  manualOutput = 0,

  -- UI:
  monitorScale = 0.5
}

local reactor, monitor, inputGate, outputGate
local monW, monH = 0, 0

local currentInput = 0
local currentOutput = 0
local targetInput = 0
local targetOutput = 0

local ui = {
  screen = "main",
  buttons = {},
  message = "Booting..."
}

local state = {
  lastInfo = nil,
  staleInfoCount = 0,
  gateWriteFailures = 0,
  startupHoldTicks = 0,
  activatedByScript = false,
  lastFieldPct = nil,
  lastSatPct = nil,
  lastTemp = nil
}

local function clamp(v, lo, hi)
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

local function round(v, places)
  local p = 10 ^ (places or 0)
  return math.floor(v * p + 0.5) / p
end

local function fmtInt(n)
  n = tonumber(n) or 0
  local sign = ""
  if n < 0 then sign = "-" n = math.abs(n) end
  local s = tostring(math.floor(n + 0.5))
  local out = ""
  while #s > 3 do
    out = "," .. s:sub(-3) .. out
    s = s:sub(1, -4)
  end
  return sign .. s .. out
end

local function pct(part, whole)
  if not whole or whole == 0 then return 0 end
  return (part / whole) * 100
end

local function setMessage(msg)
  ui.message = tostring(msg or "")
end

local function detectReactor()
  local types = { "draconic_reactor", "draconic_reactor_component", "draconicreactor" }
  for _, name in ipairs(peripheral.getNames()) do
    local pType = peripheral.getType(name)
    for _, t in ipairs(types) do
      if pType == t then
        return peripheral.wrap(name), name
      end
    end
  end
  for _, name in ipairs(peripheral.getNames()) do
    local p = peripheral.wrap(name)
    if p and type(p.getReactorInfo) == "function" then
      return p, name
    end
  end
  return nil, nil
end

local function detectLargestMonitor()
  local best, bestName, bestArea
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "monitor" then
      local m = peripheral.wrap(name)
      local ok, w, h = pcall(m.getSize)
      if ok and w and h then
        local area = w * h
        if not bestArea or area > bestArea then
          best = m
          bestName = name
          bestArea = area
        end
      end
    end
  end
  return best, bestName
end

local function wrapFlowGate(name)
  if not name or name == "" then return nil end
  if not peripheral.isPresent(name) then return nil end
  if peripheral.getType(name) ~= "flow_gate" then return nil end
  return peripheral.wrap(name)
end

local function readGate(gate)
  if not gate then return nil end
  local ok, v = pcall(gate.getSignalLowFlow)
  if ok then return tonumber(v) or 0 end
  return nil
end

local function writeGate(gate, value, maxValue, kind)
  if not gate then return false end
  local writeValue = math.floor(clamp(value, 0, maxValue))
  local ok = pcall(gate.setSignalLowFlow, writeValue)
  if not ok then
    state.gateWriteFailures = state.gateWriteFailures + 1
    return false
  end
  local back = readGate(gate)
  if back == nil then
    state.gateWriteFailures = state.gateWriteFailures + 1
    return false
  end
  if math.abs(back - writeValue) > math.max(1000, writeValue * 0.02) then
    state.gateWriteFailures = state.gateWriteFailures + 1
    return false
  end
  state.gateWriteFailures = 0
  if kind == "input" then currentInput = back else currentOutput = back end
  return true
end

local function smoothStep(current, target, step)
  if current < target then
    return math.min(current + step, target)
  elseif current > target then
    return math.max(current - step, target)
  end
  return current
end

local function getInfo()
  if not reactor then return nil end
  local ok, info = pcall(reactor.getReactorInfo)
  if ok and type(info) == "table" then
    return info
  end
  return nil
end

local function reactorStatus(info)
  return tostring((info and info.status) or "unknown")
end

local function fieldPct(info)
  return pct(info.fieldStrength or 0, info.maxFieldStrength or 1)
end

local function satPct(info)
  return pct(info.energySaturation or 0, info.maxEnergySaturation or 1)
end

local function fuelPct(info)
  local maxFuel = info.maxFuelConversion or 1
  local used = info.fuelConversion or 0
  return clamp(100 - pct(used, maxFuel), 0, 100)
end

local function chargeReactor()
  if reactor and type(reactor.chargeReactor) == "function" then
    pcall(reactor.chargeReactor)
    setMessage("Charge requested")
  end
end

local function activateReactor()
  if reactor and type(reactor.activateReactor) == "function" then
    pcall(reactor.activateReactor)
    state.startupHoldTicks = 120 -- ~24 seconds at 0.2 s loop
    state.activatedByScript = true
    setMessage("Activate requested")
  end
end

local function stopReactor()
  if reactor and type(reactor.stopReactor) == "function" then
    pcall(reactor.stopReactor)
    setMessage("Stop requested")
  end
end

local function scram(reason)
  targetOutput = 0
  targetInput = SETTINGS.maxInput
  writeGate(outputGate, 0, SETTINGS.maxOutput, "output")
  writeGate(inputGate, SETTINGS.maxInput, SETTINGS.maxInput, "input")
  stopReactor()
  setMessage("SCRAM: " .. tostring(reason))
end

local function statusColor(status)
  if status == "running" then return colors.lime end
  if status == "warming_up" then return colors.orange end
  if status == "stopping" then return colors.red end
  if status == "cooling" then return colors.lightBlue end
  return colors.lightGray
end

local function fieldColor(v)
  if v >= SETTINGS.targetField then return colors.lime end
  if v >= SETTINGS.minField then return colors.yellow end
  return colors.red
end

local function satColor(v)
  if v >= SETTINGS.targetSaturation then return colors.lime end
  if v >= SETTINGS.minSaturation then return colors.yellow end
  return colors.red
end

local function tempColor(v)
  if v <= SETTINGS.targetTemp then return colors.lime end
  if v <= SETTINGS.maxTemp then return colors.yellow end
  return colors.red
end

local function drawText(x, y, s, tc, bc)
  monitor.setCursorPos(x, y)
  if bc then monitor.setBackgroundColor(bc) end
  if tc then monitor.setTextColor(tc) end
  monitor.write(s)
  monitor.setBackgroundColor(colors.black)
  monitor.setTextColor(colors.white)
end

local function drawBox(x1, y1, x2, y2, border, fill)
  fill = fill or colors.black
  for y = y1, y2 do
    monitor.setCursorPos(x1, y)
    for x = x1, x2 do
      if y == y1 or y == y2 or x == x1 or x == x2 then
        monitor.setBackgroundColor(border)
      else
        monitor.setBackgroundColor(fill)
      end
      monitor.write(" ")
    end
  end
  monitor.setBackgroundColor(colors.black)
end

local function drawBar(x, y, w, value, maxValue, fg, bg)
  local fill = 0
  if maxValue > 0 then
    fill = math.floor(clamp(value / maxValue, 0, 1) * w + 0.5)
  end
  monitor.setCursorPos(x, y)
  for i = 1, w do
    if i <= fill then
      monitor.setBackgroundColor(fg)
    else
      monitor.setBackgroundColor(bg)
    end
    monitor.write(" ")
  end
  monitor.setBackgroundColor(colors.black)
end

local function addButton(id, x1, y1, x2, y2, label, callback, bg, fg)
  table.insert(ui.buttons, {
    id = id, x1 = x1, y1 = y1, x2 = x2, y2 = y2,
    label = label, callback = callback, bg = bg or colors.gray, fg = fg or colors.white
  })
end

local function drawButton(btn)
  for y = btn.y1, btn.y2 do
    monitor.setCursorPos(btn.x1, y)
    monitor.setBackgroundColor(btn.bg)
    monitor.setTextColor(btn.fg)
    monitor.write(string.rep(" ", btn.x2 - btn.x1 + 1))
  end
  local cx = math.floor((btn.x1 + btn.x2 - #btn.label) / 2)
  local cy = math.floor((btn.y1 + btn.y2) / 2)
  drawText(cx, cy, btn.label, btn.fg, btn.bg)
  monitor.setBackgroundColor(colors.black)
  monitor.setTextColor(colors.white)
end

local function autoControl(info)
  local status = reactorStatus(info)
  local f = fieldPct(info)
  local s = satPct(info)
  local t = tonumber(info.temperature or 0)
  local drain = tonumber(info.fieldDrainRate or 0)
  local gen = tonumber(info.generationRate or 0)

  -- Required input to maintain current field against drain.
  -- Keep a strong reserve during all phases to avoid a startup collapse.
  local containmentReserve = math.max(drain * 1.30, drain + 250000)

  if status == "cold" then
    targetInput = 0
    targetOutput = 0
    return
  end

  if status == "warming_up" then
    targetOutput = 0

    local wanted = SETTINGS.warmupInputBase
    wanted = wanted + math.max(0, SETTINGS.preActivateField - f) * 140000
    wanted = wanted + math.max(0, SETTINGS.preActivateSaturation - s) * 100000
    wanted = wanted + math.max(0, SETTINGS.preActivateTemp - t) * 1600
    wanted = math.max(wanted, containmentReserve + 100000)
    targetInput = clamp(wanted, SETTINGS.minInput, SETTINGS.warmupInputMax)

    if SETTINGS.autoActivate
      and f >= SETTINGS.preActivateField
      and s >= SETTINGS.preActivateSaturation
      and t >= SETTINGS.preActivateTemp then
      activateReactor()
    end
    return
  end

  if status == "running" then
    -- Startup stabilization window after activation:
    -- keep output shut and overfeed input a bit so field and saturation can climb
    -- above their post-activation values safely.
    if state.startupHoldTicks > 0 then
      state.startupHoldTicks = state.startupHoldTicks - 1
      targetOutput = 0

      local wanted = containmentReserve + 500000
      if f < 42 then wanted = wanted + (42 - f) * 250000 end
      if s < 40 then wanted = wanted + (40 - s) * 200000 end
      if t < 4000 then wanted = wanted + (4000 - t) * 1200 end

      targetInput = clamp(wanted, SETTINGS.minInput, SETTINGS.maxInput)

      if f >= SETTINGS.targetField and s >= 45 and t >= 4500 then
        state.startupHoldTicks = 0
      end
      return
    end

    local fieldErr = SETTINGS.targetField - f
    local satErr = SETTINGS.targetSaturation - s
    local tempErr = SETTINGS.targetTemp - t

    local wantedInput = containmentReserve
    wantedInput = wantedInput + fieldErr * 180000
    wantedInput = wantedInput + satErr * 70000

    if t > SETTINGS.targetTemp then
      wantedInput = wantedInput + (t - SETTINGS.targetTemp) * 3500
    elseif t < SETTINGS.targetTemp - 600 then
      wantedInput = wantedInput - 100000
    end

    targetInput = clamp(wantedInput, SETTINGS.minInput, SETTINGS.maxInput)

    -- Conservative output ramp:
    -- only increase output when field/sat are healthy and temperature is in range.
    local desiredOutput = currentOutput

    if f > SETTINGS.targetField + 3 and s > SETTINGS.targetSaturation + 5 and t < SETTINGS.targetTemp - 250 then
      desiredOutput = desiredOutput + SETTINGS.outputRampPerTick
    elseif s < SETTINGS.targetSaturation - 4 or f < SETTINGS.targetField - 3 then
      desiredOutput = desiredOutput - SETTINGS.outputRampPerTick * 2
    elseif t > SETTINGS.targetTemp + 100 then
      desiredOutput = desiredOutput - SETTINGS.outputRampPerTick * 2
    end

    -- Never try to extract too close to generation while reactor is marginal.
    local safeCap = math.max(0, gen - math.max(400000, containmentReserve * 0.20))
    if f < SETTINGS.targetField or s < SETTINGS.targetSaturation then
      safeCap = math.max(0, gen - math.max(700000, containmentReserve * 0.35))
    end

    targetOutput = clamp(math.min(desiredOutput, safeCap), SETTINGS.minOutput, SETTINGS.maxOutput)
    return
  end

  if status == "cooling" or status == "stopping" then
    targetOutput = 0
    targetInput = clamp(containmentReserve, SETTINGS.minInput, SETTINGS.maxInput)
    return
  end

  targetInput = clamp(containmentReserve, SETTINGS.minInput, SETTINGS.maxInput)
  targetOutput = 0
end

local function safetyChecks(info)
  local status = reactorStatus(info)
  local f = fieldPct(info)
  local s = satPct(info)
  local t = tonumber(info.temperature or 0)

  if status == "running" then
    if f < SETTINGS.minField then
      scram("field below minimum")
      return false
    end
    if s < SETTINGS.minSaturation then
      scram("saturation below minimum")
      return false
    end
    if t > SETTINGS.maxTemp then
      scram("temperature above maximum")
      return false
    end
  end

  if state.lastFieldPct and status == "running" then
    -- Extra anti-lock checks:
    -- if field or saturation free-fall while we're already pushing hard, SCRAM.
    if f < state.lastFieldPct - 3 and currentInput >= SETTINGS.maxInput * 0.85 then
      scram("field collapse / input lock suspected")
      return false
    end
    if s < state.lastSatPct - 4 and currentOutput > 0 and currentInput >= SETTINGS.maxInput * 0.50 then
      scram("saturation collapse")
      return false
    end
  end

  state.lastFieldPct = f
  state.lastSatPct = s
  state.lastTemp = t

  if state.gateWriteFailures >= 6 then
    inputGate = wrapFlowGate(INPUT_GATE_NAME)
    outputGate = wrapFlowGate(OUTPUT_GATE_NAME)
    if not inputGate or not outputGate then
      scram("lost flow gate peripheral")
      return false
    end
  end

  return true
end

local function applyControl(info)
  if SETTINGS.mode == "auto" then
    autoControl(info)
  else
    targetInput = clamp(SETTINGS.manualInput, SETTINGS.minInput, SETTINGS.maxInput)
    targetOutput = clamp(SETTINGS.manualOutput, SETTINGS.minOutput, SETTINGS.maxOutput)
  end

  local nextInput = smoothStep(currentInput, targetInput, SETTINGS.inputRampPerTick)
  local nextOutput = smoothStep(currentOutput, targetOutput, SETTINGS.outputRampPerTick)

  writeGate(inputGate, nextInput, SETTINGS.maxInput, "input")
  writeGate(outputGate, nextOutput, SETTINGS.maxOutput, "output")
end

local function addAdjustButtons(key, label, y, small, big, minV, maxV)
  drawText(3, y, label, colors.white)
  drawText(monW - 10, y, tostring(round(SETTINGS[key], 1)), colors.cyan)

  addButton(key .. "_mb", 3,  y + 1, 9,  y + 2, "-big", function()
    SETTINGS[key] = clamp(SETTINGS[key] - big, minV, maxV)
  end, colors.red)
  addButton(key .. "_ms", 11, y + 1, 17, y + 2, "-sm", function()
    SETTINGS[key] = clamp(SETTINGS[key] - small, minV, maxV)
  end, colors.orange)
  addButton(key .. "_ps", 19, y + 1, 25, y + 2, "+sm", function()
    SETTINGS[key] = clamp(SETTINGS[key] + small, minV, maxV)
  end, colors.lime)
  addButton(key .. "_pb", 27, y + 1, 33, y + 2, "+big", function()
    SETTINGS[key] = clamp(SETTINGS[key] + big, minV, maxV)
  end, colors.green)
end

local function drawMain(info)
  ui.buttons = {}
  monitor.setBackgroundColor(colors.black)
  monitor.clear()

  drawBox(1, 1, monW, monH, colors.gray, colors.black)
  drawText(3, 1, " Reactor Ctrl " .. VERSION .. " ", colors.white, colors.gray)

  local status = reactorStatus(info)
  local f = round(fieldPct(info), 1)
  local s = round(satPct(info), 1)
  local t = tonumber(info.temperature or 0)
  local fuel = round(fuelPct(info), 1)
  local gen = tonumber(info.generationRate or 0)
  local drain = tonumber(info.fieldDrainRate or 0)

  drawText(3, 3, "Status: " .. status, statusColor(status))
  drawText(3, 4, "Mode:   " .. SETTINGS.mode, SETTINGS.mode == "auto" and colors.lime or colors.yellow)
  drawText(3, 5, "Gen:    " .. fmtInt(gen) .. " FE/t", colors.white)
  drawText(3, 6, "Drain:  " .. fmtInt(drain) .. " FE/t", colors.white)

  drawText(3, 8,  "Temperature: " .. fmtInt(t) .. " C", tempColor(t))
  drawBar (3, 9,  monW - 6, math.min(t, SETTINGS.maxTemp), SETTINGS.maxTemp, tempColor(t), colors.gray)

  drawText(3, 11, "Field:       " .. f .. "%", fieldColor(f))
  drawBar (3, 12, monW - 6, f, 100, fieldColor(f), colors.gray)

  drawText(3, 14, "Saturation:  " .. s .. "%", satColor(s))
  drawBar (3, 15, monW - 6, s, 100, satColor(s), colors.gray)

  drawText(3, 17, "Fuel left:   " .. fuel .. "%", fuel > 25 and colors.lime or colors.yellow)
  drawText(3, 18, "Input gate:  " .. fmtInt(currentInput), colors.cyan)
  drawText(3, 19, "Output gate: " .. fmtInt(currentOutput), colors.cyan)
  drawText(3, 20, "Targets I/O: " .. fmtInt(targetInput) .. " / " .. fmtInt(targetOutput), colors.lightBlue)

  local buttonY1 = math.max(22, monH - 7)
  local buttonY2 = buttonY1 + 2
  local buttonY3 = buttonY2 + 1
  local buttonY4 = buttonY3 + 2

  addButton("charge", 3,  buttonY1, 12, buttonY2, "CHARGE", function() chargeReactor() end, colors.blue)
  addButton("activate", 14, buttonY1, 25, buttonY2, "ACTIVATE", function() activateReactor() end, colors.green)
  addButton("scram", 27, buttonY1, 36, buttonY2, "SCRAM", function() scram("manual button") end, colors.red)

  addButton("tuning", 3,  buttonY3, 14, buttonY4, "TUNING", function()
    ui.screen = "tuning"
    setMessage("Opened tuning")
  end, colors.purple)

  addButton("mode", 16, buttonY3, 31, buttonY4,
    SETTINGS.mode == "auto" and "SET MANUAL" or "SET AUTO",
    function()
      if SETTINGS.mode == "auto" then
        SETTINGS.mode = "manual"
        setMessage("Manual mode enabled")
      else
        SETTINGS.mode = "auto"
        setMessage("Auto mode enabled")
      end
    end,
    colors.brown
  )

  for _, btn in ipairs(ui.buttons) do
    drawButton(btn)
  end

  drawText(3, monH - 1, "Msg: " .. ui.message, colors.white)
end

local function drawTuning(info)
  ui.buttons = {}
  monitor.setBackgroundColor(colors.black)
  monitor.clear()

  drawBox(1, 1, monW, monH, colors.gray, colors.black)
  drawText(3, 1, " Tuning ", colors.white, colors.gray)
  drawText(3, 3, "Mode: " .. SETTINGS.mode, SETTINGS.mode == "auto" and colors.lime or colors.yellow)

  local row = 5
  addAdjustButtons("targetField", "Target Field %", row, 1, 5, 20, 70); row = row + 4
  addAdjustButtons("minField", "Min Field %", row, 1, 5, 5, 60); row = row + 4
  addAdjustButtons("targetSaturation", "Target Sat %", row, 1, 5, 20, 90); row = row + 4
  addAdjustButtons("minSaturation", "Min Sat %", row, 1, 5, 5, 50); row = row + 4
  addAdjustButtons("targetTemp", "Target Temp", row, 50, 250, 3000, 7900); row = row + 4
  addAdjustButtons("maxTemp", "Max Temp", row, 50, 250, 5000, 7990); row = row + 4

  if row + 7 <= monH - 4 then
    drawText(3, row, "Manual Input", colors.white)
    drawText(monW - 14, row, fmtInt(SETTINGS.manualInput), colors.cyan)
    addButton("mi_dec", 3, row + 1, 12, row + 2, "-250k", function()
      SETTINGS.manualInput = clamp(SETTINGS.manualInput - 250000, SETTINGS.minInput, SETTINGS.maxInput)
    end, colors.red)
    addButton("mi_inc", 14, row + 1, 23, row + 2, "+250k", function()
      SETTINGS.manualInput = clamp(SETTINGS.manualInput + 250000, SETTINGS.minInput, SETTINGS.maxInput)
    end, colors.green)

    drawText(25, row, "Manual Output", colors.white)
    drawText(monW - 14, row + 3, fmtInt(SETTINGS.manualOutput), colors.cyan)
    addButton("mo_dec", 25, row + 1, 34, row + 2, "-250k", function()
      SETTINGS.manualOutput = clamp(SETTINGS.manualOutput - 250000, SETTINGS.minOutput, SETTINGS.maxOutput)
    end, colors.red)
    addButton("mo_inc", 36, row + 1, 45, row + 2, "+250k", function()
      SETTINGS.manualOutput = clamp(SETTINGS.manualOutput + 250000, SETTINGS.minOutput, SETTINGS.maxOutput)
    end, colors.green)
  end

  addButton("back", 3, monH - 3, 12, monH - 2, "BACK", function()
    ui.screen = "main"
    setMessage("Returned to main")
  end, colors.blue)

  addButton("mode", 14, monH - 3, 29, monH - 2,
    SETTINGS.mode == "auto" and "SET MANUAL" or "SET AUTO",
    function()
      if SETTINGS.mode == "auto" then
        SETTINGS.mode = "manual"
        setMessage("Manual mode enabled")
      else
        SETTINGS.mode = "auto"
        setMessage("Auto mode enabled")
      end
    end,
    colors.brown
  )

  for _, btn in ipairs(ui.buttons) do
    drawButton(btn)
  end

  drawText(3, monH - 1, "No cfg file is created. Settings reset on restart.", colors.white)
end

local function redraw()
  local info = state.lastInfo or {
    status = "unknown",
    temperature = 0,
    fieldStrength = 0,
    maxFieldStrength = 1,
    energySaturation = 0,
    maxEnergySaturation = 1,
    fuelConversion = 0,
    maxFuelConversion = 1,
    generationRate = 0,
    fieldDrainRate = 0
  }

  if ui.screen == "tuning" then
    drawTuning(info)
  else
    drawMain(info)
  end
end

local function handlePress(x, y)
  for _, btn in ipairs(ui.buttons) do
    if x >= btn.x1 and x <= btn.x2 and y >= btn.y1 and y <= btn.y2 then
      btn.callback()
      return
    end
  end
end

local function setup()
  while true do
    reactor = select(1, detectReactor())
    monitor = select(1, detectLargestMonitor())
    inputGate = wrapFlowGate(INPUT_GATE_NAME)
    outputGate = wrapFlowGate(OUTPUT_GATE_NAME)

    if monitor then
      pcall(monitor.setTextScale, SETTINGS.monitorScale)
      monitor.setBackgroundColor(colors.black)
      monitor.setTextColor(colors.white)
      monitor.clear()
      monW, monH = monitor.getSize()
    end

    if reactor and monitor and inputGate and outputGate then
      currentInput = readGate(inputGate) or 0
      currentOutput = readGate(outputGate) or 0
      setMessage("Ready")
      return
    end

    term.setBackgroundColor(colors.black)
    term.setTextColor(colors.white)
    term.clear()
    term.setCursorPos(1, 1)
    print("Waiting for peripherals...")
    print("")
    print("Need reactor: " .. tostring(reactor ~= nil))
    print("Need monitor: " .. tostring(monitor ~= nil))
    print("Need input gate (" .. INPUT_GATE_NAME .. "): " .. tostring(inputGate ~= nil))
    print("Need output gate (" .. OUTPUT_GATE_NAME .. "): " .. tostring(outputGate ~= nil))
    print("")
    print("Edit the two gate names at the top of the file if needed.")
    sleep(2)
  end
end

local function controlLoop()
  while true do
    local info = getInfo()
    if not info then
      state.staleInfoCount = state.staleInfoCount + 1
      setMessage("Reactor info unavailable")
      if state.staleInfoCount >= 10 then
        scram("stale reactor info")
        reactor = select(1, detectReactor())
      end
      sleep(0.2)
    else
      state.staleInfoCount = 0
      state.lastInfo = info
      if safetyChecks(info) then
        applyControl(info)
      end
      sleep(0.2)
    end
  end
end

local function uiLoop()
  while true do
    redraw()
    sleep(0.15)
  end
end

local function eventLoop()
  while true do
    local e, p1, p2, p3 = os.pullEvent()
    if e == "monitor_touch" then
      handlePress(p2, p3)
    elseif e == "mouse_click" then
      -- allows local terminal mouse if monitor isn't convenient
      handlePress(p2, p3)
    elseif e == "peripheral" or e == "peripheral_detach" then
      reactor = select(1, detectReactor())
      monitor = select(1, detectLargestMonitor())
      inputGate = wrapFlowGate(INPUT_GATE_NAME)
      outputGate = wrapFlowGate(OUTPUT_GATE_NAME)
      if monitor then
        pcall(monitor.setTextScale, SETTINGS.monitorScale)
        monW, monH = monitor.getSize()
      end
      setMessage("Peripherals refreshed")
    end
  end
end

setup()
parallel.waitForAny(controlLoop, uiLoop, eventLoop)
