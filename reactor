-- draconic_reactor_controller.lua
-- CC: Tweaked / ATM10-friendly Draconic Evolution reactor controller
-- Main features:
--   * Auto-detects reactor + monitor
--   * Manual naming for input/output flow gates (saved to config)
--   * Main UI with Charge / Activate / SCRAM / Tuning
--   * Separate Auto / Manual mode
--   * Auto warm-up and output ramp logic
--   * Anti-lock / watchdog checks for stale peripherals and gate write failures
--
-- INSTALL:
--   1) Put this file on an Advanced Computer as startup or run it manually.
--   2) Make sure the reactor peripheral and a monitor are connected.
--   3) On first launch, enter your input and output flow-gate peripheral names.
--      Example: flow_gate_0 and flow_gate_1
--
-- NOTES:
--   * Best reliability is direct peripheral attachment for the two flow gates.
--   * The script will still work with manually named peripherals if your setup exposes them.

local VERSION = "1.0"

local CONFIG_PATH = "draconic_reactor_ctrl.cfg"

local DEFAULTS = {
  inputGateName = "",
  outputGateName = "",
  mode = "auto",                 -- auto | manual
  autoActivate = true,

  targetField = 50.0,            -- preferred steady-state field %
  minField = 30.0,               -- scram below this while running
  activateField = 52.0,          -- min field % before activate

  targetSaturation = 45.0,       -- preferred steady-state saturation %
  minSaturation = 15.0,          -- scram below this while running
  activateSaturation = 50.0,     -- min saturation % before activate

  targetTemp = 7600,             -- high-output operating target
  maxTemp = 7900,                -- scram above this
  activateTemp = 2050,           -- warm-up threshold before activate
  coolResumeTemp = 5000,         -- informational only

  baseWarmupInput = 3000000,     -- starting warm-up feed
  maxInput = 25000000,
  minInput = 0,
  maxOutput = 50000000,
  minOutput = 0,

  inputRampPerTick = 250000,     -- smooth gate change limits
  outputRampPerTick = 250000,

  manualInput = 3000000,
  manualOutput = 0,

  uiScale = 0.5
}

local cfg = {}
for k, v in pairs(DEFAULTS) do cfg[k] = v end

local reactor
local mon
local monW, monH = 0, 0
local inputGate
local outputGate
local inputGateName
local outputGateName

local currentInput = 0
local currentOutput = 0
local targetInput = 0
local targetOutput = 0

local ui = {
  screen = "main", -- main | tuning
  buttons = {},
  message = "Booting...",
  lastTouch = 0
}

local state = {
  lastInfo = nil,
  lastPoll = 0,
  lastFieldPct = nil,
  lastSatPct = nil,
  lastTemp = nil,
  gateWriteFailures = 0,
  staleInfoCount = 0,
  runningTick = 0,
  warmupTick = 0,
  fieldDropTicks = 0,
  satDropTicks = 0,
  overTempTicks = 0,
  lastAction = "none"
}

local colorsEx = {
  orange = colors.orange or colors.yellow
}

local function clamp(v, lo, hi)
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

local function round(v, places)
  local p = 10 ^ (places or 0)
  return math.floor(v * p + 0.5) / p
end

local function fmtInt(n)
  n = tonumber(n) or 0
  local sign = ""
  if n < 0 then sign = "-" n = math.abs(n) end
  local s = tostring(math.floor(n + 0.5))
  local out = ""
  while #s > 3 do
    out = "," .. s:sub(-3) .. out
    s = s:sub(1, -4)
  end
  return sign .. s .. out
end

local function pct(part, whole)
  if not whole or whole == 0 then return 0 end
  return (part / whole) * 100
end

local function saveConfig()
  local f = fs.open(CONFIG_PATH, "w")
  if not f then return false end
  for k, v in pairs(cfg) do
    f.writeLine(k .. "=" .. tostring(v))
  end
  f.close()
  return true
end

local function loadConfig()
  if not fs.exists(CONFIG_PATH) then return false end
  local f = fs.open(CONFIG_PATH, "r")
  if not f then return false end
  while true do
    local line = f.readLine()
    if not line then break end
    local key, value = line:match("^([^=]+)=(.*)$")
    if key then
      if value == "true" then
        cfg[key] = true
      elseif value == "false" then
        cfg[key] = false
      elseif tonumber(value) then
        cfg[key] = tonumber(value)
      else
        cfg[key] = value
      end
    end
  end
  f.close()
  return true
end

local function setMessage(msg)
  ui.message = msg
end

local function findPeripheralByTypes(types)
  for _, name in ipairs(peripheral.getNames()) do
    local pType = peripheral.getType(name)
    for _, wanted in ipairs(types) do
      if pType == wanted then
        return peripheral.wrap(name), name, pType
      end
    end
  end
  return nil, nil, nil
end

local function wrapPeripheral(name, expectedType)
  if not name or name == "" then return nil end
  if not peripheral.isPresent(name) then return nil end
  local pType = peripheral.getType(name)
  if expectedType and pType ~= expectedType then return nil end
  return peripheral.wrap(name)
end

local function chooseLargestMonitor()
  local bestMon, bestName, bestArea
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "monitor" then
      local m = peripheral.wrap(name)
      local ok, w, h = pcall(m.getSize)
      if ok and w and h then
        local area = w * h
        if not bestArea or area > bestArea then
          bestArea = area
          bestMon = m
          bestName = name
        end
      end
    end
  end
  return bestMon, bestName
end

local function readGate(gate)
  if not gate then return nil end
  local ok, value = pcall(gate.getSignalLowFlow)
  if ok then return tonumber(value) or 0 end
  return nil
end

local function writeGate(gate, value, kind)
  value = math.floor(clamp(value, 0, kind == "input" and cfg.maxInput or cfg.maxOutput))
  local ok = pcall(gate.setSignalLowFlow, value)
  if not ok then
    state.gateWriteFailures = state.gateWriteFailures + 1
    return false
  end

  local back = readGate(gate)
  if back == nil then
    state.gateWriteFailures = state.gateWriteFailures + 1
    return false
  end

  if math.abs(back - value) > math.max(1000, value * 0.02) then
    state.gateWriteFailures = state.gateWriteFailures + 1
    return false
  end

  state.gateWriteFailures = 0
  if kind == "input" then currentInput = back else currentOutput = back end
  return true
end

local function smoothStep(current, target, maxStep)
  if current < target then
    return math.min(current + maxStep, target)
  elseif current > target then
    return math.max(current - maxStep, target)
  end
  return current
end

local function detectPeripherals()
  reactor = nil
  local reactorTypes = {
    "draconic_reactor",
    "draconic_reactor_component",
    "draconicreactor"
  }

  reactor = select(1, findPeripheralByTypes(reactorTypes))
  if not reactor then
    for _, name in ipairs(peripheral.getNames()) do
      local p = peripheral.wrap(name)
      if p and type(p.getReactorInfo) == "function" then
        reactor = p
        break
      end
    end
  end

  mon = select(1, chooseLargestMonitor())
  if mon then
    pcall(mon.setTextScale, cfg.uiScale)
    mon.setBackgroundColor(colors.black)
    mon.setTextColor(colors.white)
    mon.clear()
    monW, monH = mon.getSize()
  end

  inputGateName = cfg.inputGateName
  outputGateName = cfg.outputGateName
  inputGate = wrapPeripheral(inputGateName, "flow_gate")
  outputGate = wrapPeripheral(outputGateName, "flow_gate")

  return reactor ~= nil and mon ~= nil and inputGate ~= nil and outputGate ~= nil
end

local function promptForGateNames()
  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.white)
  term.clear()
  term.setCursorPos(1, 1)
  print("Draconic Reactor Controller v" .. VERSION)
  print("")
  print("Detected peripherals:")
  for _, name in ipairs(peripheral.getNames()) do
    print(" - " .. name .. " [" .. tostring(peripheral.getType(name)) .. "]")
  end
  print("")
  write("Enter INPUT flow gate name: ")
  cfg.inputGateName = read()
  write("Enter OUTPUT flow gate name: ")
  cfg.outputGateName = read()
  saveConfig()
end

local function ensureSetup()
  loadConfig()

  while true do
    local ok = detectPeripherals()
    if ok then
      currentInput = readGate(inputGate) or cfg.manualInput or 0
      currentOutput = readGate(outputGate) or cfg.manualOutput or 0
      return
    end

    if not cfg.inputGateName or cfg.inputGateName == "" or not cfg.outputGateName or cfg.outputGateName == "" then
      promptForGateNames()
    else
      term.setBackgroundColor(colors.black)
      term.setTextColor(colors.white)
      term.clear()
      term.setCursorPos(1, 1)
      print("Waiting for peripherals...")
      print("")
      print("Need:")
      print(" - Reactor peripheral")
      print(" - Monitor")
      print(" - Input gate:  " .. tostring(cfg.inputGateName))
      print(" - Output gate: " .. tostring(cfg.outputGateName))
      print("")
      print("Press R to re-enter gate names.")
      local timer = os.startTimer(2)
      while true do
        local e, p = os.pullEvent()
        if e == "char" and (p == "r" or p == "R") then
          promptForGateNames()
          break
        elseif e == "timer" and p == timer then
          break
        end
      end
    end
  end
end

local function getInfo()
  if not reactor then return nil end
  local ok, info = pcall(reactor.getReactorInfo)
  if not ok or type(info) ~= "table" then return nil end
  return info
end

local function fieldPct(info)
  return pct(info.fieldStrength or 0, info.maxFieldStrength or 1)
end

local function satPct(info)
  return pct(info.energySaturation or 0, info.maxEnergySaturation or 1)
end

local function fuelPct(info)
  local maxFuel = info.maxFuelConversion or 1
  local used = info.fuelConversion or 0
  return clamp(100 - pct(used, maxFuel), 0, 100)
end

local function reactorStatus(info)
  return tostring(info.status or "unknown")
end

local function statusColor(status)
  if status == "running" then return colors.lime end
  if status == "warming_up" then return colorsEx.orange end
  if status == "cooling" then return colors.lightBlue end
  if status == "stopping" then return colors.red end
  return colors.lightGray
end

local function fieldColor(v)
  if v >= cfg.targetField then return colors.lime end
  if v >= cfg.minField then return colors.yellow end
  return colors.red
end

local function satColor(v)
  if v >= cfg.targetSaturation then return colors.lime end
  if v >= cfg.minSaturation then return colors.yellow end
  return colors.red
end

local function tempColor(v)
  if v <= cfg.targetTemp then return colors.lime end
  if v <= cfg.maxTemp then return colors.yellow end
  return colors.red
end

local function bar(x, y, w, value, maxValue, fg, bg)
  value = clamp(value, 0, maxValue)
  local fill = 0
  if maxValue > 0 then
    fill = math.floor((value / maxValue) * w + 0.5)
  end
  mon.setCursorPos(x, y)
  for i = 1, w do
    if i <= fill then
      mon.setBackgroundColor(fg)
    else
      mon.setBackgroundColor(bg)
    end
    mon.write(" ")
  end
  mon.setBackgroundColor(colors.black)
end

local function text(x, y, s, tc, bc)
  mon.setCursorPos(x, y)
  if bc then mon.setBackgroundColor(bc) end
  if tc then mon.setTextColor(tc) end
  mon.write(s)
  mon.setBackgroundColor(colors.black)
  mon.setTextColor(colors.white)
end

local function clearLine(y)
  mon.setCursorPos(1, y)
  mon.setBackgroundColor(colors.black)
  mon.clearLine()
end

local function drawBox(x1, y1, x2, y2, border, fill)
  fill = fill or colors.black
  for y = y1, y2 do
    mon.setCursorPos(x1, y)
    for x = x1, x2 do
      if y == y1 or y == y2 or x == x1 or x == x2 then
        mon.setBackgroundColor(border)
      else
        mon.setBackgroundColor(fill)
      end
      mon.write(" ")
    end
  end
  mon.setBackgroundColor(colors.black)
end

local function addButton(id, x1, y1, x2, y2, label, callback, bg, fg)
  table.insert(ui.buttons, {
    id = id, x1 = x1, y1 = y1, x2 = x2, y2 = y2,
    label = label, callback = callback,
    bg = bg or colors.gray, fg = fg or colors.white
  })
end

local function drawButton(btn)
  for y = btn.y1, btn.y2 do
    mon.setCursorPos(btn.x1, y)
    mon.setBackgroundColor(btn.bg)
    mon.setTextColor(btn.fg)
    mon.write(string.rep(" ", btn.x2 - btn.x1 + 1))
  end
  local cx = math.floor((btn.x1 + btn.x2 - #btn.label) / 2)
  local cy = math.floor((btn.y1 + btn.y2) / 2)
  text(cx, cy, btn.label, btn.fg, btn.bg)
  mon.setBackgroundColor(colors.black)
  mon.setTextColor(colors.white)
end

local function addParamButtons(name, display, y, stepSmall, stepBig, minVal, maxVal)
  text(3, y, display, colors.white)
  local val = cfg[name]
  text(monW - 16, y, tostring(round(val, 1)), colors.cyan)

  addButton(name .. "_mBig", 3, y + 1, 9, y + 2, "-big", function()
    cfg[name] = clamp(cfg[name] - stepBig, minVal, maxVal)
    saveConfig()
  end, colors.red)
  addButton(name .. "_mSmall", 11, y + 1, 17, y + 2, "-sm", function()
    cfg[name] = clamp(cfg[name] - stepSmall, minVal, maxVal)
    saveConfig()
  end, colors.orange)
  addButton(name .. "_pSmall", 19, y + 1, 25, y + 2, "+sm", function()
    cfg[name] = clamp(cfg[name] + stepSmall, minVal, maxVal)
    saveConfig()
  end, colors.lime)
  addButton(name .. "_pBig", 27, y + 1, 33, y + 2, "+big", function()
    cfg[name] = clamp(cfg[name] + stepBig, minVal, maxVal)
    saveConfig()
  end, colors.green)
end

local function chargeReactor()
  if reactor and type(reactor.chargeReactor) == "function" then
    pcall(reactor.chargeReactor)
    state.lastAction = "charge"
    setMessage("Charge requested")
  end
end

local function activateReactor()
  if reactor and type(reactor.activateReactor) == "function" then
    pcall(reactor.activateReactor)
    state.lastAction = "activate"
    setMessage("Activate requested")
  end
end

local function stopReactor()
  if reactor and type(reactor.stopReactor) == "function" then
    pcall(reactor.stopReactor)
    state.lastAction = "stop"
    setMessage("Stop requested")
  end
end

local function scram(reason)
  targetOutput = 0
  targetInput = cfg.maxInput
  writeGate(outputGate, 0, "output")
  writeGate(inputGate, cfg.maxInput, "input")
  stopReactor()
  setMessage("SCRAM: " .. tostring(reason))
end

local function updateAutoTargets(info)
  local status = reactorStatus(info)
  local fPct = fieldPct(info)
  local sPct = satPct(info)
  local temp = tonumber(info.temperature or 0)
  local drain = tonumber(info.fieldDrainRate or 0)
  local gen = tonumber(info.generationRate or 0)

  local requiredForField = 0
  local fieldTargetFrac = clamp(cfg.targetField / 100, 0.05, 0.95)
  requiredForField = drain / (1 - fieldTargetFrac)

  if status == "cold" then
    targetOutput = 0
    targetInput = 0
    return
  end

  if status == "warming_up" then
    state.warmupTick = state.warmupTick + 1
    targetOutput = 0

    local warmBoost = cfg.baseWarmupInput
    if fPct < cfg.activateField then
      warmBoost = warmBoost + (cfg.activateField - fPct) * 220000
    end
    if sPct < cfg.activateSaturation then
      warmBoost = warmBoost + (cfg.activateSaturation - sPct) * 120000
    end
    if temp < cfg.activateTemp then
      warmBoost = warmBoost + (cfg.activateTemp - temp) * 2200
    end

    targetInput = clamp(math.max(requiredForField + 50000, warmBoost), cfg.minInput, cfg.maxInput)

    if cfg.autoActivate
      and fPct >= cfg.activateField
      and sPct >= cfg.activateSaturation
      and temp >= cfg.activateTemp then
      activateReactor()
    end
    return
  end

  if status == "running" then
    state.runningTick = state.runningTick + 1

    local fieldErr = cfg.targetField - fPct
    local satErr = cfg.targetSaturation - sPct
    local tempErr = cfg.targetTemp - temp

    local inputBias = requiredForField
    inputBias = inputBias + fieldErr * 180000
    inputBias = inputBias + satErr * 50000
    if temp > cfg.targetTemp then
      inputBias = inputBias + (temp - cfg.targetTemp) * 3500
    end
    targetInput = clamp(inputBias, cfg.minInput, cfg.maxInput)

    local reserve = requiredForField * 0.15 + 50000
    local desiredOutput = currentOutput

    if temp < cfg.targetTemp - 400 and sPct > cfg.minSaturation + 8 and fPct > cfg.minField + 8 then
      desiredOutput = desiredOutput + cfg.outputRampPerTick * 1.6
    elseif sPct > cfg.targetSaturation + 8 and fPct > cfg.targetField + 5 then
      desiredOutput = desiredOutput + cfg.outputRampPerTick
    elseif sPct < cfg.targetSaturation - 5 or fPct < cfg.targetField - 5 then
      desiredOutput = desiredOutput - cfg.outputRampPerTick * 1.5
    end

    if temp > cfg.targetTemp + 150 then
      desiredOutput = desiredOutput - cfg.outputRampPerTick * 2.0
    end
    if temp > cfg.maxTemp - 75 then
      desiredOutput = math.min(desiredOutput, math.max(0, gen - reserve - 500000))
    end
    if sPct < cfg.minSaturation + 3 or fPct < cfg.minField + 3 then
      desiredOutput = math.min(desiredOutput, math.max(0, gen - reserve - 250000))
    end

    desiredOutput = clamp(desiredOutput, cfg.minOutput, cfg.maxOutput)
    targetOutput = desiredOutput
    return
  end

  if status == "cooling" or status == "stopping" then
    targetOutput = 0
    targetInput = clamp(requiredForField, 0, cfg.maxInput)
    return
  end

  targetOutput = 0
  targetInput = clamp(requiredForField, 0, cfg.maxInput)
end

local function safetyChecks(info)
  local status = reactorStatus(info)
  local fPct = fieldPct(info)
  local sPct = satPct(info)
  local temp = tonumber(info.temperature or 0)

  if status == "running" then
    if fPct < cfg.minField then
      scram("field below min")
      return
    end
    if sPct < cfg.minSaturation then
      scram("saturation below min")
      return
    end
    if temp > cfg.maxTemp then
      scram("temperature above max")
      return
    end
  end

  if state.lastFieldPct and status == "running" then
    if fPct < state.lastFieldPct - 2.0 and currentInput >= (cfg.maxInput * 0.9) then
      state.fieldDropTicks = state.fieldDropTicks + 1
    else
      state.fieldDropTicks = 0
    end

    if sPct < state.lastSatPct - 3.0 and currentOutput > 0 and currentInput >= (cfg.maxInput * 0.5) then
      state.satDropTicks = state.satDropTicks + 1
    else
      state.satDropTicks = 0
    end

    if temp > cfg.maxTemp - 50 then
      state.overTempTicks = state.overTempTicks + 1
    else
      state.overTempTicks = 0
    end

    if state.fieldDropTicks >= 8 then
      scram("field collapsing / input locked?")
      return
    end
    if state.satDropTicks >= 8 then
      scram("saturation collapsing")
      return
    end
    if state.overTempTicks >= 10 then
      scram("persistent overtemp")
      return
    end
  end

  state.lastFieldPct = fPct
  state.lastSatPct = sPct
  state.lastTemp = temp

  if state.gateWriteFailures >= 6 then
    inputGate = wrapPeripheral(cfg.inputGateName, "flow_gate")
    outputGate = wrapPeripheral(cfg.outputGateName, "flow_gate")
    if not inputGate or not outputGate then
      scram("lost gate peripheral")
      return
    end
  end
end

local function applyControl(info)
  if cfg.mode == "auto" then
    updateAutoTargets(info)
  else
    targetInput = clamp(cfg.manualInput, cfg.minInput, cfg.maxInput)
    targetOutput = clamp(cfg.manualOutput, cfg.minOutput, cfg.maxOutput)
  end

  local newInput = smoothStep(currentInput, targetInput, cfg.inputRampPerTick)
  local newOutput = smoothStep(currentOutput, targetOutput, cfg.outputRampPerTick)

  writeGate(inputGate, newInput, "input")
  writeGate(outputGate, newOutput, "output")
end

local function drawMain(info)
  ui.buttons = {}
  mon.setBackgroundColor(colors.black)
  mon.clear()

  drawBox(1, 1, monW, monH, colors.gray, colors.black)
  text(3, 1, " Draconic Reactor Ctrl v" .. VERSION .. " ", colors.white, colors.gray)

  local status = reactorStatus(info)
  local fPct = round(fieldPct(info), 1)
  local sPct = round(satPct(info), 1)
  local temp = tonumber(info.temperature or 0)
  local fuel = round(fuelPct(info), 1)
  local gen = tonumber(info.generationRate or 0)
  local drain = tonumber(info.fieldDrainRate or 0)

  text(3, 3, "Status: " .. status, statusColor(status))
  text(3, 4, "Mode:   " .. tostring(cfg.mode), cfg.mode == "auto" and colors.lime or colors.yellow)
  text(3, 5, "Gen:    " .. fmtInt(gen) .. " FE/t", colors.white)
  text(3, 6, "Drain:  " .. fmtInt(drain) .. " FE/t", colors.white)

  text(3, 8, "Temperature: " .. fmtInt(temp) .. " C", tempColor(temp))
  bar(3, 9, monW - 6, math.min(temp, cfg.maxTemp), cfg.maxTemp, tempColor(temp), colors.gray)

  text(3, 11, "Field:       " .. tostring(fPct) .. "%", fieldColor(fPct))
  bar(3, 12, monW - 6, fPct, 100, fieldColor(fPct), colors.gray)

  text(3, 14, "Saturation:  " .. tostring(sPct) .. "%", satColor(sPct))
  bar(3, 15, monW - 6, sPct, 100, satColor(sPct), colors.gray)

  text(3, 17, "Fuel left:   " .. tostring(fuel) .. "%", fuel > 25 and colors.lime or colors.yellow)

  text(3, 19, "Input gate:  " .. fmtInt(currentInput), colors.cyan)
  text(3, 20, "Output gate: " .. fmtInt(currentOutput), colors.cyan)

  text(3, 22, "Auto target in/out: " .. fmtInt(targetInput) .. " / " .. fmtInt(targetOutput), colors.lightBlue)
  clearLine(monH - 1)
  text(3, monH - 1, "Msg: " .. tostring(ui.message), colors.white)

  addButton("charge",   3, 24, 12, 26, "CHARGE", function() chargeReactor() end, colors.blue)
  addButton("activate", 14, 24, 25, 26, "ACTIVATE", function() activateReactor() end, colors.green)
  addButton("scram",   27, 24, 36, 26, "SCRAM", function() scram("manual button") end, colors.red)
  addButton("tuning",   3, 28, 14, 30, "TUNING", function() ui.screen = "tuning" end, colors.purple)
  addButton("mode",    16, 28, 28, 30, cfg.mode == "auto" and "SET MANUAL" or "SET AUTO", function()
    cfg.mode = (cfg.mode == "auto") and "manual" or "auto"
    saveConfig()
    setMessage("Mode -> " .. cfg.mode)
  end, colors.brown)

  for _, btn in ipairs(ui.buttons) do drawButton(btn) end
end

local function drawTuning(info)
  ui.buttons = {}
  mon.setBackgroundColor(colors.black)
  mon.clear()
  drawBox(1, 1, monW, monH, colors.gray, colors.black)
  text(3, 1, " Tuning ", colors.white, colors.gray)
  text(3, 3, "Mode: " .. cfg.mode, cfg.mode == "auto" and colors.lime or colors.yellow)

  local row = 5
  addParamButtons("targetField",      "Target Field %", row, 1, 5, 20, 80); row = row + 4
  addParamButtons("minField",         "Min Field %", row,    1, 5, 5, 60); row = row + 4
  addParamButtons("targetSaturation", "Target Sat %", row,   1, 5, 10, 90); row = row + 4
  addParamButtons("minSaturation",    "Min Sat %", row,      1, 5, 5, 50); row = row + 4

  if monH >= row + 8 then
    addParamButtons("targetTemp", "Target Temp", row, 50, 250, 3000, 7900); row = row + 4
    addParamButtons("maxTemp",    "Max Temp", row,    50, 250, 5000, 7990); row = row + 4
  end

  if monH >= row + 4 then
    text(3, row, "Manual Input", colors.white)
    text(monW - 16, row, fmtInt(cfg.manualInput), colors.cyan)
    addButton("mi_dec", 3, row + 1, 10, row + 2, "-250k", function()
      cfg.manualInput = clamp(cfg.manualInput - 250000, cfg.minInput, cfg.maxInput)
      saveConfig()
    end, colors.red)
    addButton("mi_inc", 12, row + 1, 19, row + 2, "+250k", function()
      cfg.manualInput = clamp(cfg.manualInput + 250000, cfg.minInput, cfg.maxInput)
      saveConfig()
    end, colors.green)

    text(22, row, "Manual Output", colors.white)
    text(monW - 16, row + 3, fmtInt(cfg.manualOutput), colors.cyan)
    addButton("mo_dec", 22, row + 1, 30, row + 2, "-250k", function()
      cfg.manualOutput = clamp(cfg.manualOutput - 250000, cfg.minOutput, cfg.maxOutput)
      saveConfig()
    end, colors.red)
    addButton("mo_inc", 32, row + 1, 40, row + 2, "+250k", function()
      cfg.manualOutput = clamp(cfg.manualOutput + 250000, cfg.minOutput, cfg.maxOutput)
      saveConfig()
    end, colors.green)
    row = row + 5
  end

  addButton("back", 3, monH - 3, 12, monH - 2, "BACK", function() ui.screen = "main" end, colors.blue)
  addButton("autoAct", 14, monH - 3, 27, monH - 2,
    cfg.autoActivate and "AUTO ACT: ON" or "AUTO ACT: OFF",
    function()
      cfg.autoActivate = not cfg.autoActivate
      saveConfig()
    end,
    cfg.autoActivate and colors.green or colors.red
  )

  for _, btn in ipairs(ui.buttons) do drawButton(btn) end
  clearLine(monH - 1)
  text(3, monH - 1, "Field/Sat/Temp manual targets are saved instantly.", colors.white)
end

local function redraw(info)
  if ui.screen == "tuning" then
    drawTuning(info)
  else
    drawMain(info)
  end
end

local function handleTouch(side, x, y)
  for _, btn in ipairs(ui.buttons) do
    if x >= btn.x1 and x <= btn.x2 and y >= btn.y1 and y <= btn.y2 then
      btn.callback()
      return
    end
  end
end

local function uiLoop()
  while true do
    local info = state.lastInfo or getInfo() or {
      status = "unknown",
      temperature = 0,
      fieldStrength = 0,
      maxFieldStrength = 1,
      energySaturation = 0,
      maxEnergySaturation = 1,
      fuelConversion = 0,
      maxFuelConversion = 1,
      generationRate = 0,
      fieldDrainRate = 0
    }
    redraw(info)
    sleep(0.2)
  end
end

local function controlLoop()
  while true do
    local info = getInfo()
    if not info then
      state.staleInfoCount = state.staleInfoCount + 1
      setMessage("No reactor info; retrying...")
      if state.staleInfoCount >= 10 then
        scram("reactor info stale")
        detectPeripherals()
      end
      sleep(0.2)
    else
      state.staleInfoCount = 0
      state.lastInfo = info
      safetyChecks(info)
      applyControl(info)
      sleep(0.2)
    end
  end
end

local function eventLoop()
  while true do
    local e, p1, p2, p3 = os.pullEvent()
    if e == "monitor_touch" then
      handleTouch(p1, p2, p3)
    elseif e == "peripheral" or e == "peripheral_detach" then
      detectPeripherals()
      setMessage("Peripherals refreshed")
    elseif e == "char" then
      if p1 == "q" or p1 == "Q" then
        scram("keyboard quit")
      end
    end
  end
end

ensureSetup()
setMessage("Ready")
if not loadConfig() then saveConfig() end

parallel.waitForAny(uiLoop, controlLoop, eventLoop)
