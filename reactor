local function clearButtons()
  buttons = {}
end

local function writeAt(t, x, y, txt, fg, bg)
  if bg then t.setBackgroundColor(bg) end
  if fg then t.setTextColor(fg) end
  t.setCursorPos(x, y)
  t.write(txt)
end

local function fill(t, x1, y1, x2, y2, bg)
  t.setBackgroundColor(bg)
  for y = y1, y2 do
    t.setCursorPos(x1, y)
    t.write((" "):rep(x2 - x1 + 1))
  end
end

local function addButton(id, x1, y1, x2, y2, label, bg, fg, fn)
  buttons[id] = {
    x1 = x1, y1 = y1, x2 = x2, y2 = y2,
    label = label, bg = bg, fg = fg, fn = fn
  }
end

local function drawButton(t, b)
  fill(t, b.x1, b.y1, b.x2, b.y2, b.bg)
  local tx = math.floor((b.x1 + b.x2 - #b.label) / 2)
  local ty = math.floor((b.y1 + b.y2) / 2)
  writeAt(t, tx, ty, b.label, b.fg, b.bg)
end

local function drawBar(t, x, y, w, valuePct, fillColor, backColor, label)
  valuePct = clamp(valuePct or 0, 0, 100)
  local fillW = math.floor((w * valuePct) / 100)

  fill(t, x, y, x + w - 1, y, backColor)
  if fillW > 0 then
    fill(t, x, y, x + fillW - 1, y, fillColor)
  end

  local txt = label .. " " .. string.format("%5.1f%%", valuePct)
  local tx = x + math.max(0, math.floor((w - #txt) / 2))
  writeAt(t, tx, y, txt, colors.white, colors.black)
end

