local function clamp(v, lo, hi)
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

local function round(n)
  return math.floor((tonumber(n) or 0) + 0.5)
end

local function toNum(v)
  local n = tonumber(v)
  if n == nil then return nil end
  if n ~= n then return nil end
  if n == math.huge or n == -math.huge then return nil end
  return n
end

local function fmtInt(n)
  n = tonumber(n or 0) or 0
  local a = math.abs(n)
  if a >= 1e12 then return string.format("%.2fT", n / 1e12) end
  if a >= 1e9 then return string.format("%.2fG", n / 1e9) end
  if a >= 1e6 then return string.format("%.2fM", n / 1e6) end
  if a >= 1e3 then return string.format("%.2fk", n / 1e3) end
  return tostring(round(n))
end

local function fmtPct(v)
  v = tonumber(v or 0) or 0
  return string.format("%.1f%%", v * 100)
end

local function safeCall(obj, method, ...)
  if not obj or type(obj[method]) ~= "function" then return nil end
  local ok, a, b, c, d = pcall(obj[method], ...)
  if ok then return a, b, c, d end
  return nil
end

local function centerText(y, text, fg, bg)
  local w = select(1, mon.getSize())
  local x = math.max(1, math.floor((w - #text) / 2) + 1)
  mon.setCursorPos(x, y)
  mon.setTextColor(fg or UI.fg)
  mon.setBackgroundColor(bg or UI.bg)
  mon.write(text)
end

local function writeAt(x, y, text, fg, bg)
  mon.setCursorPos(x, y)
  mon.setTextColor(fg or UI.fg)
  mon.setBackgroundColor(bg or UI.bg)
  mon.write(text)
end

local function clearMonitor()
  mon.setBackgroundColor(UI.bg)
  mon.setTextColor(UI.fg)
  mon.clear()
end

local function progressBar(x, y, width, pct, fillColor, emptyColor)
  pct = clamp(pct or 0, 0, 1)
  local fill = math.floor(width * pct + 0.5)

  mon.setCursorPos(x, y)
  mon.setBackgroundColor(emptyColor or colors.gray)
  mon.write(string.rep(" ", width))

  if fill > 0 then
    mon.setCursorPos(x, y)
    mon.setBackgroundColor(fillColor or colors.green)
    mon.write(string.rep(" ", fill))
  end

  mon.setBackgroundColor(UI.bg)
end

local function button(map, id, x1, y1, x2, y2, label, bg, fg)
  map[id] = {x1=x1, y1=y1, x2=x2, y2=y2}
  for y = y1, y2 do
    mon.setCursorPos(x1, y)
    mon.setBackgroundColor(bg)
    mon.setTextColor(fg)
    mon.write(string.rep(" ", x2 - x1 + 1))
  end
  local cx = x1 + math.floor(((x2 - x1 + 1) - #label) / 2)
  local cy = math.floor((y1 + y2) / 2)
  writeAt(cx, cy, label, fg, bg)
end

local function hitButton(map, x, y)
  for id, b in pairs(map) do
    if x >= b.x1 and x <= b.x2 and y >= b.y1 and y <= b.y2 then
      return id
    end
  end
  return nil
end

local function isMonitorPeripheral(name)
  local p = peripheral.wrap(name)
  return p
    and type(p.setTextScale) == "function"
    and type(p.getSize) == "function"
    and type(p.clear) == "function"
end

local function isReactorPeripheral(name)
  local p = peripheral.wrap(name)
  return p
    and (type(p.getReactorInfo) == "function"
      or type(p.chargeReactor) == "function"
      or type(p.activateReactor) == "function")
end

local function findReactor()
  for _, name in ipairs(peripheral.getNames()) do
    if isReactorPeripheral(name) then
      return name, peripheral.wrap(name)
    end
  end
end

local function findMonitor()
  for _, name in ipairs(peripheral.getNames()) do
    if isMonitorPeripheral(name) then
      return name, peripheral.wrap(name)
    end
  end
end

local function bindPeripherals()
  reactorName, reactor = findReactor()
  if not reactor then error("No reactor peripheral auto-detected.") end

  monitorName, mon = findMonitor()
  if not mon then error("No monitor peripheral auto-detected.") end

  inputGate = peripheral.wrap(CFG.inputGateName)
  if not inputGate then error("Missing input gate: " .. tostring(CFG.inputGateName)) end

  outputGate = peripheral.wrap(CFG.outputGateName)
  if not outputGate then error("Missing output gate: " .. tostring(CFG.outputGateName)) end
end

local function getInfo()
  local info = safeCall(reactor, "getReactorInfo")
  if type(info) == "table" then return info end
  return nil
end

local function normalizeStatus(s)
  s = tostring(s or "unknown")
  local t = string.lower(s)
  t = t:gsub("%s+", "_")
  return t, s
end

local function lower(s)
  return string.lower(tostring(s or ""))
end

local function containsAny(s, tokens)
  s = lower(s)
  for _, tok in ipairs(tokens) do
    if s:find(tok, 1, true) then
      return true
    end
  end
  return false
end

local function getAny(info, names)
  for _, k in ipairs(names) do
    local v = info[k]
    local n = toNum(v)
    if n ~= nil then
      return n, k
    end
  end
  return nil, nil
end

local function collectNumericPairs(info)
  local nums = {}
  for k, v in pairs(info) do
    if type(k) == "string" then
      local n = toNum(v)
      if n ~= nil then
        nums[k] = n
      end
    end
  end
  return nums
end

local function chooseBestPair(candidates)
  local best = nil
  for _, c in ipairs(candidates) do
    if c.max and c.max > 0 then
      local pct = c.value / c.max
      local score = 0

      if pct >= 0 and pct <= 1.05 then score = score + 100 end
      if c.value > 0 then score = score + 30 end
      if c.value > 1 then score = score + 10 end
      if c.max > 1 then score = score + 5 end
      if pct > 0.01 and pct < 0.99 then score = score + 20 end
      if c.preferred then score = score + 25 end

      c.score = score
      c.pct = clamp(pct, 0, 1)

      if not best or c.score > best.score then
        best = c
      end
    end
  end
  return best
end

local function discoverPairByTokens(info, valueTokens, maxTokens, preferredKnown)
  local nums = collectNumericPairs(info)
  local candidates = {}

  for valueKey, value in pairs(nums) do
    local lvk = lower(valueKey)
    if containsAny(lvk, valueTokens) and not lvk:find("max", 1, true) then
      for maxKey, maxValue in pairs(nums) do
        local lmk = lower(maxKey)
        if containsAny(lmk, maxTokens) and lmk:find("max", 1, true) then
          local scoreBoost = 0
          local joined = valueKey .. "/" .. maxKey

          for _, pair in ipairs(preferredKnown or {}) do
            if pair[1] == valueKey and pair[2] == maxKey then
              scoreBoost = 25
              break
            end
          end

          if maxValue > 0 and value >= 0 then
            local shared = 0
            for _, tok in ipairs(valueTokens) do
              if lvk:find(tok, 1, true) and lmk:find(tok, 1, true) then
                shared = shared + 1
              end
            end

            table.insert(candidates, {
              value = value,
              max = maxValue,
              valueKey = valueKey,
              maxKey = maxKey,
              preferred = shared > 0 or scoreBoost > 0,
              pairName = joined,
            })
          end
        end
      end
    end
  end

  local best = chooseBestPair(candidates)
  return best, candidates
end

local function chooseKnownPair(info, pairs)
  local candidates = {}
  for _, pair in ipairs(pairs) do
    local v = toNum(info[pair[1]])
    local m = toNum(info[pair[2]])
    if v ~= nil and m ~= nil and m > 0 then
      table.insert(candidates, {
        value = v,
        max = m,
        valueKey = pair[1],
        maxKey = pair[2],
        preferred = true,
        pairName = pair[1] .. "/" .. pair[2],
      })
    end
  end
  return chooseBestPair(candidates)
end

local function chooseFieldPair(info, statusNorm)
  local known = {
    {"fieldStrength", "maxFieldStrength"},
    {"shieldCharge", "maxShieldCharge"},
    {"fieldCharge", "maxFieldCharge"},
    {"shieldStrength", "maxShieldStrength"},
    {"containmentField", "maxContainmentField"},
    {"containment", "maxContainment"},
  }

  local knownBest = chooseKnownPair(info, known)
  local discoveredBest = discoverPairByTokens(
    info,
    {"field", "shield", "containment"},
    {"field", "shield", "containment"},
    known
  )

  local best = knownBest
  if discoveredBest and (not best or discoveredBest.score > best.score) then
    best = discoveredBest
  end

  -- ATM10 startup workaround:
  -- If the chosen pair is stuck at 0 during charging/warming, but another field-like pair is nonzero,
  -- prefer the nonzero one.
  if best and best.pct <= 0.001 and (statusNorm == "charging" or statusNorm == "warming_up" or statusNorm == "warmingup" or statusNorm == "cold") then
    local nums = collectNumericPairs(info)
    local fallbackCandidates = {}

    for k, v in pairs(nums) do
      local lk = lower(k)
      if containsAny(lk, {"field", "shield", "containment"}) and not lk:find("max", 1, true) and v > 0 then
        for mk, mv in pairs(nums) do
          local lmk = lower(mk)
          if containsAny(lmk, {"field", "shield", "containment"}) and lmk:find("max", 1, true) and mv > 0 then
            local pct = v / mv
            if pct > 0.01 and pct < 1.0 then
              table.insert(fallbackCandidates, {
                value = v,
                max = mv,
                valueKey = k,
                maxKey = mk,
                preferred = true,
                pairName = k .. "/" .. mk,
              })
            end
          end
        end
      end
    end

    local fallback = chooseBestPair(fallbackCandidates)
    if fallback and fallback.pct > 0.01 then
      best = fallback
    end
  end

  return best
end

local function chooseSatPair(info)
  local known = {
    {"energySaturation", "maxEnergySaturation"},
    {"saturation", "maxSaturation"},
    {"coreSaturation", "maxCoreSaturation"},
    {"energy", "maxEnergy"},
  }

  local knownBest = chooseKnownPair(info, known)
  local discoveredBest = discoverPairByTokens(
    info,
    {"saturation", "energy"},
    {"saturation", "energy"},
    known
  )

  if discoveredBest and (not knownBest or discoveredBest.score > knownBest.score) then
    return discoveredBest
  end
  return knownBest
end

local function chooseFuel(info)
  local fuelConv = toNum(info.fuelConversion)
  local maxFuelConv = toNum(info.maxFuelConversion)
  local reactableFuel = toNum(info.reactableFuel)
  local fuel = toNum(info.fuel)
  local convertedFuel = toNum(info.convertedFuel)

  if fuelConv and maxFuelConv and maxFuelConv > 0 then
    local remaining = math.max(0, maxFuelConv - fuelConv)
    return remaining, maxFuelConv, "maxFuelConversion-fuelConversion"
  end

  if reactableFuel and reactableFuel >= 0 then
    return reactableFuel, math.max(reactableFuel, 1), "reactableFuel"
  end

  if fuel and fuel >= 0 then
    return fuel, math.max(fuel, 1), "fuel"
  end

  if convertedFuel and convertedFuel >= 0 then
    return convertedFuel, math.max(convertedFuel, 1), "convertedFuel"
  end

  for k, v in pairs(info) do
    if type(k) == "string" then
      local n = toNum(v)
      if n and lower(k):find("fuel", 1, true) then
        return n, math.max(n, 1), k
      end
    end
  end

  return 0, 1, "fallback0"
end

local function normalizeInfo(info)
  local statusNorm, statusRaw = normalizeStatus(info.status or info.reactorState or info.state or "unknown")

  local temp, tempKey = getAny(info, {
    "temperature", "temp", "coreTemperature"
  })
  temp = temp or 0

  local gen, genKey = getAny(info, {
    "generationRate", "genRate", "outputRate", "generation", "output"
  })
  gen = gen or 0

  local drain, drainKey = getAny(info, {
    "fieldDrainRate", "fieldInputRate", "fieldDrain", "shieldDrain",
    "shieldInputRate", "drainRate"
  })
  drain = drain or 0

  local field = chooseFieldPair(info, statusNorm)
  local sat = chooseSatPair(info)

  local fuelRemaining, fuelMax, fuelKey = chooseFuel(info)
  local fuelPct = 0
  if fuelMax and fuelMax > 0 then
    fuelPct = clamp(fuelRemaining / fuelMax, 0, 1)
  end

  return {
    status = statusRaw,
    statusNorm = statusNorm,

    temp = temp,
    tempKey = tempKey or "fallback0",

    generation = gen,
    generationKey = genKey or "fallback0",

    fieldDrain = drain,
    fieldDrainKey = drainKey or "fallback0",

    field = field and field.value or 0,
    maxField = field and field.max or 1,
    fieldPct = field and field.pct or 0,
    fieldKeys = field and (field.valueKey .. "/" .. field.maxKey) or "fallback0",

    saturation = sat and sat.value or 0,
    maxSaturation = sat and sat.max or 1,
    saturationPct = sat and sat.pct or 0,
    saturationKeys = sat and (sat.valueKey .. "/" .. sat.maxKey) or "fallback0",

    fuel = fuelRemaining,
    fuelMax = fuelMax or 1,
    fuelPct = fuelPct,
    fuelKey = fuelKey,

    raw = info,
  }
end

local function statusLooksOnline(status)
  local s = string.lower(tostring(status or ""))
  return s:find("online") ~= nil
      or s:find("running") ~= nil
      or s:find("active") ~= nil
end

local function isOnline(info)
  local ni = normalizeInfo(info)
  local s = ni.statusNorm

  if s == "warming_up" or s == "warmingup" or s == "charged" or s == "charging" or s == "cold" or s == "stopping" then
    return false
  end

  if statusLooksOnline(ni.status) then
    return true
  end

  if ni.temp >= CFG.startupReadyTemp and ni.fieldDrain > 0 and ni.generation > 0 then
    return true
  end

  return false
end

local function isStartupReady(info)
  local ni = normalizeInfo(info)
  return ni.fieldPct >= CFG.startupReadyField
     and ni.saturationPct >= CFG.startupReadySat
     and ni.temp >= CFG.startupReadyTemp
end

local function setGateFlow(gate, rate)
  rate = math.max(0, math.floor(rate or 0))

  if safeCall(gate, "setOverrideEnabled", true) ~= nil then end
  if safeCall(gate, "setSignalLowFlow", rate) ~= nil then return true end
  if safeCall(gate, "setFlowOverride", rate) ~= nil then return true end
  if safeCall(gate, "setTransferRate", rate) ~= nil then return true end
  return false
end

local function resetPID()
  state.inputPID.integral = 0
  state.inputPID.lastError = 0
  state.outputPID.integral = 0
  state.outputPID.lastError = 0
end

local function pidStep(pidState, pidCfg, error, dt)
  pidState.integral = pidState.integral + error * dt
  pidState.integral = clamp(pidState.integral, pidCfg.integralMin, pidCfg.integralMax)

  local derivative = 0
  if dt > 0 then derivative = (error - pidState.lastError) / dt end
  pidState.lastError = error

  return (pidCfg.kp * error)
       + (pidCfg.ki * pidState.integral)
       + (pidCfg.kd * derivative)
end

local function adaptiveInput(baseDemand, extraDemand)
  local v = math.max(CFG.minInput, (baseDemand or 0) + (extraDemand or 0))
  if v > CFG.inputSanityCeiling then
    v = CFG.inputSanityCeiling
  end
  return v
end

local function goIdle(msg)
  state.phase = "IDLE"
  state.autoShutdown = false
  state.chargeRequested = false
  state.startupActivatedAt = nil
  state.desiredInput = 0
  state.desiredOutput = 0
  state.netGain = 0
  setGateFlow(inputGate, 0)
  setGateFlow(outputGate, 0)
  resetPID()
  state.message = msg or "Idle"
end

local function doCharge()
  state.autoShutdown = false
  state.chargeRequested = true
  state.startupActivatedAt = nil
  resetPID()
  state.desiredInput = CFG.chargeInput
  state.desiredOutput = 0
  setGateFlow(inputGate, CFG.chargeInput)
  setGateFlow(outputGate, 0)
  safeCall(reactor, "chargeReactor")
  state.phase = "CHARGING"
  state.message = "Manual charge requested"
end

local function doActivate()
  local info = state.lastInfo
  if not info then
    state.message = "No reactor data"
    return
  end

  if not state.chargeRequested then
    state.message = "Press CHARGE first"
    return
  end

  if not isStartupReady(info) then
    state.message = "Not ready for ignition"
    return
  end

  local ni = normalizeInfo(info)
  state.desiredInput = adaptiveInput(ni.fieldDrain * 1.50, 10000000)
  state.desiredOutput = 0
  setGateFlow(inputGate, state.desiredInput)
  setGateFlow(outputGate, 0)

  safeCall(reactor, "activateReactor")

  state.startupActivatedAt = os.clock()
  resetPID()
  state.phase = "IGNITION HOLD"
  state.message = "Activation requested; hold engaged"
end

local function doScram(reason)
  local info = state.lastInfo or {}
  local ni = normalizeInfo(info)
  state.phase = "SCRAM"
  state.autoShutdown = false
  state.chargeRequested = false
  state.startupActivatedAt = nil
  state.desiredInput = adaptiveInput(ni.fieldDrain * 2.00, 20000000)
  state.desiredOutput = 0
  setGateFlow(inputGate, state.desiredInput)
  setGateFlow(outputGate, 0)
  safeCall(reactor, "stopReactor")
  state.message = reason or "SCRAM engaged"
end

local function cooldownControl(info)
  local ni = normalizeInfo(info)

  local extra = 0
  if ni.fieldPct < CFG.cooldownFieldTarget then
    extra = extra + ((CFG.cooldownFieldTarget - ni.fieldPct) * 12000000)
  end
  if ni.temp > CFG.cooldownSafeTemp then
    extra = extra + 2000000
  end

  local desiredInput = adaptiveInput(math.max(CFG.cooldownInputMin, ni.fieldDrain * 1.20), extra)

  state.desiredInput = desiredInput
  state.desiredOutput = 0
  setGateFlow(inputGate, desiredInput)
  setGateFlow(outputGate, 0)
  safeCall(reactor, "stopReactor")

  if ni.temp <= CFG.cooldownSafeTemp and not isOnline(info) then
    goIdle("Cooldown complete")
  else
    state.message = "Cooling after shutdown"
  end
end

local function ignitionHoldControl(info)
  local ni = normalizeInfo(info)
  local now = os.clock()
  local elapsed = now - (state.startupActivatedAt or now)
  local online = isOnline(info)

  local extra = 15000000
  if ni.fieldPct < 0.50 then
    extra = extra + ((0.50 - ni.fieldPct) * 20000000)
  end
  if ni.saturationPct < 0.50 then
    extra = extra + ((0.50 - ni.saturationPct) * 8000000)
  end
  if ni.temp > CFG.targetTemp then
    extra = extra + 4000000
  end

  state.desiredInput = adaptiveInput(ni.fieldDrain * 1.35, extra)
  state.desiredOutput = 0
  setGateFlow(inputGate, state.desiredInput)
  setGateFlow(outputGate, 0)

  if ni.fieldPct <= CFG.scramField or ni.saturationPct <= CFG.scramSaturation or ni.temp >= CFG.scramTemp then
    doScram("SCRAM during ignition hold")
    return
  end

  if not online then
    state.message = "Waiting for online state..."
    return
  end

  if elapsed < CFG.ignitionMinTime then
    state.message = "Ignition hold: " .. string.format("%.1fs", CFG.ignitionMinTime - elapsed)
    return
  end

  if ni.fieldPct < CFG.ignitionExitField then
    state.message = "Holding until field recovers"
    return
  end

  if ni.saturationPct < CFG.ignitionExitSat then
    state.message = "Holding until saturation stabilizes"
    return
  end

  resetPID()
  state.phase = "RUNNING"
  state.message = "Ignition stabilized"
end

local function runningControl(info, dt)
  local ni = normalizeInfo(info)

  if ni.fieldPct <= CFG.scramField then
    doScram("SCRAM: field critical")
    return
  end
  if ni.saturationPct <= CFG.scramSaturation then
    doScram("SCRAM: saturation critical")
    return
  end
  if ni.temp >= CFG.scramTemp then
    doScram("SCRAM: temperature critical")
    return
  end

  if CFG.enableFuelShutdown and ni.fuel <= CFG.shutdownFuelAmount then
    state.autoShutdown = true
    state.phase = "AUTO SHUTDOWN"
    cooldownControl(info)
    return
  end

  local fieldError = CFG.targetField - ni.fieldPct
  local inputAdjust = pidStep(state.inputPID, CFG.inputPID, fieldError, dt)

  local extraInput = inputAdjust
  if ni.fieldPct < CFG.targetField then
    extraInput = extraInput + ((CFG.targetField - ni.fieldPct) * 10000000)
  end
  if ni.temp > CFG.targetTemp then
    extraInput = extraInput + 2000000
  end

  local desiredInput = adaptiveInput(ni.fieldDrain * 1.08, extraInput)

  local satError = ni.saturationPct - CFG.targetSaturation
  local outputBase = clamp(ni.generation * 0.60, CFG.minOutput, CFG.maxOutput)
  local outputAdjust = pidStep(state.outputPID, CFG.outputPID, satError, dt)
  local desiredOutput = outputBase + outputAdjust

  if ni.temp > CFG.targetTemp then
    desiredOutput = desiredOutput - ((ni.temp - CFG.targetTemp) * 5000)
  end
  if ni.fieldPct < CFG.targetField then
    desiredOutput = desiredOutput * 0.30
  end
  if ni.saturationPct < CFG.targetSaturation then
    desiredOutput = desiredOutput * 0.60
  end

  desiredOutput = clamp(desiredOutput, CFG.minOutput, CFG.maxOutput)

  state.desiredInput = desiredInput
  state.desiredOutput = desiredOutput
  state.netGain = ni.generation - desiredInput - desiredOutput

  setGateFlow(inputGate, desiredInput)
  setGateFlow(outputGate, desiredOutput)

  state.phase = "RUNNING"
  state.message = "Regulating"
end

local lastTickClock = os.clock()

local function updateControl(info)
  local now = os.clock()
  local dt = now - lastTickClock
  if dt <= 0 then dt = CFG.tickRate end
  lastTickClock = now

  local ni = normalizeInfo(info)
  state.lastNormalized = ni

  if state.phase == "SCRAM" then
    state.desiredInput = adaptiveInput(ni.fieldDrain * 2.00, 20000000)
    state.desiredOutput = 0
    setGateFlow(inputGate, state.desiredInput)
    setGateFlow(outputGate, 0)
    state.netGain = ni.generation - state.desiredInput
    if not isOnline(info) and ni.temp <= CFG.cooldownSafeTemp then
      goIdle("SCRAM complete")
    end
    return
  end

  if state.autoShutdown then
    cooldownControl(info)
    state.netGain = ni.generation - state.desiredInput
    return
  end

  if state.phase == "IGNITION HOLD" then
    ignitionHoldControl(info)
    state.netGain = ni.generation - state.desiredInput - state.desiredOutput
    return
  end

  if isOnline(info) then
    if state.phase ~= "RUNNING" then resetPID() end
    runningControl(info, dt)
    return
  end

  state.desiredOutput = 0
  state.netGain = 0
  setGateFlow(outputGate, 0)

  if state.chargeRequested then
    state.desiredInput = CFG.chargeInput
    setGateFlow(inputGate, CFG.chargeInput)
    safeCall(reactor, "chargeReactor")

    if ni.fieldPct >= CFG.startupReadyField and ni.saturationPct >= CFG.startupReadySat and ni.temp >= CFG.startupReadyTemp then
      state.phase = "READY"
      state.message = "Ready to activate"
    else
      state.phase = "CHARGING"
      state.message = "Charging reactor"
    end
    return
  end

  state.phase = "IDLE"
  state.desiredInput = 0
  state.desiredOutput = 0
  setGateFlow(inputGate, 0)
  setGateFlow(outputGate, 0)
  state.message = "Idle - press CHARGE to begin"
end

local function fieldColor(v)
  if v <= CFG.scramField then return UI.bad end
  if v < CFG.targetField then return UI.warn end
  return UI.good
end

local function satColor(v)
  if v <= CFG.scramSaturation then return UI.bad end
  if v < CFG.targetSaturation then return UI.warn end
  return UI.good
end

local function tempColor(v)
  if v >= CFG.scramTemp then return UI.bad end
  if v > CFG.targetTemp then return UI.warn end
  return UI.good
end

local function netColor(v)
  if v > 0 then return UI.good end
  if v == 0 then return UI.warn end
  return UI.bad
end

local function drawMain(info)
  clearMonitor()
  state.buttonMap = {}

  local ni = state.lastNormalized or normalizeInfo(info)
  local w, h = mon.getSize()
  local online = isOnline(info)

  centerText(1, CFG.title, UI.accent, UI.bg)
  writeAt(1, 2, string.rep("-", w), UI.dim, UI.bg)

  writeAt(1, 3, "Phase: " .. state.phase, UI.accent, UI.bg)
  writeAt(1, 4, "Raw Status: " .. tostring(ni.status), UI.dim, UI.bg)
  writeAt(1, 5, "Derived Online: " .. tostring(online), online and UI.good or UI.warn, UI.bg)
  writeAt(1, 6, "Message: " .. tostring(state.message), UI.dim, UI.bg)

  writeAt(1, 8, "Field: " .. fmtPct(ni.fieldPct), fieldColor(ni.fieldPct), UI.bg)
  progressBar(1, 9, w, ni.fieldPct, colors.blue, colors.gray)

  writeAt(1, 11, "Saturation: " .. fmtPct(ni.saturationPct), satColor(ni.saturationPct), UI.bg)
  progressBar(1, 12, w, ni.saturationPct, colors.green, colors.gray)

  writeAt(1, 14, "Temp: " .. fmtInt(ni.temp) .. " C", tempColor(ni.temp), UI.bg)
  writeAt(1, 15, "Generation: " .. fmtInt(ni.generation) .. " RF/t", UI.good, UI.bg)
  writeAt(1, 16, "Field Input/Drain: " .. fmtInt(ni.fieldDrain) .. " RF/t", UI.warn, UI.bg)
  writeAt(1, 17, "Input Gate: " .. fmtInt(state.desiredInput) .. " RF/t", UI.accent, UI.bg)
  writeAt(1, 18, "Output Gate: " .. fmtInt(state.desiredOutput) .. " RF/t", UI.accent, UI.bg)
  writeAt(1, 19, "Net Gain: " .. fmtInt(state.netGain) .. " RF/t", netColor(state.netGain), UI.bg)
  writeAt(1, 20, "Fuel Remaining: " .. string.format("%.2f", ni.fuel), UI.fg, UI.bg)
  writeAt(1, 21, "Fuel %: " .. fmtPct(ni.fuelPct), UI.dim, UI.bg)

  writeAt(1, 23, "Target Temp: " .. fmtInt(CFG.targetTemp) .. " C", UI.dim, UI.bg)
  writeAt(1, 24, "Target Field: " .. fmtPct(CFG.targetField), UI.dim, UI.bg)
  writeAt(1, 25, "Target Saturation: " .. fmtPct(CFG.targetSaturation), UI.dim, UI.bg)

  if CFG.showDebugKeys and h >= 30 then
    writeAt(1, 27, "Field Keys: " .. ni.fieldKeys, UI.dim, UI.bg)
    writeAt(1, 28, "Sat Keys:   " .. ni.saturationKeys, UI.dim, UI.bg)
    writeAt(1, 29, "Fuel Key:   " .. ni.fuelKey, UI.dim, UI.bg)
  end

  local by = h - 2
  local bw = math.floor(w / 4)

  button(state.buttonMap, "charge",   1,          by, bw,        h, "CHARGE",   colors.blue,   colors.white)
  button(state.buttonMap, "activate", bw + 1,     by, bw * 2,    h, "ACTIVATE", colors.green,  colors.black)
  button(state.buttonMap, "scram",    bw * 2 + 1, by, bw * 3,    h, "SCRAM",    colors.red,    colors.white)
  button(state.buttonMap, "tune",     bw * 3 + 1, by, w,         h, "TUNE",     colors.orange, colors.black)
end

local function drawTune()
  clearMonitor()
  state.tuneMap = {}

  local w, h = mon.getSize()
  centerText(1, "Tune Targets", UI.accent, UI.bg)
  writeAt(1, 2, string.rep("-", w), UI.dim, UI.bg)

  writeAt(2, 4, "Target Temp", UI.fg, UI.bg)
  writeAt(w - 12, 4, fmtInt(CFG.targetTemp) .. " C", UI.warn, UI.bg)
  button(state.tuneMap, "temp_m100", 2, 5, 8, 6, "-100", colors.gray, colors.white)
  button(state.tuneMap, "temp_m10", 10, 5, 15, 6, "-10", colors.gray, colors.white)
  button(state.tuneMap, "temp_p10", 17, 5, 22, 6, "+10", colors.gray, colors.white)
  button(state.tuneMap, "temp_p100", 24, 5, 31, 6, "+100", colors.gray, colors.white)

  writeAt(2, 9, "Target Field", UI.fg, UI.bg)
  writeAt(w - 12, 9, fmtPct(CFG.targetField), UI.warn, UI.bg)
  button(state.tuneMap, "field_m5", 2, 10, 8, 11, "-5%", colors.gray, colors.white)
  button(state.tuneMap, "field_m1", 10, 10, 15, 11, "-1%", colors.gray, colors.white)
  button(state.tuneMap, "field_p1", 17, 10, 22, 11, "+1%", colors.gray, colors.white)
  button(state.tuneMap, "field_p5", 24, 10, 31, 11, "+5%", colors.gray, colors.white)

  writeAt(2, 14, "Target Saturation", UI.fg, UI.bg)
  writeAt(w - 12, 14, fmtPct(CFG.targetSaturation), UI.warn, UI.bg)
  button(state.tuneMap, "sat_m5", 2, 15, 8, 16, "-5%", colors.gray, colors.white)
  button(state.tuneMap, "sat_m1", 10, 15, 15, 16, "-1%", colors.gray, colors.white)
  button(state.tuneMap, "sat_p1", 17, 15, 22, 16, "+1%", colors.gray, colors.white)
  button(state.tuneMap, "sat_p5", 24, 15, 31, 16, "+5%", colors.gray, colors.white)

  button(state.tuneMap, "back",  2, h - 2, math.floor(w / 2) - 1, h, "BACK", colors.blue, colors.white)
  button(state.tuneMap, "scram", math.floor(w / 2) + 1, h - 2, w, h, "SCRAM", colors.red, colors.white)
end

local function redraw()
  local info = state.lastInfo
  if not info then
    clearMonitor()
    centerText(2, "Waiting for reactor data...", UI.warn, UI.bg)
    return
  end

  if state.screen == "main" then
    drawMain(info)
  else
    drawTune()
  end
end

local function handleMainTouch(x, y)
  local now = os.clock()
  if now - state.lastTouch < CFG.buttonDebounce then return end
  state.lastTouch = now

  local id = hitButton(state.buttonMap, x, y)
  if not id then return end

  if id == "charge" then
    doCharge()
  elseif id == "activate" then
    doActivate()
  elseif id == "scram" then
    doScram("Manual SCRAM")
  elseif id == "tune" then
    state.screen = "tune"
  end
end

local function handleTuneTouch(x, y)
  local now = os.clock()
  if now - state.lastTouch < CFG.buttonDebounce then return end
  state.lastTouch = now

  local id = hitButton(state.tuneMap, x, y)
  if not id then return end

  if id == "back" then
    state.screen = "main"
    return
  elseif id == "scram" then
    doScram("Manual SCRAM")
    return
  end

  if id == "temp_m100" then CFG.targetTemp = clamp(CFG.targetTemp - 100, 3000, 9000) end
  if id == "temp_m10"  then CFG.targetTemp = clamp(CFG.targetTemp - 10, 3000, 9000) end
  if id == "temp_p10"  then CFG.targetTemp = clamp(CFG.targetTemp + 10, 3000, 9000) end
  if id == "temp_p100" then CFG.targetTemp = clamp(CFG.targetTemp + 100, 3000, 9000) end

  if id == "field_m5" then CFG.targetField = clamp(CFG.targetField - 0.05, 0.35, 0.70) end
  if id == "field_m1" then CFG.targetField = clamp(CFG.targetField - 0.01, 0.35, 0.70) end
  if id == "field_p1" then CFG.targetField = clamp(CFG.targetField + 0.01, 0.35, 0.70) end
  if id == "field_p5" then CFG.targetField = clamp(CFG.targetField + 0.05, 0.35, 0.70) end

  if id == "sat_m5" then CFG.targetSaturation = clamp(CFG.targetSaturation - 0.05, 0.35, 0.90) end
  if id == "sat_m1" then CFG.targetSaturation = clamp(CFG.targetSaturation - 0.01, 0.35, 0.90) end
  if id == "sat_p1" then CFG.targetSaturation = clamp(CFG.targetSaturation + 0.01, 0.35, 0.90) end
  if id == "sat_p5" then CFG.targetSaturation = clamp(CFG.targetSaturation + 0.05, 0.35, 0.90) end
end

bindPeripherals()
mon.setTextScale(CFG.monitorScale)
clearMonitor()

setGateFlow(inputGate, 0)
setGateFlow(outputGate, 0)
state.message = "Reactor: " .. reactorName .. " | Monitor: " .. monitorName

local tickTimer = os.startTimer(CFG.tickRate)

while true do
  local ev = { os.pullEvent() }
  local e = ev[1]

  if e == "timer" and ev[2] == tickTimer then
    local info = getInfo()
    if info then
      state.lastInfo = info
      updateControl(info)
    else
      state.message = "Failed to read reactor info"
    end

    redraw()
    tickTimer = os.startTimer(CFG.tickRate)

  elseif e == "monitor_touch" then
    local side, x, y = ev[2], ev[3], ev[4]
    if side == monitorName then
      if state.screen == "main" then
        handleMainTouch(x, y)
      else
        handleTuneTouch(x, y)
      end
      redraw()
    end

  elseif e == "peripheral" or e == "peripheral_detach" then
    local ok, err = pcall(function()
      bindPeripherals()
      mon.setTextScale(CFG.monitorScale)
    end)

    if ok then
      state.message = "Peripheral layout refreshed"
    else
      state.message = "Peripheral refresh failed: " .. tostring(err)
    end

    redraw()
  end
end
