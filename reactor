}

local reactorName, reactor
local monitorName, mon
local inputGate, outputGate

local state = {
  screen = "main",
  phase = "IDLE",
  message = "Booting...",
  lastInfo = nil,
  lastNormalized = nil,

  desiredInput = 0,
  desiredOutput = 0,
