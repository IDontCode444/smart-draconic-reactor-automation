-- ======= START ===========
-- =========================

-- Safe startup
setGateFlow(outputGate, 0)
setGateFlow(inputGate, 0)
state.lastInfo = readInfo()
setMode("IDLE", "Ready")

parallel.waitForAny(uiLoop, controlLoop, inputLoop)
