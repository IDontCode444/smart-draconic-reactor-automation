  writeAt(t, 2, 3, "Status: ", colors.white, colors.black)
  writeAt(t, 10, 3, info and statusLabel(info.status) or "NO DATA", info and statusColor(info.status) or colors.red, colors.black)

  writeAt(t, 2, 4, "Auto: ", colors.white, colors.black)
  writeAt(t, 8, 4, state.autoEnabled and "ON" or "OFF", state.autoEnabled and colors.lime or colors.orange, colors.black)

  writeAt(t, 2, 6, "Reactor: " .. CONFIG.reactorName, colors.lightGray, colors.black)
  writeAt(t, 2, 7, "Input:   " .. CONFIG.inputGateName, colors.lightGray, colors.black)
  writeAt(t, 2, 8, "Output:  " .. CONFIG.outputGateName, colors.lightGray, colors.black)

  if info then
    writeAt(t, 2, 10, "Temp:       " .. fmtInt(info.temperature or 0) .. " C", colors.white, colors.black)
    writeAt(t, 2, 11, "Generate:   " .. fmtInt(info.generationRate or 0) .. " RF/t", colors.white, colors.black)
