local function drawTuneDynamic()
  writeAt(24, 8, tostring(CONFIG.targetTemp) .. (" "):rep(10), colors.yellow, colors.black)
  writeAt(24, 12, fmtPct(CONFIG.targetField) .. (" "):rep(10), colors.yellow, colors.black)
  writeAt(24, 16, fmtPct(CONFIG.targetSaturation) .. (" "):rep(10), colors.yellow, colors.black)
  writeAt(24, 20, tostring(CONFIG.targetGain) .. "%" .. (" "):rep(10), colors.yellow, colors.black)

  writeAt(3, 23, "Current mode: " .. string.upper(state.mode) .. (" "):rep(20), colors.lightBlue, colors.black)
  writeAt(3, 24, (" "):rep(monW - 4), colors.white, colors.black)
  writeAt(3, 24, "Status: " .. state.statusMsg, state.statusColor, colors.black)
end

local function redraw(forceStatic)
  forceStatic = forceStatic or false

  if forceStatic or lastStaticPage ~= uiPage then
    if uiPage == "tune" then
      drawTuneStatic()
    else
      drawMainStatic()
    end
    lastStaticPage = uiPage
    uiDirty = true
  end

  if uiPage == "tune" then
    drawTuneDynamic()
  else
    drawMainDynamic(lastInfo)
  end
end

local function handleTouch(side, x, y)
  if side ~= monName then return end
  for _, b in pairs(buttons) do
    if x >= b.x1 and x <= b.x2 and y >= b.y1 and y <= b.y2 then
      local oldPage = uiPage
      if b.fn then b.fn() end
      if uiPage ~= oldPage then
        requestFullRedraw()
      else
        uiDirty = true
      end
      return
    end
  end
end

--========================================================--
-- CONTROL ACTIONS
--========================================================--

local function scram(reason)
  state.emergencyLatch = true
  state.safeStopLatch = true
  state.scramReason = reason or "SCRAM"
  state.mode = "scram"
  state.readyToActivate = false
  state.activateRequested = false
  state.chargeRequested = false
  state.startupSince = nil
  state.bleedSince = nil
  state.primeUntil = nil
  state.fieldRecovery = false
  state.fieldDipCount = 0
  state.justRecovered = false
  state.outputBias = 0

  pcall(function() reactor.stopReactor() end)
  gateSet(gateOut, 0)
  holdInputSafe(lastInfo, math.max(CONFIG.targetField, 55), CONFIG.startupHoldInputFloor, 1.20)
  state.lastOutput = 0

  setStatus("SCRAM: " .. tostring(state.scramReason), colors.red)
end

local function safeShutdown(reason)
  state.safeStopLatch = true
  state.readyToActivate = false
  state.activateRequested = false
  state.startupSince = nil
  state.bleedSince = nil
  state.primeUntil = nil
  state.fieldRecovery = false
  state.fieldDipCount = 0
  state.justRecovered = false
  state.outputBias = 0

  pcall(function() reactor.stopReactor() end)
  gateSet(gateOut, 0)
  holdInputSafe(lastInfo, math.max(CONFIG.targetField, 55), CONFIG.cooldownInputFloor, 1.08)
  state.lastOutput = 0
  state.mode = "stopping"

  setStatus(reason or "Safe shutdown", colors.orange)
end

local function processOperatorRequests(info)
  if state.chargeRequested then
    state.chargeRequested = false
    state.activateRequested = false
    state.readyToActivate = false
    state.startupSince = nil
    state.bleedSince = nil
    state.primeUntil = nil
    state.fieldRecovery = false
    state.fieldDipCount = 0
    state.justRecovered = false
    state.outputBias = 0
    state.mode = "charging"
    resetPIDs()

    pcall(function() reactor.chargeReactor() end)
    gateSet(gateOut, 0)
    holdInputSafe(info, 60, CONFIG.minChargeRate, 1.25)
    state.lastOutput = 0
    uiDirty = true
    setStatus("Charging reactor", colors.yellow)
  end

  if state.activateRequested then
    state.activateRequested = false

    if state.lowFuelLatch then
      setStatus("Blocked: low fuel latch active", colors.red)
      return
    end

    if not info or not chargeReady(info) then
      state.readyToActivate = false
      setStatus("Not ready: charge to 2000C / 50% field / 50% sat", colors.orange)
      return
    end

    gateSet(gateOut, 0)
    holdInputSafe(info, 60, CONFIG.activatePrimeInputFloor, CONFIG.activatePrimeMultiplier)
    state.lastOutput = 0
    state.mode = "priming"
    state.primeUntil = os.clock() + CONFIG.activatePrimeSeconds
    uiDirty = true
    setStatus("Priming injector before activation", colors.yellow)
  end
end

--========================================================--
-- SAFETY / CONTROL
--========================================================--

local function emergencyCheck(info)
  if not info then
    scram("Lost reactor data")
    return true
  end

  if isHardFailStatus(info.status) then
    scram("Reactor entered " .. tostring(info.status))
    return true
  end

  local fp = fieldPct(info)
  local sp = saturationPct(info)
  local fup = fuelPct(info)
  local temp = info.temperature or 0

  if fup <= CONFIG.fuelCritical and (isRunningStatus(info.status) or isWarmupStatus(info.status)) then
    state.lowFuelLatch = true
    scram("Critical fuel low")
    return true
  end

  if fup <= CONFIG.fuelSafeShutdown and isRunningStatus(info.status) then
    state.lowFuelLatch = true
    safeShutdown("Fuel low safe shutdown")
    return true
  end

  if temp >= CONFIG.tempEmergency then
    scram("Temperature emergency")
    return true
  end

  if fp <= CONFIG.fieldEmergency and isRunningStatus(info.status) then
    scram("Field emergency")
    return true
  end

  if sp <= CONFIG.saturationEmergency and isRunningStatus(info.status) then
    scram("Saturation emergency")
    return true
  end

  return false
end

local function applyChargingControl(info)
  gateSet(gateOut, 0)
  holdInputSafe(info, 60, CONFIG.minChargeRate, 1.25)
  state.lastOutput = 0

  if chargeReady(info) then
    state.readyToActivate = true
    state.mode = "ready"
    uiDirty = true
    setStatus("READY - press Activate", colors.lime)
  else
    state.readyToActivate = false
    state.mode = "charging"
    setStatus("Charging / warming up", colors.yellow)
  end
end

local function applyCoolingControl(info)
  gateSet(gateOut, 0)
  holdInputSafe(info, math.max(CONFIG.targetField, 55), CONFIG.cooldownInputFloor, 1.05)
  state.lastOutput = 0

  if state.safeStopLatch then
    setStatus("Safe shutdown in progress", colors.orange)
  else
    setStatus("Cooling reactor", colors.orange)
  end
end

local function computeRunInput(info, dt, holdFieldTarget)
  local fField = state.filtField or fieldPct(info)
  local fTemp  = state.filtTemp or (info.temperature or 0)

  holdFieldTarget = holdFieldTarget or (CONFIG.targetField + 10)

  local baseIn = computeBaseInput(info, holdFieldTarget)
  local minSafeIn = baseIn * CONFIG.inputBaseFloorFactor

  local inFieldTrim = pidUpdate(pidInField, holdFieldTarget - fField, dt)
  local inTempTrim  = pidUpdate(pidInTemp, fTemp - CONFIG.targetTemp, dt)

  local wantIn = baseIn + inFieldTrim + inTempTrim
  wantIn = math.max(wantIn, minSafeIn)
  wantIn = clamp(wantIn, 0, CONFIG.maxInput)

  local slewed = slew(state.lastInput, wantIn, CONFIG.inputRampUp, CONFIG.inputRampDown)
  return slewed, baseIn
end

local function applyPrimingControl(info)
  gateSet(gateOut, 0)
  holdInputSafe(info, 60, CONFIG.activatePrimeInputFloor, CONFIG.activatePrimeMultiplier)
  state.lastOutput = 0

  if os.clock() >= (state.primeUntil or 0) then
    pcall(function() reactor.activateReactor() end)
    state.primeUntil = nil
    state.startupSince = os.clock()
    state.bleedSince = nil
    state.fieldRecovery = false
    state.fieldDipCount = 0
    state.justRecovered = false
    state.outputBias = 0
    state.mode = "startup_hold"
    uiDirty = true
    setStatus("Activated - startup hold", colors.lime)
  else
    setStatus("Priming injector before activation", colors.yellow)
  end
end

local function applyStartupHoldControl(info)
  local fp = fieldPct(info)
  local sp = saturationPct(info)
  local temp = info.temperature or 0
  local elapsed = os.clock() - (state.startupSince or os.clock())

  gateSet(gateOut, 0)
  state.lastOutput = 0

  local base = computeBaseInput(info, 60)
  local wantIn = math.max(base * CONFIG.startupHoldMultiplier, CONFIG.startupHoldInputFloor)

  if fp < CONFIG.startupRecoverField or sp < CONFIG.startupRecoverSat then
    wantIn = math.max(wantIn, CONFIG.startupHoldInputFloor * 1.10)
  end

  wantIn = clamp(wantIn, 0, CONFIG.maxInput)
  gateSet(gateIn, wantIn)
  state.lastInput = wantIn

  if elapsed >= CONFIG.startupHoldSeconds then
    state.mode = "startup_bleed"
    state.bleedSince = os.clock()
    state.lastOutput = CONFIG.bleedOutputStart
    gateSet(gateOut, CONFIG.bleedOutputStart)
    uiDirty = true
    setStatus("Startup bleed phase", colors.yellow)
    return
  end

  state.mode = "startup_hold"
  setStatus(
    ("Startup hold %.1fs  T:%d  F:%.1f%%  S:%.1f%%"):format(
      elapsed, temp, fp, sp
    ),
    colors.yellow
  )
end

local function applyStartupBleedControl(info)
  local fp = fieldPct(info)
  local sp = saturationPct(info)
  local temp = info.temperature or 0
  local gen = info.generationRate or 0
  local elapsed = os.clock() - (state.bleedSince or os.clock())
  local gScale = gainScale()

  local bleedFieldTarget = math.max(CONFIG.targetField + 10, 60)
  local baseIn = computeBaseInput(info, bleedFieldTarget)
  local wantIn = math.max(baseIn * CONFIG.bleedInputMultiplier, CONFIG.bleedInputFloor)

  if fp < CONFIG.startupRecoverField then
    wantIn = math.max(wantIn, baseIn * 1.60)
  end
  if sp < CONFIG.startupRecoverSat then
    wantIn = math.max(wantIn, baseIn * 1.40)
  end

  wantIn = clamp(wantIn, 0, CONFIG.maxInput)
  gateSet(gateIn, wantIn)
  state.lastInput = wantIn

  local rampFactor = 1
  if sp > CONFIG.targetSaturation + 30 then
    rampFactor = 4
  elseif sp > CONFIG.targetSaturation + 20 then
    rampFactor = 3
  elseif sp > CONFIG.targetSaturation + 10 then
    rampFactor = 2
  end

  local bleedCap = math.max(CONFIG.bleedOutputMax, gen * (0.9 + 0.4 * gScale))
  bleedCap = clamp(bleedCap, CONFIG.bleedOutputStart, CONFIG.maxOutput)

  local bleedTarget = state.lastOutput + (CONFIG.bleedOutputRampUp * rampFactor)

  if fp < CONFIG.startupRecoverField - 2 or sp < CONFIG.startupRecoverSat - 8 then
    bleedTarget = math.max(0, state.lastOutput - CONFIG.bleedOutputRampUp * 2)
  end

  bleedTarget = clamp(bleedTarget, 0, bleedCap)
  gateSet(gateOut, bleedTarget)
  state.lastOutput = bleedTarget

  local readyForRun =
    elapsed >= CONFIG.bleedMinSeconds
    and gen >= CONFIG.startupExitGeneration
    and fp >= CONFIG.startupExitField
    and isRunningStatus(info.status)

  local timeoutFallback =
    elapsed >= CONFIG.bleedTimeoutSeconds
    and gen > 0
    and fp >= 45
    and isRunningStatus(info.status)

  if readyForRun or timeoutFallback then
    state.mode = "run"
    resetPIDs()
    state.fieldRecovery = false
    state.outputBias = math.min(state.lastOutput, gen * 0.35)
    uiDirty = true
    setStatus("Startup complete - run mode", colors.lime)
    return
  end

  state.mode = "startup_bleed"
  setStatus(
    ("Startup bleed %.1fs  T:%d  G:%s  F:%.1f%%  S:%.1f%%  In:%s  Out:%s"):format(
      elapsed, temp, fmtInt(gen), fp, sp, fmtInt(wantIn), fmtInt(bleedTarget)
    ),
    colors.yellow
  )
end

local function applyRunControl(info, dt)
  local rawField = fieldPct(info)
  local rawSat = saturationPct(info)
  local rawTemp = info.temperature or 0
  local fField = state.filtField or rawField
  local fSat = state.filtSat or rawSat
  local fTemp = state.filtTemp or rawTemp
  local prevField = state.prevFiltField or fField
  local fup = fuelPct(info)
  local gen = info.generationRate or 0
  local gScale = gainScale()

  local fieldDelta = fField - prevField
  local recoverEnter = fieldRecoverEnterThreshold()
  local recoverExit = fieldRecoverExitThreshold()
  local fieldSoftBand = fieldSoftThreshold()
  local fieldHardBand = fieldHardThreshold()

  local severeFieldDip = (fField < fieldHardBand) or (fieldDelta <= -CONFIG.fieldDropTrip)
  local shakyField = (fField < recoverEnter) or (fieldDelta <= -(CONFIG.fieldDropTrip * 0.55))

  if severeFieldDip then
    state.fieldDipCount = CONFIG.fieldTripSamples
  elseif shakyField then
    state.fieldDipCount = math.min((state.fieldDipCount or 0) + 1, CONFIG.fieldTripSamples)
  else
    state.fieldDipCount = math.max((state.fieldDipCount or 0) - 1, 0)
  end

  if severeFieldDip or (state.fieldDipCount or 0) >= CONFIG.fieldTripSamples then
    state.fieldRecovery = true
  elseif state.fieldRecovery and fField > recoverExit and rawField > math.max(recoverExit - 1, CONFIG.targetField + 3) and fieldDelta >= -1.0 then
    state.fieldRecovery = false
    state.fieldDipCount = 0
    state.justRecovered = true
  end

  local holdFieldTarget = CONFIG.targetField + 8
  local wantIn, baseIn = computeRunInput(info, dt, holdFieldTarget)

  if state.fieldRecovery then
    local recoverTarget = CONFIG.targetField + 10
    baseIn = computeBaseInput(info, recoverTarget)
    wantIn = math.max(baseIn * 1.22, CONFIG.bleedInputFloor, baseIn + 3000000)
    wantIn = slew(state.lastInput, clamp(wantIn, 0, CONFIG.maxInput), CONFIG.inputRampUp, CONFIG.inputRampDown)

    local keepOut = math.min(state.lastOutput * 0.35, gen * 0.08)
    if severeFieldDip or fField < fieldHardBand or fSat < CONFIG.satLowBand then
      keepOut = 0
    end
    local wantOut = slew(state.lastOutput, clamp(keepOut, 0, CONFIG.maxOutput), CONFIG.outputRampUp, CONFIG.outputRampDown)

    gateSet(gateIn, wantIn)
    gateSet(gateOut, wantOut)

    state.lastInput = wantIn
    state.lastOutput = wantOut
    state.outputBias = wantOut
    state.mode = "recover"
    setStatus(
      ("Field recovery F:%.1f raw:%.1f dF:%.1f dips:%d In:%s Out:%s"):format(
        fField, rawField, fieldDelta, state.fieldDipCount or 0, fmtInt(wantIn), fmtInt(wantOut)
      ),
      colors.orange
    )
    return
  end

  local satError = fSat - CONFIG.targetSaturation
  local tempError = CONFIG.targetTemp - fTemp

  local outSatTrim  = pidUpdate(pidOutSat, satError, dt)
  local outTempTrim = pidUpdate(pidOutTemp, tempError, dt)

  local biasUp   = CONFIG.outputBiasStepUpBase * gScale
  local biasDown = CONFIG.outputBiasStepDownBase
  local biasDownFast = CONFIG.outputBiasStepDownFast

  local outputFactorMax = CONFIG.outputBiasMaxFactorBase + ((gScale - 1.0) * 0.22)
  outputFactorMax = clamp(outputFactorMax, 0.25, 0.95)
  local maxAllowedOut = gen * outputFactorMax

  if fTemp < CONFIG.targetTemp - 1000 and fSat > CONFIG.targetSaturation + 10 and fField > recoverExit then
    maxAllowedOut = math.max(maxAllowedOut, gen * CONFIG.outputBiasHeatPushFactor)
  end

  maxAllowedOut = clamp(maxAllowedOut, 0, CONFIG.maxOutput)

  local safeFieldHeadroom = math.max(0, fField - CONFIG.targetField)
  local biasBaseFactor = 0.18

  if safeFieldHeadroom >= 10 and fSat >= CONFIG.targetSaturation + 15 then
    biasBaseFactor = 0.34
  elseif safeFieldHeadroom >= 6 and fSat >= CONFIG.targetSaturation + 8 then
    biasBaseFactor = 0.26
  elseif safeFieldHeadroom >= 3 then
    biasBaseFactor = 0.20
  end

  local biasTarget = (gen * biasBaseFactor) + outSatTrim + outTempTrim

  if state.justRecovered then
    biasTarget = math.max(biasTarget, gen * 0.28)
  end

  if fField < fieldSoftBand then
    biasTarget = math.min(biasTarget, gen * 0.35)
  end

  if fField < fieldHardBand or fSat < CONFIG.satLowBand then
    biasTarget = math.min(biasTarget, gen * 0.05)
    wantIn = math.max(wantIn, baseIn * 1.22)
  elseif fField < fieldSoftBand or fSat < CONFIG.satSoftBand then
    biasTarget = math.min(biasTarget, gen * 0.25)
    wantIn = math.max(wantIn, baseIn * 1.12)
  end

  if fieldDelta < -2.0 then
    biasTarget = math.min(biasTarget, gen * 0.15)
    wantIn = math.max(wantIn, baseIn * 1.16)
  elseif fieldDelta < -1.0 then
    biasTarget = math.min(biasTarget, gen * 0.25)
    wantIn = math.max(wantIn, baseIn * 1.10)
  end

  if fTemp > CONFIG.targetTemp - 50 then
    biasTarget = math.min(biasTarget, gen * 0.22)
  end

  if fSat > CONFIG.targetSaturation + 18 and fField > recoverExit and fTemp < CONFIG.targetTemp - 300 then
    biasTarget = math.max(biasTarget, gen * (0.50 + 0.15 * gScale))
  elseif fSat > CONFIG.targetSaturation + 10 and fField > fieldSoftBand and fTemp < CONFIG.targetTemp - 100 then
    biasTarget = math.max(biasTarget, gen * (0.36 + 0.10 * gScale))
  end

  biasTarget = clamp(biasTarget, 0, maxAllowedOut)

  local biasStepUp = biasUp
  local biasStepDownNow = biasDown

  if state.justRecovered then
    biasStepUp = math.max(biasStepUp, CONFIG.outputRampUp * 2)
  end

  if fieldDelta < -1.0 or fField < fieldSoftBand or fSat < CONFIG.satSoftBand then
    biasStepDownNow = biasDownFast
  end

  state.outputBias = slew(state.outputBias, biasTarget, biasStepUp, biasStepDownNow)
  state.justRecovered = false

  local wantOut = slew(state.lastOutput, state.outputBias, CONFIG.outputRampUp, CONFIG.outputRampDown)

  gateSet(gateIn, clamp(wantIn, 0, CONFIG.maxInput))
  gateSet(gateOut, clamp(wantOut, 0, CONFIG.maxOutput))

  state.lastInput = wantIn
  state.lastOutput = wantOut
  state.mode = "run"
  state.safeStopLatch = false
  state.emergencyLatch = false
  state.scramReason = nil
  state.fieldDipCount = math.max((state.fieldDipCount or 0) - 1, 0)

  setStatus(
    ("Run | T:%d F:%.1f/%.1f dF:%.1f dips:%d S:%.1f/%.1f Fuel:%.1f%% Out:%s"):format(
      rawTemp, rawField, fField, fieldDelta, state.fieldDipCount or 0, rawSat, fSat, fup, fmtInt(wantOut)
    ),
    colors.lime
  )
end

local function applyControl(info, dt)
  processOperatorRequests(info)

  if emergencyCheck(info) then
    return
  end

  updateFiltered(info)

  local status = info.status
  local fup = fuelPct(info)

  if state.lowFuelLatch and fup > (CONFIG.fuelSafeShutdown + 5) and (status == "cold" or status == "cooling") then
    state.lowFuelLatch = false
    uiDirty = true
    setStatus("Fuel latch cleared", colors.lime)
  end

  if not state.autoEnabled then
    setStatus("Auto paused", colors.orange)
    return
  end

  if state.mode == "priming" then
    applyPrimingControl(info)
    return
  end

  if status == "cold" then
    gateSet(gateIn, 0)
    gateSet(gateOut, 0)
    state.lastInput = 0
    state.lastOutput = 0
    state.readyToActivate = false
    state.startupSince = nil
    state.bleedSince = nil
    state.primeUntil = nil
    state.fieldRecovery = false
    state.fieldDipCount = 0
    state.justRecovered = false
    state.outputBias = 0
    state.filtField = nil
    state.filtSat = nil
    state.filtTemp = nil
    state.prevFiltField = nil
    state.mode = "idle"
    uiDirty = true

    if state.safeStopLatch then
      setStatus("Reactor offline (safe stop)", colors.orange)
    else
      setStatus("Reactor offline", colors.lightGray)
    end
    return
  end

  if isWarmupStatus(status) then
    applyChargingControl(info)
    return
  end

  if status == "stopping" or status == "cooling" then
    state.readyToActivate = false
    state.mode = (status == "stopping") and "stopping" or "cooling"
    state.fieldRecovery = false
    state.fieldDipCount = 0
    state.justRecovered = false
    state.outputBias = 0
    uiDirty = true
    applyCoolingControl(info)
    return
  end

  if isRunningStatus(status) then
    if state.mode == "startup_hold" then
      applyStartupHoldControl(info)
      return
    end

    if state.mode == "startup_bleed" then
      applyStartupBleedControl(info)
      return
    end

    if state.startupSince ~= nil and state.mode ~= "run" then
      applyStartupHoldControl(info)
      return
    end

    applyRunControl(info, dt)
    return
  end

  state.readyToActivate = false
  state.mode = "idle"
  state.fieldRecovery = false
  state.justRecovered = false
  state.outputBias = 0
  uiDirty = true
  setStatus("Unhandled status: " .. tostring(status), colors.orange)
end

--========================================================--
-- LOOPS
--========================================================--

local function controlLoop()
  resetPIDs()

  while running do
    local now = os.clock()
    local dt = now - state.lastLoopTime
    if dt <= 0 then dt = CONFIG.controlRate end
    state.lastLoopTime = now

    local info = getInfo()
    lastInfo = info

    if not info then
      setStatus("No reactor info", colors.red)
      gateSet(gateOut, 0)
    else
      applyControl(info, dt)
    end

    sleep(CONFIG.controlRate)
  end
end

local function uiLoop()
  local lastSnapshot = ""

  while running do
    local info = lastInfo
    local snapshot = table.concat({
      uiPage,
      state.mode,
      state.statusMsg,
      tostring(state.statusColor),
      tostring(state.autoEnabled),
      tostring(CONFIG.targetTemp),
      tostring(CONFIG.targetField),
      tostring(CONFIG.targetSaturation),
      tostring(CONFIG.targetGain),
      tostring(state.fieldRecovery),
      tostring(math.floor(state.outputBias or 0)),
      info and tostring(math.floor(info.temperature or 0)) or "nil",
      info and tostring(math.floor((info.generationRate or 0) / 1000)) or "nil",
      info and tostring(math.floor((fieldPct(info) or 0) * 10)) or "nil",
      info and tostring(math.floor((saturationPct(info) or 0) * 10)) or "nil",
      info and tostring(math.floor((fuelPct(info) or 0) * 10)) or "nil",
      tostring(math.floor(gateGet(gateIn) or 0)),
      tostring(math.floor(gateGet(gateOut) or 0))
    }, "|")

    if uiDirty or snapshot ~= lastSnapshot or state.redrawQueued then
      redraw(state.redrawQueued)
      lastSnapshot = snapshot
      uiDirty = false
      state.redrawQueued = false
    end

    sleep(CONFIG.uiRate)
  end
end

local function eventLoop()
  while running do
    local e = { os.pullEvent() }

    if e[1] == "monitor_touch" then
      handleTouch(e[2], e[3], e[4])
    elseif e[1] == "monitor_resize" then
      pcall(monitor.setTextScale, CONFIG.monitorScale)
      monW, monH = monitor.getSize()
      requestFullRedraw()
    elseif e[1] == "terminate" then
      running = false
      gateSet(gateOut, 0)
      error("Terminated")
    end
  end
end

