-- Draconic Reactor Controller (single-file, updated)
-- Improvements:
--  1) Partial monitor redraw to reduce flicker
--  2) Fuel-based auto shutdown
--  3) Status/phase label in UI
--
-- Expected peripherals:
--   - reactor logic adapter
--   - input flux gate  (injector side)
--   - output flux gate (extractor side)
--   - monitor
--
-- Adjust the peripheral names below to match your setup.

-----------------------------
-- CONFIG
-----------------------------

local CFG = {
  -- Peripheral names
  reactorName   = "draconic_reactor",
  inputGateName = "flux_gate_0",
  outputGateName= "flux_gate_1",
  monitorName   = "monitor_0",

  -- Monitor
  monitorScale = 0.5,
  title = "Draconic Reactor Control",

  -- Timing
  tick = 0.1,              -- main loop delay
  uiRefresh = 0.15,        -- redraw interval
  startupHoldTime = 8.0,   -- how long to hold startup boost after activation
  buttonDebounce = 0.25,

  -- Startup behavior
  startupChargeField = 0.50,   -- minimum shield before activation allowed
  startupChargeSat   = 0.50,   -- minimum saturation before activation allowed
  startupTemp        = 2000,   -- minimum temp before activation allowed
  startupInputRate   = 12000000, -- strong startup injection
  startupOutputRate  = 0,

  -- Running targets
  targetField        = 0.45,   -- normal operating target
  minField           = 0.25,   -- emergency minimum
  highField          = 0.60,   -- aggressive recovery target
  targetSaturation   = 0.60,   -- preferred sat level
  minSaturation      = 0.20,   -- emergency minimum

  -- Input control
  minInputRate       = 250000,
  maxInputRate       = 25000000,
  inputResponse      = 1.10,
  emergencyInputMult = 1.35,

  -- Output control
  baseOutputRate     = 3000000,
  maxOutputRate      = 12000000,
  minOutputRate      = 0,
  outputResponse     = 1.08,
  lowSatOutputMult   = 0.72,
  lowFieldOutputMult = 0.55,
  hotTempOutputMult  = 0.78,

  -- Temperature guidance
  warmTemp           = 5000,
  hotTemp            = 7500,
  dangerTemp         = 8000,

  -- Fuel shutdown
  enableFuelShutdown = true,
  shutdownFuelAmount = 4.0,     -- trigger shutdown when reactable fuel <= this
  shutdownHoldInput  = 4000000, -- keep field fed during cooldown
  shutdownFieldTarget= 0.50,    -- field target while cooling down
  shutdownUntilTemp  = 2500,    -- treat as safe cooldown point for "idle" phase

  -- Safety
  scramField         = 0.15,
  scramSaturation    = 0.10,
  scramTemp          = 8500,

  -- UI colors
  colors = {
    bg = colors.black,
    fg = colors.white,
    good = colors.lime,
    warn = colors.yellow,
    bad = colors.red,
    info = colors.cyan,
    accent = colors.orange,
    dim = colors.lightGray,
    button = colors.gray,
    buttonText = colors.white,
  },
}

-----------------------------
-- PERIPHERALS
-----------------------------

local reactor = peripheral.wrap(CFG.reactorName)
local inputGate = peripheral.wrap(CFG.inputGateName)
local outputGate = peripheral.wrap(CFG.outputGateName)
local mon = peripheral.wrap(CFG.monitorName)

if not reactor then error("Missing reactor peripheral: " .. tostring(CFG.reactorName)) end
if not inputGate then error("Missing input flux gate: " .. tostring(CFG.inputGateName)) end
if not outputGate then error("Missing output flux gate: " .. tostring(CFG.outputGateName)) end
if not mon then error("Missing monitor: " .. tostring(CFG.monitorName)) end

-----------------------------
-- MONITOR SETUP
-----------------------------

mon.setTextScale(CFG.monitorScale)
mon.setBackgroundColor(CFG.colors.bg)
mon.setTextColor(CFG.colors.fg)
mon.clear()

local MON_W, MON_H = mon.getSize()
local lastFrame = {}

-----------------------------
-- STATE
-----------------------------

local state = {
  mode = "IDLE",                 -- IDLE / STARTUP / RUN / SHUTDOWN / SCRAM
  enabled = true,
  startupActive = false,
  startupActivatedAt = nil,
  startupPressedAt = 0,
  lastUI = 0,
  lastTouch = 0,
  autoFuelShutdown = false,
  shutdownIssued = false,
  desiredInput = CFG.minInputRate,
  desiredOutput = CFG.baseOutputRate,
  message = "Ready",
}

-----------------------------
-- HELPERS
-----------------------------

local function clamp(v, lo, hi)
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

local function round(n)
  return math.floor(n + 0.5)
end

local function fmtInt(n)
  if not n then return "?" end
  n = tonumber(n) or 0
  local absn = math.abs(n)
  if absn >= 1e12 then return string.format("%.2fT", n / 1e12) end
  if absn >= 1e9  then return string.format("%.2fG", n / 1e9) end
  if absn >= 1e6  then return string.format("%.2fM", n / 1e6) end
  if absn >= 1e3  then return string.format("%.2fk", n / 1e3) end
  return tostring(round(n))
end

local function fmtPct(x)
  if x == nil then return "?" end
  return string.format("%.1f%%", x * 100)
end

local function safeCall(obj, method, ...)
  if not obj or type(obj[method]) ~= "function" then return nil end
  local ok, a, b, c, d = pcall(obj[method], ...)
  if ok then return a, b, c, d end
  return nil
end

local function getInfo()
  local info = safeCall(reactor, "getReactorInfo")
  if type(info) ~= "table" then return nil end
  return info
end

local function setGateFlow(gate, rate)
  rate = math.max(0, math.floor(rate or 0))

  -- common DE/flux gate methods
  if safeCall(gate, "setOverrideEnabled", true) ~= nil then end
  if safeCall(gate, "setSignalLowFlow", rate) ~= nil then return true end
  if safeCall(gate, "setFlowOverride", rate) ~= nil then return true end
  if safeCall(gate, "setTransferRate", rate) ~= nil then return true end
  return false
end

local function getStatus(info)
  return info.status or info.reactorState or "unknown"
end

local function getField(info)
  return info.fieldStrength or info.shieldCharge or 0
end

local function getMaxField(info)
  return info.maxFieldStrength or info.maxShieldCharge or 1
end

local function getFieldPct(info)
  local mx = getMaxField(info)
  if not mx or mx == 0 then return 0 end
  return getField(info) / mx
end

local function getSaturation(info)
  return info.energySaturation or info.saturation or 0
end

local function getMaxSaturation(info)
  return info.maxEnergySaturation or info.maxSaturation or 1
end

local function getSatPct(info)
  local mx = getMaxSaturation(info)
  if not mx or mx == 0 then return 0 end
  return getSaturation(info) / mx
end

local function getTemp(info)
  return info.temperature or 0
end

local function getGeneration(info)
  return info.generationRate or info.genRate or 0
end

local function getFieldDrain(info)
  return info.fieldDrainRate or info.fieldInputRate or 0
end

local function getFuel(info)
  return info.reactableFuel
      or info.fuel
      or info.fuelRemaining
      or 0
end

local function isOnline(info)
  local s = string.lower(tostring(getStatus(info)))
  return s:find("online") ~= nil
      or s:find("running") ~= nil
      or s:find("active") ~= nil
end

local function isChargedForStartup(info)
  return getFieldPct(info) >= CFG.startupChargeField
     and getSatPct(info)   >= CFG.startupChargeSat
     and getTemp(info)     >= CFG.startupTemp
end

local function canActivate(info)
  local s = string.lower(tostring(getStatus(info)))
  return s:find("charged") ~= nil
      or s:find("warming") ~= nil
      or isChargedForStartup(info)
end

local function chargeReactor()
  return safeCall(reactor, "chargeReactor")
end

local function activateReactor()
  return safeCall(reactor, "activateReactor")
end

local function stopReactor()
  return safeCall(reactor, "stopReactor")
end

local function phaseLabel(info)
  if state.mode == "SCRAM" then
    return "SCRAM"
  elseif state.mode == "SHUTDOWN" then
    if state.autoFuelShutdown then
      return "AUTO SHUTDOWN (FUEL)"
    end
    return "SHUTDOWN"
  elseif state.mode == "STARTUP" then
    if not isOnline(info) then
      if canActivate(info) then
        return "STARTUP READY"
      else
        return "CHARGING"
      end
    else
      return "STARTUP HOLD"
    end
  elseif state.mode == "RUN" then
    return "RUNNING"
  else
    local s = string.lower(tostring(getStatus(info)))
    if s:find("cold") then return "COLD" end
    if s:find("cool") then return "COOLING" end
    if s:find("invalid") then return "INVALID" end
    return "IDLE"
  end
end

local function scram(reason)
  state.mode = "SCRAM"
  state.startupActive = false
  state.autoFuelShutdown = false
  state.shutdownIssued = false
  state.desiredOutput = 0
  state.desiredInput = CFG.maxInputRate
  setGateFlow(outputGate, 0)
  setGateFlow(inputGate, CFG.maxInputRate)
  state.message = "SCRAM: " .. reason
end

local function beginStartup()
  state.mode = "STARTUP"
  state.startupActive = true
  state.startupActivatedAt = nil
  state.autoFuelShutdown = false
  state.shutdownIssued = false
  state.desiredInput = CFG.startupInputRate
  state.desiredOutput = CFG.startupOutputRate
  setGateFlow(outputGate, CFG.startupOutputRate)
  setGateFlow(inputGate, CFG.startupInputRate)
  chargeReactor()
  state.message = "Startup initiated"
end

local function beginShutdown(fuelTriggered)
  state.mode = "SHUTDOWN"
  state.startupActive = false
  state.autoFuelShutdown = fuelTriggered and true or false
  state.desiredOutput = 0
  state.desiredInput = CFG.shutdownHoldInput
  setGateFlow(outputGate, 0)
  if not state.shutdownIssued then
    stopReactor()
    state.shutdownIssued = true
  end
  state.message = fuelTriggered and "Fuel low: controlled shutdown" or "Controlled shutdown"
end

local function stopAllIdle()
  state.mode = "IDLE"
  state.startupActive = false
  state.autoFuelShutdown = false
  state.shutdownIssued = false
  state.desiredInput = 0
  state.desiredOutput = 0
  setGateFlow(outputGate, 0)
  setGateFlow(inputGate, 0)
  state.message = "Idle"
end

-----------------------------
-- CONTROL LOGIC
-----------------------------

local function controlStartup(info, now)
  setGateFlow(outputGate, 0)
  setGateFlow(inputGate, CFG.startupInputRate)

  if not isOnline(info) then
    chargeReactor()

    if canActivate(info) and isChargedForStartup(info) then
      activateReactor()
      state.startupActivatedAt = now
      state.message = "Activated; holding startup injection"
    else
      state.message = "Charging for activation"
    end
    return
  end

  if not state.startupActivatedAt then
    state.startupActivatedAt = now
  end

  if (now - state.startupActivatedAt) < CFG.startupHoldTime then
    state.message = "Startup hold"
    return
  end

  state.mode = "RUN"
  state.startupActive = false
  state.desiredInput = CFG.minInputRate
  state.desiredOutput = CFG.baseOutputRate
  state.message = "Startup complete"
end

local function controlRun(info)
  local fieldPct = getFieldPct(info)
  local satPct = getSatPct(info)
  local temp = getTemp(info)
  local gen = getGeneration(info)
  local drain = getFieldDrain(info)
  local fuel = getFuel(info)

  if CFG.enableFuelShutdown and fuel <= CFG.shutdownFuelAmount then
    beginShutdown(true)
    return
  end

  if fieldPct <= CFG.scramField then
    scram("Field critical")
    return
  end
  if satPct <= CFG.scramSaturation then
    scram("Saturation critical")
    return
  end
  if temp >= CFG.scramTemp then
    scram("Temperature critical")
    return
  end

  local targetField = CFG.targetField
  if temp >= CFG.dangerTemp or satPct < CFG.minSaturation then
    targetField = CFG.highField
  end

  local desiredInput = math.max(CFG.minInputRate, drain * 1.10)

  if fieldPct < targetField then
    local deficit = (targetField - fieldPct) * 2.0
    desiredInput = desiredInput * (CFG.inputResponse + deficit)
  end

  if fieldPct < CFG.minField then
    desiredInput = desiredInput * CFG.emergencyInputMult
  end

  if satPct < CFG.targetSaturation then
    desiredInput = desiredInput * 1.05
  end

  desiredInput = clamp(desiredInput, CFG.minInputRate, CFG.maxInputRate)

  local desiredOutput = state.desiredOutput
  if desiredOutput <= 0 then desiredOutput = CFG.baseOutputRate end

  if satPct > CFG.targetSaturation and fieldPct > CFG.targetField and temp < CFG.hotTemp then
    desiredOutput = desiredOutput * CFG.outputResponse
  end

  if satPct < CFG.targetSaturation then
    desiredOutput = desiredOutput * CFG.lowSatOutputMult
  end

  if fieldPct < CFG.targetField then
    desiredOutput = desiredOutput * CFG.lowFieldOutputMult
  end

  if temp >= CFG.hotTemp then
    desiredOutput = desiredOutput * CFG.hotTempOutputMult
  end

  desiredOutput = clamp(desiredOutput, CFG.minOutputRate, CFG.maxOutputRate)

  if gen > 0 and desiredOutput > gen * 1.25 then
    desiredOutput = gen * 1.25
  end

  state.desiredInput = desiredInput
  state.desiredOutput = desiredOutput

  setGateFlow(inputGate, desiredInput)
  setGateFlow(outputGate, desiredOutput)

  state.message = "Regulating"
end

local function controlShutdown(info)
  local fieldPct = getFieldPct(info)
  local temp = getTemp(info)
  local drain = getFieldDrain(info)

  local desiredInput = math.max(CFG.shutdownHoldInput, drain * 1.15)

  if fieldPct < CFG.shutdownFieldTarget then
    desiredInput = desiredInput * 1.20
  end

  desiredInput = clamp(desiredInput, CFG.minInputRate, CFG.maxInputRate)

  state.desiredInput = desiredInput
  state.desiredOutput = 0

  setGateFlow(outputGate, 0)
  setGateFlow(inputGate, desiredInput)

  if temp <= CFG.shutdownUntilTemp and not isOnline(info) then
    state.message = "Shutdown cooled"
    state.mode = "IDLE"
    state.autoFuelShutdown = false
    state.shutdownIssued = false
    setGateFlow(outputGate, 0)
    setGateFlow(inputGate, 0)
    state.desiredInput = 0
    return
  end

  state.message = state.autoFuelShutdown and "Cooling down (fuel shutdown)" or "Cooling down"
end

local function controlScram(info)
  local drain = getFieldDrain(info)
  local desiredInput = clamp(math.max(CFG.maxInputRate, drain * 1.25), CFG.minInputRate, CFG.maxInputRate)
  state.desiredInput = desiredInput
  state.desiredOutput = 0
  setGateFlow(outputGate, 0)
  setGateFlow(inputGate, desiredInput)

  if not isOnline(info) and getTemp(info) < CFG.shutdownUntilTemp then
    state.mode = "IDLE"
    state.message = "Recovered from scram to idle"
    setGateFlow(inputGate, 0)
    state.desiredInput = 0
  end
end

local function updateControl(info, now)
  if not state.enabled then
    setGateFlow(outputGate, 0)
    setGateFlow(inputGate, 0)
    return
  end

  if state.mode == "STARTUP" then
    controlStartup(info, now)
  elseif state.mode == "RUN" then
    controlRun(info)
  elseif state.mode == "SHUTDOWN" then
    controlShutdown(info)
  elseif state.mode == "SCRAM" then
    controlScram(info)
  else
    setGateFlow(outputGate, 0)
    setGateFlow(inputGate, 0)
    state.desiredInput = 0
    state.desiredOutput = 0
  end
end

-----------------------------
-- UI
-----------------------------

local function bar(width, pct)
  pct = clamp(pct or 0, 0, 1)
  local fill = math.floor(width * pct + 0.5)
  return string.rep("=", fill) .. string.rep("-", width - fill)
end

local function pickColor(val, warnAt, badAt, invert)
  if invert then
    if val <= badAt then return CFG.colors.good end
    if val <= warnAt then return CFG.colors.warn end
    return CFG.colors.bad
  else
    if val >= badAt then return CFG.colors.good end
    if val >= warnAt then return CFG.colors.warn end
    return CFG.colors.bad
  end
end

local function drawText(x, y, text, fg, bg)
  if y < 1 or y > MON_H then return end
  text = tostring(text or "")
  if #text > MON_W - x + 1 then
    text = text:sub(1, MON_W - x + 1)
  end

  local old = lastFrame[y] or ""
  local padded = text
  local visibleLen = #padded

  if x == 1 then
    padded = padded .. string.rep(" ", math.max(0, MON_W - #padded))
    visibleLen = #padded
  end

  local same = true
  if #old < x + visibleLen - 1 then
    same = false
  else
    if old:sub(x, x + visibleLen - 1) ~= padded then
      same = false
    end
  end

  if not same then
    mon.setCursorPos(x, y)
    if bg then mon.setBackgroundColor(bg) else mon.setBackgroundColor(CFG.colors.bg) end
    if fg then mon.setTextColor(fg) else mon.setTextColor(CFG.colors.fg) end
    mon.write(padded)

    if #old < MON_W then
      old = old .. string.rep(" ", MON_W - #old)
    end
    local prefix = old:sub(1, x - 1)
    local suffix = old:sub(x + visibleLen)
    lastFrame[y] = (prefix .. padded .. suffix):sub(1, MON_W)
  end
end

local function clearLine(y)
  drawText(1, y, "", CFG.colors.fg, CFG.colors.bg)
end

local function drawButton(x1, y1, x2, y2, label, active)
  local bg = active and CFG.colors.accent or CFG.colors.button
  for y = y1, y2 do
    mon.setCursorPos(x1, y)
    mon.setBackgroundColor(bg)
    mon.setTextColor(CFG.colors.buttonText)
    mon.write(string.rep(" ", x2 - x1 + 1))
    lastFrame[y] = nil
  end
  local cx = x1 + math.floor(((x2 - x1 + 1) - #label) / 2)
  local cy = math.floor((y1 + y2) / 2)
  mon.setCursorPos(cx, cy)
  mon.setBackgroundColor(bg)
  mon.setTextColor(CFG.colors.buttonText)
  mon.write(label)
  lastFrame[cy] = nil
end

local function render(info, now)
  if now - state.lastUI < CFG.uiRefresh then return end
  state.lastUI = now

  local fieldPct = getFieldPct(info)
  local satPct   = getSatPct(info)
  local temp     = getTemp(info)
  local gen      = getGeneration(info)
  local drain    = getFieldDrain(info)
  local fuel     = getFuel(info)
  local status   = tostring(getStatus(info))
  local phase    = phaseLabel(info)

  drawText(1, 1, CFG.title, CFG.colors.accent)
  drawText(1, 2, string.rep("-", MON_W), CFG.colors.dim)
  drawText(1, 3, "Phase: " .. phase, CFG.colors.info)
  drawText(1, 4, "Reactor: " .. status, CFG.colors.dim)

  drawText(1, 6, string.format("Field  %s", fmtPct(fieldPct)), pickColor(fieldPct, CFG.minField, CFG.targetField, false))
  drawText(1, 7, "[" .. bar(math.max(10, MON_W - 2), fieldPct) .. "]", pickColor(fieldPct, CFG.minField, CFG.targetField, false))

  drawText(1, 9, string.format("Sat    %s", fmtPct(satPct)), pickColor(satPct, CFG.minSaturation, CFG.targetSaturation, false))
  drawText(1,10, "[" .. bar(math.max(10, MON_W - 2), satPct) .. "]", pickColor(satPct, CFG.minSaturation, CFG.targetSaturation, false))

  drawText(1,12, string.format("Temp   %s C", fmtInt(temp)), pickColor(temp, CFG.hotTemp, CFG.warmTemp, true))
  drawText(1,13, "Gen    " .. fmtInt(gen) .. " RF/t", CFG.colors.good)
  drawText(1,14, "Drain  " .. fmtInt(drain) .. " RF/t", CFG.colors.warn)
  drawText(1,15, "In     " .. fmtInt(state.desiredInput) .. " RF/t", CFG.colors.info)
  drawText(1,16, "Out    " .. fmtInt(state.desiredOutput) .. " RF/t", CFG.colors.info)
  drawText(1,17, "Fuel   " .. string.format("%.2f", fuel), fuel <= CFG.shutdownFuelAmount and CFG.colors.warn or CFG.colors.fg)

  clearLine(18)
  drawText(1,18, state.message, CFG.colors.dim)

  local btnY1 = MON_H - 3
  local btnY2 = MON_H
  local third = math.floor(MON_W / 3)

  drawButton(1, btnY1, third, btnY2, "START", state.mode == "STARTUP" or state.mode == "RUN")
  drawButton(third + 1, btnY1, third * 2, btnY2, "STOP", state.mode == "SHUTDOWN")
  drawButton(third * 2 + 1, btnY1, MON_W, btnY2, "SCRAM", state.mode == "SCRAM")
end

-----------------------------
-- TOUCH HANDLING
-----------------------------

local function handleTouch(x, y, now)
  if now - state.lastTouch < CFG.buttonDebounce then return end
  state.lastTouch = now

  local btnY1 = MON_H - 3
  local btnY2 = MON_H
  if y < btnY1 or y > btnY2 then return end

  local third = math.floor(MON_W / 3)

  if x >= 1 and x <= third then
    beginStartup()
    return
  end

  if x >= third + 1 and x <= third * 2 then
    beginShutdown(false)
    return
  end

  if x >= third * 2 + 1 and x <= MON_W then
    scram("Manual")
    return
  end
end

-----------------------------
-- MAIN
-----------------------------

local function ensureInitialGateState()
  setGateFlow(outputGate, 0)
  setGateFlow(inputGate, 0)
end

ensureInitialGateState()

while true do
  local now = os.clock()
  local info = getInfo()

  if info then
    updateControl(info, now)
    render(info, now)
  else
    state.message = "Failed to read reactor info"
    drawText(1, 1, CFG.title, CFG.colors.accent)
    drawText(1, 3, "No reactor data", CFG.colors.bad)
  end

  local event = { os.pullEventTimeout(CFG.tick) }
  if #event > 0 then
    if event[1] == "monitor_touch" then
      local side, x, y = event[2], event[3], event[4]
      if side == peripheral.getName(mon) then
        handleTouch(x, y, os.clock())
      end
    elseif event[1] == "term_resize" then
      MON_W, MON_H = mon.getSize()
      lastFrame = {}
      mon.setBackgroundColor(CFG.colors.bg)
      mon.clear()
    end
  end
end
