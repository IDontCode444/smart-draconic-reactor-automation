--========================================================--
-- CONTROL ACTIONS
--========================================================--

local function scram(reason)
  state.emergencyLatch = true
  state.safeStopLatch = true
  state.scramReason = reason or "SCRAM"
  state.mode = "scram"
  state.readyToActivate = false
  state.activateRequested = false
  state.chargeRequested = false
  state.startupSince = nil
  state.primeUntil = nil

  pcall(function() reactor.stopReactor() end)
  gateSet(gateOut, 0)
  holdInputSafe(lastInfo, math.max(CONFIG.targetField, 50), CONFIG.startupInputFloor, 1.20)
  state.lastOutput = 0

  setStatus("SCRAM: " .. tostring(state.scramReason), colors.red)
end

local function safeShutdown(reason)
  state.safeStopLatch = true
  state.readyToActivate = false
  state.activateRequested = false
  state.startupSince = nil
  state.primeUntil = nil

  pcall(function() reactor.stopReactor() end)
  gateSet(gateOut, 0)
  holdInputSafe(lastInfo, math.max(CONFIG.targetField, 50), CONFIG.cooldownInputFloor, 1.08)
  state.lastOutput = 0
  state.mode = "stopping"

  setStatus(reason or "Safe shutdown", colors.orange)
end

local function processOperatorRequests(info)
  if state.chargeRequested then
    state.chargeRequested = false
    state.activateRequested = false
    state.readyToActivate = false
    state.startupSince = nil
    state.primeUntil = nil
    state.mode = "charging"
    resetPIDs()

    pcall(function() reactor.chargeReactor() end)
    gateSet(gateOut, 0)
    holdInputSafe(info, 55, CONFIG.minChargeRate, 1.25)
    state.lastOutput = 0
    setStatus("Charging reactor", colors.yellow)
  end

  if state.activateRequested then
    state.activateRequested = false

    if state.lowFuelLatch then
      setStatus("Blocked: low fuel latch active", colors.red)
      return
    end

    if not info or not chargeReady(info) then
      state.readyToActivate = false
      setStatus("Not ready: charge to 2000C / 50% field / 50% sat", colors.orange)
      return
    end

    -- Prime injector BEFORE activate. This is the main fix.
    gateSet(gateOut, 0)
    holdInputSafe(info, 55, CONFIG.activatePrimeInputFloor, CONFIG.activatePrimeMultiplier)
    state.lastOutput = 0
    state.mode = "priming"
    state.primeUntil = os.clock() + CONFIG.activatePrimeSeconds
    setStatus("Priming injector before activation", colors.yellow)
  end
end

--========================================================--
-- SAFETY / CONTROL
--========================================================--

local function emergencyCheck(info)
  if not info then
    scram("Lost reactor data")
    return true
  end

  if isHardFailStatus(info.status) then
    scram("Reactor entered " .. tostring(info.status))
    return true
  end

  local fp = fieldPct(info)
  local sp = saturationPct(info)
  local fup = fuelPct(info)
  local temp = info.temperature or 0

  if fup <= CONFIG.fuelCritical and (isRunningStatus(info.status) or isWarmupStatus(info.status)) then
    state.lowFuelLatch = true
    scram("Critical fuel low")
    return true
  end

  if fup <= CONFIG.fuelSafeShutdown and isRunningStatus(info.status) then
    state.lowFuelLatch = true
    safeShutdown("Fuel low safe shutdown")
    return true
  end

  if temp >= CONFIG.tempEmergency then
    scram("Temperature emergency")
    return true
  end

  if fp <= CONFIG.fieldEmergency and isRunningStatus(info.status) then
    scram("Field emergency")
    return true
  end

  if sp <= CONFIG.saturationEmergency and isRunningStatus(info.status) then
    scram("Saturation emergency")
    return true
  end

  return false
end

local function applyChargingControl(info)
  gateSet(gateOut, 0)
  holdInputSafe(info, 55, CONFIG.minChargeRate, 1.25)
  state.lastOutput = 0

  if chargeReady(info) then
    state.readyToActivate = true
    state.mode = "ready"
    setStatus("READY - press Activate", colors.lime)
  else
    state.readyToActivate = false
    state.mode = "charging"
    setStatus("Charging / warming up", colors.yellow)
  end
end

local function applyCoolingControl(info)
  gateSet(gateOut, 0)
  holdInputSafe(info, math.max(CONFIG.targetField, 50), CONFIG.cooldownInputFloor, 1.05)
  state.lastOutput = 0

  if state.safeStopLatch then
    setStatus("Safe shutdown in progress", colors.orange)
  else
    setStatus("Cooling reactor", colors.orange)
  end
end

local function computeRunInput(info, dt)
  local fp = fieldPct(info)
  local temp = info.temperature or 0

  local baseIn = computeBaseInput(info, CONFIG.targetField)
  local minSafeIn = baseIn * CONFIG.inputBaseFloorFactor

  local inFieldTrim = pidUpdate(pidInField, CONFIG.targetField - fp, dt)
  local inTempTrim  = pidUpdate(pidInTemp, temp - CONFIG.targetTemp, dt)

  local wantIn = baseIn + inFieldTrim + inTempTrim
  wantIn = clamp(math.max(wantIn, minSafeIn), 0, CONFIG.maxInput)

  return wantIn, baseIn
end

local function applyPrimingControl(info)
  gateSet(gateOut, 0)
  holdInputSafe(info, 55, CONFIG.activatePrimeInputFloor, CONFIG.activatePrimeMultiplier)
  state.lastOutput = 0

  if os.clock() >= (state.primeUntil or 0) then
    pcall(function() reactor.activateReactor() end)
    state.primeUntil = nil
    state.startupSince = os.clock()
    state.mode = "startup"
    setStatus("Activated - startup hold engaged", colors.lime)
  else
    setStatus("Priming injector before activation", colors.yellow)
  end
end

local function applyStartupControl(info)
  local fp = fieldPct(info)
  local sp = saturationPct(info)
  local temp = info.temperature or 0
  local elapsed = os.clock() - (state.startupSince or os.clock())

  gateSet(gateOut, CONFIG.startupOutputCap)
  state.lastOutput = CONFIG.startupOutputCap

  local startupBase = computeBaseInput(info, 55)
  local wantIn = math.max(
    startupBase * CONFIG.startupInputMultiplier,
    CONFIG.startupInputFloor
  )

  if fp < CONFIG.startupRecoverField or sp < CONFIG.startupRecoverSat then
    wantIn = math.max(wantIn, CONFIG.startupInputFloor * 1.15)
  end

  wantIn = clamp(wantIn, 0, CONFIG.maxInput)
  gateSet(gateIn, wantIn)
  state.lastInput = wantIn

  local startupDone =
    elapsed >= CONFIG.startupHoldSeconds
    and temp >= CONFIG.startupExitTemp
    and fp >= CONFIG.startupExitField
    and sp >= CONFIG.startupExitSaturation
    and isRunningStatus(info.status)

  if startupDone then
    state.mode = "run"
    resetPIDs()
    setStatus("Startup complete - run mode", colors.lime)
  else
    state.mode = "startup"
    setStatus(
      ("Startup %.1fs  T:%d  F:%.1f%%  S:%.1f%%  In:%s"):format(
        elapsed, temp, fp, sp, fmtInt(wantIn)
      ),
      colors.yellow
    )
  end
end

local function applyRunControl(info, dt)
  local fp = fieldPct(info)
  local sp = saturationPct(info)
  local fup = fuelPct(info)
  local temp = info.temperature or 0
  local gen = info.generationRate or 0

  local wantIn, baseIn = computeRunInput(info, dt)

  local outSatTrim  = pidUpdate(pidOutSat, sp - CONFIG.targetSaturation, dt)
  local outTempTrim = pidUpdate(pidOutTemp, CONFIG.targetTemp - temp, dt)

  local rawOutTarget = state.lastOutput + outSatTrim + outTempTrim

  local dynamicOutMax = math.max(gen * 0.75, 25000)
  dynamicOutMax = clamp(dynamicOutMax, 0, CONFIG.maxOutput)

  if sp < CONFIG.targetSaturation - 5 then
    rawOutTarget = math.min(rawOutTarget, gen * 0.45)
  end
  if temp > CONFIG.targetTemp - 75 then
    rawOutTarget = math.min(rawOutTarget, gen * 0.40)
  end
  if fp < CONFIG.targetField - 3 then
    rawOutTarget = math.min(rawOutTarget, gen * 0.35)
    wantIn = math.max(wantIn, baseIn * 1.20)
  end
  if sp < CONFIG.targetSaturation - 10 or fp < CONFIG.targetField - 6 then
    rawOutTarget = 0
    wantIn = math.max(wantIn, baseIn * 1.30)
  end

  rawOutTarget = clamp(rawOutTarget, 0, dynamicOutMax)
  local wantOut = slew(state.lastOutput, rawOutTarget, CONFIG.outputRampUp, CONFIG.outputRampDown)

  gateSet(gateIn, clamp(wantIn, 0, CONFIG.maxInput))
  gateSet(gateOut, clamp(wantOut, 0, CONFIG.maxOutput))

  state.lastInput = wantIn
  state.lastOutput = wantOut
  state.mode = "run"
  state.safeStopLatch = false
  state.emergencyLatch = false
  state.scramReason = nil

  setStatus(
    ("Run | T:%d F:%.1f%% S:%.1f%% Fuel:%.1f%%"):format(temp, fp, sp, fup),
    colors.lime
  )
end

local function applyControl(info, dt)
  processOperatorRequests(info)

  if emergencyCheck(info) then
    return
  end

  local status = info.status
  local fup = fuelPct(info)

  if state.lowFuelLatch and fup > (CONFIG.fuelSafeShutdown + 5) and (status == "cold" or status == "cooling") then
    state.lowFuelLatch = false
    setStatus("Fuel latch cleared", colors.lime)
  end

  if not state.autoEnabled then
    setStatus("Auto paused", colors.orange)
    return
  end

  if state.mode == "priming" then
    applyPrimingControl(info)
    return
  end

  if status == "cold" then
    gateSet(gateIn, 0)
    gateSet(gateOut, 0)
    state.lastInput = 0
    state.lastOutput = 0
    state.readyToActivate = false
    state.startupSince = nil
    state.primeUntil = nil
    state.mode = "idle"

    if state.safeStopLatch then
      setStatus("Reactor offline (safe stop)", colors.orange)
    else
      setStatus("Reactor offline", colors.lightGray)
    end
    return
  end

  if isWarmupStatus(status) then
    applyChargingControl(info)
    return
  end

  if status == "stopping" or status == "cooling" then
    state.readyToActivate = false
    state.mode = (status == "stopping") and "stopping" or "cooling"
    applyCoolingControl(info)
    return
  end

  if isRunningStatus(status) then
    if state.mode == "startup" or state.startupSince ~= nil then
      applyStartupControl(info)
      return
    end

    applyRunControl(info, dt)
    return
  end

  state.readyToActivate = false
  state.mode = "idle"
  setStatus("Unhandled status: " .. tostring(status), colors.orange)
end

--========================================================--
-- LOOPS
--========================================================--

local function controlLoop()
  resetPIDs()

  while running do
    local now = os.clock()
    local dt = now - state.lastLoopTime
    if dt <= 0 then dt = CONFIG.controlRate end
    state.lastLoopTime = now

    local info = getInfo()
    lastInfo = info

    if not info then
      setStatus("No reactor info", colors.red)
      gateSet(gateOut, 0)
    else
      applyControl(info, dt)
    end

    sleep(CONFIG.controlRate)
  end
end

local function uiLoop()
  redraw(true)
  while running do
    redraw(false)
    sleep(CONFIG.uiRate)
  end
end

local function eventLoop()
  while running do
    local e = { os.pullEvent() }

    if e[1] == "monitor_touch" then
      handleTouch(e[2], e[3], e[4])
    elseif e[1] == "monitor_resize" then
      pcall(monitor.setTextScale, CONFIG.monitorScale)
      monW, monH = monitor.getSize()
      redraw(true)
    elseif e[1] == "terminate" then
      running = false
      gateSet(gateOut, 0)
      error("Terminated")
    end
  end
end

