--========================================================--
--  CONTROL ACTIONS
--========================================================--

local function holdFieldFeed(info, multiplier)
  multiplier = multiplier or 1.0
  local tf = clamp((CONFIG.targetField / 100), 0.05, 0.95)
  local baseIn = 0
  if info then
    baseIn = (info.fieldDrainRate or 0) / math.max(0.05, (1 - tf))
  end
  local wantIn = math.max(baseIn * multiplier, CONFIG.minChargeRate)
  gateSet(gateIn, wantIn)
  state.lastInput = wantIn
end

local function scram(reason)
  state.emergencyLatch = true
  state.safeStopLatch = true
  state.scramReason = reason or "SCRAM"
  state.mode = "scram"
  state.readyToActivate = false
  state.activationArmed = false
  state.activateRequested = false
  state.chargeRequested = false

  pcall(function() reactor.stopReactor() end)
  gateSet(gateOut, 0)
  holdFieldFeed(lastInfo, 1.15)

  state.lastOutput = 0
  setStatus("SCRAM: " .. tostring(state.scramReason), colors.red)
end

local function safeShutdown(reason)
  state.safeStopLatch = true
  state.readyToActivate = false
  state.activationArmed = false
  state.activateRequested = false

  pcall(function() reactor.stopReactor() end)
  gateSet(gateOut, 0)
  holdFieldFeed(lastInfo, 1.08)

  state.mode = "stopping"
  state.lastOutput = 0
  setStatus(reason or "Safe shutdown", colors.orange)
end

local function processOperatorRequests(info)
  if state.chargeRequested then
    state.chargeRequested = false
    state.activateRequested = false
    state.readyToActivate = false
    state.activationArmed = false
    state.spinupStart = nil
    resetPIDs()

    pcall(function() reactor.chargeReactor() end)
    gateSet(gateOut, 0)
    holdFieldFeed(info, 1.25)
    state.mode = "charging"
    setStatus("Charging reactor", colors.yellow)
  end

  if state.activateRequested then
    state.activateRequested = false

    if state.lowFuelLatch then
      setStatus("Blocked: low fuel latch active", colors.red)
      return
    end

    if not state.readyToActivate then
      setStatus("Reactor not ready; press Charge and wait for READY", colors.orange)
      return
    end

    pcall(function() reactor.activateReactor() end)
    resetPIDs()
    state.activationArmed = true
    state.readyToActivate = false
    state.spinupStart = os.clock()
    state.mode = "spinup"
    gateSet(gateOut, 0)
    holdFieldFeed(info, 1.20)
    state.lastOutput = 0
    setStatus("Activated - spinup mode", colors.lime)
  end
end

--========================================================--
--  SAFETY / CONTROL
--========================================================--

local function emergencyCheck(info)
  if not info then
    scram("Lost reactor data")
    return true
  end

  local fp = fieldPct(info)
  local sp = saturationPct(info)
  local fup = fuelPct(info)
  local temp = info.temperature or 0

  if fup <= CONFIG.fuelCritical and (isRunningStatus(info.status) or isWarmupStatus(info.status)) then
    state.lowFuelLatch = true
    scram("Critical fuel low")
    return true
  end

  if fup <= CONFIG.fuelSafeShutdown and isRunningStatus(info.status) then
    state.lowFuelLatch = true
    safeShutdown("Fuel low safe shutdown")
    return true
  end

  if temp >= CONFIG.tempEmergency then
    scram("Temperature emergency")
    return true
  end

  if fp <= CONFIG.fieldEmergency and isRunningStatus(info.status) then
    scram("Field emergency")
    return true
  end

  if sp <= CONFIG.saturationEmergency and isRunningStatus(info.status) then
    scram("Saturation emergency")
    return true
  end

  return false
end

local function applyChargingControl(info)
  gateSet(gateOut, 0)
  holdFieldFeed(info, 1.25)

  if chargeReady(info) then
    state.readyToActivate = true
    state.mode = "ready"
    setStatus("READY - press Activate", colors.lime)
  else
    state.readyToActivate = false
    state.mode = "charging"
    setStatus("Charging / warming up", colors.yellow)
  end
end

local function applyCoolingControl(info)
  gateSet(gateOut, 0)
  holdFieldFeed(info, 1.05)
  state.lastOutput = 0

  if state.safeStopLatch then
    setStatus("Safe shutdown in progress", colors.orange)
  else
    setStatus("Cooling reactor", colors.orange)
  end
end

local function computeInputTarget(info, targetFieldValue, targetTempValue, dt)
  local fp = fieldPct(info)
  local temp = info.temperature or 0

  local tf = clamp(targetFieldValue / 100, 0.05, 0.95)
  local baseIn = (info.fieldDrainRate or 0) / math.max(0.05, (1 - tf))
  local minSafeIn = baseIn * CONFIG.inputBaseFloorFactor

  local inFieldTrim = pidUpdate(pidInField, targetFieldValue - fp, dt)
  local inTempTrim  = pidUpdate(pidInTemp, temp - targetTempValue, dt)

  local wantIn = baseIn + inFieldTrim + inTempTrim
  wantIn = clamp(wantIn, minSafeIn, CONFIG.maxInput)
  return wantIn, baseIn
end

local function applySpinupControl(info, dt)
  local temp = info.temperature or 0
  local fp = fieldPct(info)
  local sp = saturationPct(info)

  local wantIn = computeInputTarget(info, CONFIG.spinupTargetField, CONFIG.targetTemp, dt)
  gateSet(gateIn, wantIn)
  state.lastInput = wantIn

  local outTarget = 0

  -- only begin output ramp once the reactor is actually up and moving
  if temp >= 5000 and fp >= 45 and sp >= 70 then
    local gen = info.generationRate or 0
    outTarget = math.min(CONFIG.spinupOutputCap, gen * 0.25)
  end

  local newOut = slew(state.lastOutput, outTarget, CONFIG.spinupRampRate, CONFIG.outputDownRampRate)
  gateSet(gateOut, clamp(newOut, 0, CONFIG.maxOutput))
  state.lastOutput = newOut

  local elapsed = os.clock() - (state.spinupStart or os.clock())
  local spinupDone = elapsed >= CONFIG.spinupMinSeconds and temp >= CONFIG.spinupExitTemp and sp >= 65 and fp >= 40

  if spinupDone then
    state.mode = "run"
    resetPIDs()
    setStatus("Spinup complete - run mode", colors.lime)
  else
    state.mode = "spinup"
    setStatus(("Spinup %.1fs  T:%d  F:%.1f%%  S:%.1f%%"):format(elapsed, temp, fp, sp), colors.yellow)
  end
end

local function applyRunControl(info, dt)
  local fp = fieldPct(info)
  local sp = saturationPct(info)
  local fup = fuelPct(info)
  local temp = info.temperature or 0
  local gen = info.generationRate or 0

  local wantIn, baseIn = computeInputTarget(info, CONFIG.targetField, CONFIG.targetTemp, dt)

  local outSatTrim  = pidUpdate(pidOutSat, sp - CONFIG.targetSaturation, dt)
  local outTempTrim = pidUpdate(pidOutTemp, CONFIG.targetTemp - temp, dt)

  local rawOutTarget = state.lastOutput + outSatTrim + outTempTrim

  -- safer dynamic max than previous version
  local dynamicOutMax = math.max(gen * 0.85, 50000)
  dynamicOutMax = clamp(dynamicOutMax, 50000, CONFIG.maxOutput)

  -- softeners
  if sp < CONFIG.targetSaturation - 6 then
    rawOutTarget = math.min(rawOutTarget, gen * 0.60)
  end
  if temp > CONFIG.targetTemp - 50 then
    rawOutTarget = math.min(rawOutTarget, gen * 0.55)
  end
  if fp < CONFIG.targetField - 3 then
    rawOutTarget = math.min(rawOutTarget, gen * 0.50)
    wantIn = math.max(wantIn, baseIn * 1.12)
  end
  if sp < CONFIG.targetSaturation - 12 or fp < CONFIG.targetField - 6 then
    rawOutTarget = 0
    wantIn = math.max(wantIn, baseIn * 1.20)
  end

  rawOutTarget = clamp(rawOutTarget, 0, dynamicOutMax)

  local wantOut = slew(state.lastOutput, rawOutTarget, CONFIG.outputRampRate, CONFIG.outputDownRampRate)
  wantOut = clamp(wantOut, 0, dynamicOutMax)

  gateSet(gateIn, wantIn)
  gateSet(gateOut, wantOut)

  state.lastInput = wantIn
  state.lastOutput = wantOut
  state.mode = "run"
  state.safeStopLatch = false
  state.emergencyLatch = false
  state.scramReason = nil

  setStatus(("Run | T:%d F:%.1f%% S:%.1f%% Fuel:%.1f%%"):format(temp, fp, sp, fup), colors.lime)
end

local function applyControl(info, dt)
  processOperatorRequests(info)

  if emergencyCheck(info) then
    return
  end

  local status = info.status
  local fup = fuelPct(info)

  if state.lowFuelLatch and fup > (CONFIG.fuelSafeShutdown + 5) and (status == "cold" or status == "cooling") then
    state.lowFuelLatch = false
    setStatus("Fuel latch cleared", colors.lime)
  end

  if not state.autoEnabled then
    setStatus("Auto paused", colors.orange)
    return
  end

  if status == "cold" then
    gateSet(gateIn, 0)
    gateSet(gateOut, 0)
    state.lastInput = 0
    state.lastOutput = 0

    if state.readyToActivate then
      state.mode = "ready"
      setStatus("READY - press Activate", colors.lime)
    else
      state.mode = "idle"
      setStatus("Reactor offline", colors.lightGray)
    end
    return
  end

  if isWarmupStatus(status) then
    applyChargingControl(info)
    return
  end

  if status == "stopping" or status == "cooling" then
    state.mode = (status == "stopping") and "stopping" or "cooling"
    applyCoolingControl(info)
    return
  end

  if isRunningStatus(status) then
    if state.activationArmed or state.mode == "spinup" then
      state.activationArmed = false
      applySpinupControl(info, dt)
      return
    end

    applyRunControl(info, dt)
    return
  end

  setStatus("Unhandled status: " .. tostring(status), colors.orange)
end

--========================================================--
--  LOOPS
--========================================================--

local function controlLoop()
  resetPIDs()

  while running do
    local now = os.clock()
    local dt = now - state.lastLoopTime
    if dt <= 0 then dt = CONFIG.controlRate end
    state.lastLoopTime = now

    local info = getInfo()
    lastInfo = info

    if not info then
      setStatus("No reactor info", colors.red)
      gateSet(gateOut, 0)
    else
      applyControl(info, dt)
    end

    sleep(CONFIG.controlRate)
  end
end

local function uiLoop()
  redraw(true)
  while running do
    redraw(false)
    sleep(CONFIG.uiRate)
  end
end

local function eventLoop()
  while running do
    local e = { os.pullEvent() }
    if e[1] == "monitor_touch" then
      handleTouch(e[2], e[3], e[4])
    elseif e[1] == "monitor_resize" then
      pcall(monitor.setTextScale, CONFIG.monitorScale)
      monW, monH = monitor.getSize()
      redraw(true)
    elseif e[1] == "terminate" then
      running = false
      gateSet(gateOut, 0)
      error("Terminated")
    end
  end
end

