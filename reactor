-- reactor.lua
-- ATM10 / CC:Tweaked Draconic Reactor Controller
-- Single-file monitor UI + automatic control + live tuning
--
-- USER SETUP:
local INPUT_GATE_NAME  = "flow_gate_0"
local OUTPUT_GATE_NAME = "flow_gate_1"
local REACTOR_NAME     = "draconic_reactor_0"

-- =========================
-- ====== CONFIG ===========
-- =========================

local cfg = {
  -- Default targets (editable live from tuning page)
  targetTemp         = 7850,   -- C
  targetSaturation   = 0.72,   -- 0.00 - 1.00
  targetField        = 0.56,   -- 0.00 - 1.00

  -- Hard safety limits
  scramFieldMin      = 0.18,
  scramTempMax       = 8200,
  scramSatMin        = 0.10,
  lowFuelThreshold   = 0.08,   -- fraction remaining

  -- Charge/activate behavior
  chargeFieldGoal    = 0.50,
  chargeSatGoal      = 0.50,
  startHoldSeconds   = 12,     -- zero-output hold after activation
  startTempForOutput = 2400,   -- don’t export before this
  startRampPerSec    = 120000, -- RF/t increase limit during startup

  -- Running ramp / smoothing
  outputRampPerSec   = 220000, -- RF/t max change per second
  inputRampPerSec    = 400000, -- RF/t max change per second

  -- Control limits
  minInput           = 0,
  maxInput           = 12000000,
  minOutput          = 0,
  maxOutput          = 12000000,

  -- UI
  uiFps              = 4,
  controlHz          = 8,
  advancedMonitorScale = 0.5,
}

-- =========================
-- ====== HELPERS ==========
-- =========================

local function clamp(x, a, b)
  if x < a then return a end
  if x > b then return b end
  return x
end

local function round(x)
  if x >= 0 then return math.floor(x + 0.5) else return math.ceil(x - 0.5) end
end

local function lerp(a, b, t)
  return a + (b - a) * t
end

local function sign(x)
  if x > 0 then return 1 elseif x < 0 then return -1 else return 0 end
end

local function fmtInt(n)
  n = tonumber(n) or 0
  local neg = n < 0
  n = math.abs(math.floor(n + 0.5))
  local s = tostring(n)
  local out = ""
  while #s > 3 do
    out = "," .. s:sub(-3) .. out
    s = s:sub(1, -4)
  end
  out = s .. out
  if neg then out = "-" .. out end
  return out
end

local function fmtRF(n)
  n = tonumber(n) or 0
  local abs = math.abs(n)
  if abs >= 1000000000 then
    return string.format("%.2fG", n / 1000000000)
  elseif abs >= 1000000 then
    return string.format("%.2fM", n / 1000000)
  elseif abs >= 1000 then
    return string.format("%.1fk", n / 1000)
  else
    return tostring(round(n))
  end
end

local function fmtPct(x)
  x = tonumber(x) or 0
  return string.format("%.1f%%", x * 100)
end

local function now()
  return os.epoch("utc") / 1000
end

local function shallowCopy(t)
  local n = {}
  for k, v in pairs(t) do n[k] = v end
  return n
end

local function listMethods(p)
  local ok, methods = pcall(peripheral.getMethods, peripheral.getName(p))
  if ok and methods then return methods end
  return {}
end

local function hasMethod(p, name)
  if type(p[name]) == "function" then return true end
  local methods = listMethods(p)
  for _, m in ipairs(methods) do
    if m == name then return true end
  end
  return false
end

local function callFirst(obj, names, ...)
  for _, name in ipairs(names) do
    if type(obj[name]) == "function" then
      local ok, a, b, c, d = pcall(obj[name], ...)
      if ok then return true, a, b, c, d end
    end
  end
  return false, nil
end

local function getAny(t, candidates, default)
  if type(t) ~= "table" then return default end
  for _, key in ipairs(candidates) do
    if t[key] ~= nil then return t[key] end
  end
  return default
end

local function setGateFlow(gate, value)
  value = clamp(round(value), 0, cfg.maxInput * 2)
  callFirst(gate, {"setOverrideEnabled"}, true)
  local ok = callFirst(gate, {"setFlowOverride", "setFlow", "setSignalLowFlow", "setTransferRate"}, value)
  return ok
end

local function getGateFlow(gate)
  local ok, v = callFirst(gate, {"getFlow", "getFlowOverride", "getSignalLowFlow", "getTransferRate"})
  if ok and type(v) == "number" then return v end
  return 0
end

-- =========================
-- ==== PERIPHERALS ========
-- =========================

local inputGate = peripheral.wrap(INPUT_GATE_NAME)
local outputGate = peripheral.wrap(OUTPUT_GATE_NAME)
local reactor = peripheral.wrap(REACTOR_NAME)
local monitor = peripheral.find("monitor")

if not inputGate then error("Missing input gate peripheral: " .. INPUT_GATE_NAME) end
if not outputGate then error("Missing output gate peripheral: " .. OUTPUT_GATE_NAME) end
if not reactor then error("Missing reactor peripheral: " .. REACTOR_NAME) end
if not monitor then error("No monitor peripheral detected") end

pcall(monitor.setTextScale, cfg.advancedMonitorScale)
monitor.setBackgroundColor(colors.black)
monitor.setTextColor(colors.white)
monitor.clear()

local MON = monitor
local MW, MH = MON.getSize()

-- =========================
-- ===== REACTOR IO ========
-- =========================

local function readInfo()
  local ok, info = callFirst(reactor, {"getReactorInfo", "info", "getInfo"})
  if not ok or type(info) ~= "table" then
    return {
      valid = false,
      status = "NO DATA",
      temperature = 0,
      fieldStrength = 0,
      maxFieldStrength = 1,
      energySaturation = 0,
      maxEnergySaturation = 1,
      generationRate = 0,
      fuelConversion = 0,
      maxFuelConversion = 1,
      fuelRemainingFrac = 1,
      raw = {},
    }
  end

  local temp = tonumber(getAny(info, {"temperature", "temp"}, 0)) or 0
  local fieldNow = tonumber(getAny(info, {"fieldStrength", "shieldCharge", "fieldCharge"}, 0)) or 0
  local fieldMax = tonumber(getAny(info, {"maxFieldStrength", "maxShieldCharge", "maxFieldCharge"}, 1)) or 1
  local satNow = tonumber(getAny(info, {"energySaturation", "saturation"}, 0)) or 0
  local satMax = tonumber(getAny(info, {"maxEnergySaturation", "maxSaturation"}, 1)) or 1
  local gen = tonumber(getAny(info, {"generationRate", "genRate", "outputGenerationRate"}, 0)) or 0

  local fuelConv = tonumber(getAny(info, {"fuelConversion", "convertedFuel"}, 0)) or 0
  local maxFuelConv = tonumber(getAny(info, {"maxFuelConversion", "maxConvertedFuel"}, 1)) or 1

  local fuel = tonumber(getAny(info, {"fuel", "reactableFuel", "fuelAmount"}, 0)) or 0
  local chaos = tonumber(getAny(info, {"chaos", "convertedFuel"}, 0)) or 0
  local totalFuel = fuel + chaos
  local fuelRemainingFrac

  if totalFuel > 0 then
    fuelRemainingFrac = fuel / totalFuel
  else
    fuelRemainingFrac = 1 - clamp(fuelConv / math.max(maxFuelConv, 1), 0, 1)
  end

  local status = tostring(getAny(info, {"status", "reactorState"}, "UNKNOWN"))

  return {
    valid = true,
    status = status,
    temperature = temp,
    fieldStrength = fieldNow,
    maxFieldStrength = math.max(fieldMax, 1),
    fieldFrac = clamp(fieldNow / math.max(fieldMax, 1), 0, 1),
    energySaturation = satNow,
    maxEnergySaturation = math.max(satMax, 1),
    satFrac = clamp(satNow / math.max(satMax, 1), 0, 1),
    generationRate = gen,
    fuelConversion = fuelConv,
    maxFuelConversion = math.max(maxFuelConv, 1),
    conversionFrac = clamp(fuelConv / math.max(maxFuelConv, 1), 0, 1),
    fuelRemainingFrac = clamp(fuelRemainingFrac, 0, 1),
    raw = info,
  }
end

local function reactorCharge()
  local ok = callFirst(reactor, {"chargeReactor", "charge"})
  return ok
end

local function reactorActivate()
  local ok = callFirst(reactor, {"activateReactor", "activate"})
  return ok
end

local function reactorScram()
  local ok = callFirst(reactor, {"stopReactor", "shutdownReactor", "scram", "deactivateReactor", "stop"})
  return ok
end

-- =========================
-- ====== STATE ============
-- =========================

local state = {
  page = "main", -- main / tuning
  mode = "IDLE", -- IDLE / CHARGING / STARTING / RUNNING / SCRAMMED / LOW_FUEL / FAULT
  lastInfo = readInfo(),
  inputSet = 0,
  outputSet = 0,
  startupAt = nil,
  statusMsg = "Ready",
  tuneIndex = 1,
  lastUiHash = "",
  buttons = {},
  needsFullRedraw = true,
}

local function setMode(mode, msg)
  state.mode = mode
  if msg then state.statusMsg = msg end
end

local function ramp(current, target, maxPerSec, dt)
  local maxStep = math.max(0, maxPerSec * dt)
  if target > current then
    return math.min(current + maxStep, target)
  else
    return math.max(current - maxStep, target)
  end
end

local function pushFlows(dt)
  state.inputSet = clamp(state.inputSet, cfg.minInput, cfg.maxInput)
  state.outputSet = clamp(state.outputSet, cfg.minOutput, cfg.maxOutput)
  setGateFlow(inputGate, state.inputSet)
  setGateFlow(outputGate, state.outputSet)
end

local function hardZeroOutput()
  state.outputSet = 0
  setGateFlow(outputGate, 0)
end

local function hardSetInput(v)
  state.inputSet = clamp(v, cfg.minInput, cfg.maxInput)
  setGateFlow(inputGate, state.inputSet)
end

local function engageCharge()
  hardZeroOutput()
  hardSetInput(cfg.maxInput)
  reactorCharge()
  setMode("CHARGING", "Charging reactor")
end

local function engageActivate()
  reactorActivate()
  state.startupAt = now()
  state.outputSet = 0
  state.inputSet = cfg.maxInput
  pushFlows(0)
  setMode("STARTING", "Activation sequence started")
end

local function engageScram(msg)
  reactorScram()
  hardZeroOutput()
  hardSetInput(cfg.maxInput)
  setMode("SCRAMMED", msg or "SCRAM engaged")
end

-- =========================
-- ===== CONTROLLER ========
-- =========================

local ctrl = {
  -- simple PI accumulators
  inI = 0,
  outI = 0,
}

local function safetyCheck(info)
  if info.fuelRemainingFrac <= cfg.lowFuelThreshold then
    engageScram("Auto shutdown: low fuel")
    setMode("LOW_FUEL", "Auto shutdown: low fuel")
    return false
  end

  if info.fieldFrac <= cfg.scramFieldMin then
    engageScram("Emergency shutdown: field too low")
    return false
  end

  if info.temperature >= cfg.scramTempMax then
    engageScram("Emergency shutdown: temp too high")
    return false
  end

  if state.mode == "RUNNING" and info.satFrac <= cfg.scramSatMin then
    engageScram("Emergency shutdown: saturation too low")
    return false
  end

  return true
end

local function chargeControl(info, dt)
  -- Keep input high, output zero until reactor is ready to activate.
  state.outputSet = 0

  local fieldErr = cfg.chargeFieldGoal - info.fieldFrac
  local satErr = cfg.chargeSatGoal - info.satFrac

  local wantedInput = cfg.maxInput
  if fieldErr < 0.01 and satErr < 0.01 then
    wantedInput = math.min(cfg.maxInput, math.max(2000000, info.generationRate + 1000000))
    state.statusMsg = "Charge ready"
  else
    state.statusMsg = "Charging to 50/50"
  end

  state.inputSet = ramp(state.inputSet, wantedInput, cfg.inputRampPerSec, dt)
end

local function startupControl(info, dt)
  -- Activation phase:
  -- 1) output must stay at zero initially
  -- 2) input stays very high
  -- 3) only after safe warm-up do we ramp output up gradually
  local elapsed = (state.startupAt and (now() - state.startupAt)) or 0

  local fieldErr = cfg.targetField - info.fieldFrac
  local tempErr = cfg.targetTemp - info.temperature

  local inputBase = 7000000
  local inputBoost = clamp(fieldErr * 18000000 + tempErr * 1800, 0, 5000000)
  local wantedInput = clamp(inputBase + inputBoost, cfg.minInput, cfg.maxInput)

  state.inputSet = ramp(state.inputSet, wantedInput, cfg.inputRampPerSec, dt)

  local allowOutput = elapsed >= cfg.startHoldSeconds
    and info.temperature >= cfg.startTempForOutput
    and info.fieldFrac >= math.max(cfg.targetField - 0.04, 0.45)
    and info.satFrac >= math.max(cfg.targetSaturation - 0.05, 0.45)

  if not allowOutput then
    state.outputSet = 0
    state.statusMsg = string.format("Starting... hold %.0fs", math.max(0, cfg.startHoldSeconds - elapsed))
    return
  end

  local satHeadroom = clamp(info.satFrac - cfg.targetSaturation, -0.2, 0.3)
  local fieldHeadroom = clamp(info.fieldFrac - cfg.targetField, -0.2, 0.3)
  local tempHeadroom = clamp((cfg.targetTemp - info.temperature) / 2000, -0.5, 0.5)

  local stableFactor = clamp(0.45 + satHeadroom * 1.2 + fieldHeadroom * 0.8 + tempHeadroom * 0.25, 0, 1)
  local wantedOutput = clamp(info.generationRate * stableFactor, 0, cfg.maxOutput)

  state.outputSet = ramp(state.outputSet, wantedOutput, cfg.startRampPerSec, dt)

  if elapsed >= cfg.startHoldSeconds + 10 and info.fieldFrac >= 0.45 then
    setMode("RUNNING", "Online")
  else
    state.statusMsg = "Ramping output safely"
  end
end

local function runningControl(info, dt)
  -- Dual-ish smooth control:
  -- input prioritizes field + temperature support
  -- output targets saturation/temp without sudden jumps

  local fieldErr = cfg.targetField - info.fieldFrac
  local tempErr = cfg.targetTemp - info.temperature
  local satErr  = info.satFrac - cfg.targetSaturation

  -- INPUT PI: defend field, then help temp
  ctrl.inI = clamp(ctrl.inI + (fieldErr * 350000 + tempErr * 20) * dt, -2500000, 2500000)
  local wantedInput = (
    info.generationRate
    + fieldErr * 14000000
    + tempErr * 1400
    + ctrl.inI
    + 1200000
  )
  wantedInput = clamp(wantedInput, cfg.minInput, cfg.maxInput)

  -- OUTPUT PI: bleed saturation toward target while respecting field/temp
  local fieldPenalty = clamp((cfg.targetField - info.fieldFrac) * 18000000, 0, 6000000)
  local tempPenalty = clamp((info.temperature - cfg.targetTemp) * 900, 0, 5000000)

  ctrl.outI = clamp(ctrl.outI + (satErr * 2200000) * dt, -3000000, 3000000)
  local wantedOutput = (
    info.generationRate
    + satErr * 9000000
    + ctrl.outI
    - fieldPenalty
    - tempPenalty
  )

  -- Protective soft clamps
  if info.fieldFrac < cfg.targetField - 0.03 then
    wantedOutput = math.min(wantedOutput, info.generationRate * 0.65)
  end
  if info.satFrac < cfg.targetSaturation - 0.03 then
    wantedOutput = math.min(wantedOutput, info.generationRate * 0.50)
  end
  if info.temperature > cfg.targetTemp + 150 then
    wantedOutput = math.min(wantedOutput, info.generationRate * 0.45)
  end

  wantedOutput = clamp(wantedOutput, cfg.minOutput, cfg.maxOutput)

  state.inputSet  = ramp(state.inputSet, wantedInput, cfg.inputRampPerSec, dt)
  state.outputSet = ramp(state.outputSet, wantedOutput, cfg.outputRampPerSec, dt)

  state.statusMsg = "Regulating"
end

local function controlStep(dt)
  local info = readInfo()
  state.lastInfo = info

  if not info.valid then
    setMode("FAULT", "No reactor data")
    state.inputSet = 0
    state.outputSet = 0
    pushFlows(dt)
    return
  end

  if state.mode == "LOW_FUEL" then
    state.outputSet = 0
    state.inputSet = cfg.maxInput
    pushFlows(dt)
    return
  end

  if state.mode == "SCRAMMED" then
    state.outputSet = 0
    state.inputSet = cfg.maxInput
    pushFlows(dt)
    return
  end

  if not safetyCheck(info) then
    pushFlows(dt)
    return
  end

  if state.mode == "CHARGING" then
    chargeControl(info, dt)
  elseif state.mode == "STARTING" then
    startupControl(info, dt)
  elseif state.mode == "RUNNING" then
    runningControl(info, dt)
  else
    -- IDLE or unknown
    state.outputSet = 0
    state.inputSet = clamp(state.inputSet, 0, cfg.maxInput)
  end

  pushFlows(dt)
end

-- =========================
-- ========= UI ============
-- =========================

local function resetButtons()
  state.buttons = {}
end

local function addButton(id, x1, y1, x2, y2, label, bg, fg)
  table.insert(state.buttons, {
    id = id, x1 = x1, y1 = y1, x2 = x2, y2 = y2,
    label = label, bg = bg or colors.gray, fg = fg or colors.white
  })
end

local function hitButton(x, y)
  for _, b in ipairs(state.buttons) do
    if x >= b.x1 and x <= b.x2 and y >= b.y1 and y <= b.y2 then
      return b.id
    end
  end
  return nil
end

local function fill(x1, y1, x2, y2, bg)
  MON.setBackgroundColor(bg)
  for y = y1, y2 do
    MON.setCursorPos(x1, y)
    MON.write(string.rep(" ", math.max(0, x2 - x1 + 1)))
  end
end

local function writeAt(x, y, text, fg, bg)
  if bg then MON.setBackgroundColor(bg) end
  if fg then MON.setTextColor(fg) end
  MON.setCursorPos(x, y)
  MON.write(text)
end

local function centerText(y, text, fg, bg)
  local x = math.max(1, math.floor((MW - #text) / 2) + 1)
  writeAt(x, y, text, fg, bg)
end

local function drawBox(x1, y1, x2, y2, title, bg, fg)
  fill(x1, y1, x2, y2, bg or colors.black)
  MON.setBackgroundColor(bg or colors.black)
  MON.setTextColor(fg or colors.white)
  writeAt(x1, y1, "+" .. string.rep("-", math.max(0, x2 - x1 - 1)) .. "+", fg, bg)
  for y = y1 + 1, y2 - 1 do
    writeAt(x1, y, "|", fg, bg)
    writeAt(x2, y, "|", fg, bg)
  end
  writeAt(x1, y2, "+" .. string.rep("-", math.max(0, x2 - x1 - 1)) .. "+", fg, bg)
  if title and #title > 0 then
    writeAt(x1 + 2, y1, title, fg, bg)
  end
end

local function drawBar(x, y, w, frac, colorFill, colorBack, label)
  frac = clamp(frac or 0, 0, 1)
  local fillW = math.floor(w * frac + 0.5)
  MON.setCursorPos(x, y)
  MON.setBackgroundColor(colorBack or colors.gray)
  MON.write(string.rep(" ", w))
  if fillW > 0 then
    MON.setCursorPos(x, y)
    MON.setBackgroundColor(colorFill or colors.lime)
    MON.write(string.rep(" ", fillW))
  end
  if label then
    local textX = x + math.max(0, math.floor((w - #label) / 2))
    writeAt(textX, y, label, colors.white, nil)
  end
end

local function drawButton(b)
  fill(b.x1, b.y1, b.x2, b.y2, b.bg)
  local textX = b.x1 + math.max(0, math.floor(((b.x2 - b.x1 + 1) - #b.label) / 2))
  local textY = b.y1 + math.floor((b.y2 - b.y1) / 2)
  writeAt(textX, textY, b.label, b.fg, b.bg)
end

local function renderMain()
  resetButtons()
  MON.setBackgroundColor(colors.black)
  MON.setTextColor(colors.white)
  MON.clear()

  local info = state.lastInfo

  centerText(1, "DRACONIC REACTOR CONTROL", colors.cyan, colors.black)
  centerText(2, string.format("Mode: %s  |  %s", state.mode, state.statusMsg), colors.white, colors.black)

  drawBox(1, 3, MW, MH - 5, " Reactor ", colors.black, colors.lightGray)

  local left = 3
  local y = 5

  writeAt(left, y,     "Status: " .. tostring(info.status), colors.white); y = y + 1
  writeAt(left, y,     "Temp:   " .. fmtInt(info.temperature) .. " C", colors.white); y = y + 1
  writeAt(left, y,     "Gen:    " .. fmtRF(info.generationRate) .. " RF/t", colors.white); y = y + 1
  writeAt(left, y,     "Input:  " .. fmtRF(getGateFlow(inputGate)) .. " RF/t", colors.white); y = y + 1
  writeAt(left, y,     "Output: " .. fmtRF(getGateFlow(outputGate)) .. " RF/t", colors.white); y = y + 2

  writeAt(left, y, "Field", colors.white)
  drawBar(left + 8, y, MW - 12, info.fieldFrac, colors.blue, colors.gray, fmtPct(info.fieldFrac))
  y = y + 2

  writeAt(left, y, "Sat", colors.white)
  drawBar(left + 8, y, MW - 12, info.satFrac, colors.orange, colors.gray, fmtPct(info.satFrac))
  y = y + 2

  writeAt(left, y, "Fuel", colors.white)
  drawBar(left + 8, y, MW - 12, info.fuelRemainingFrac, colors.green, colors.gray, fmtPct(info.fuelRemainingFrac))
  y = y + 2

  writeAt(left, y, "Conversion: " .. fmtPct(info.conversionFrac), colors.lightGray)

  local by = MH - 3
  addButton("charge",   2, by,  math.floor(MW * 0.24), MH - 1, "CHARGE",   colors.blue, colors.white)
  addButton("activate", math.floor(MW * 0.24) + 2, by, math.floor(MW * 0.51), MH - 1, "ACTIVATE", colors.green, colors.black)
  addButton("scram",    math.floor(MW * 0.51) + 2, by, math.floor(MW * 0.76), MH - 1, "SCRAM",    colors.red, colors.white)
  addButton("tuning",   math.floor(MW * 0.76) + 2, by, MW - 1, MH - 1, "TUNING",   colors.purple, colors.white)

  for _, b in ipairs(state.buttons) do drawButton(b) end
end

local tuneFields = {
  {
    key = "targetTemp", label = "Target Temp (C)",
    format = function(v) return tostring(round(v)) end,
    stepSmall = 25, stepBig = 100, min = 5000, max = 8000
  },
  {
    key = "targetSaturation", label = "Target Saturation",
    format = function(v) return string.format("%.2f", v) end,
    stepSmall = 0.01, stepBig = 0.05, min = 0.50, max = 0.90
  },
  {
    key = "targetField", label = "Target Field",
    format = function(v) return string.format("%.2f", v) end,
    stepSmall = 0.01, stepBig = 0.05, min = 0.45, max = 0.80
  },
}

local function adjustTune(delta, big)
  local f = tuneFields[state.tuneIndex]
  local step = big and f.stepBig or f.stepSmall
  cfg[f.key] = clamp(cfg[f.key] + delta * step, f.min, f.max)
end

local function renderTuning()
  resetButtons()
  MON.setBackgroundColor(colors.black)
  MON.setTextColor(colors.white)
  MON.clear()

  centerText(1, "TUNING", colors.cyan, colors.black)
  centerText(2, "Touch arrows to edit live targets", colors.lightGray, colors.black)

  local y = 5
  for i, f in ipairs(tuneFields) do
    local selected = (i == state.tuneIndex)
    local fg = selected and colors.yellow or colors.white
    writeAt(3, y, (selected and "> " or "  ") .. f.label .. ": " .. f.format(cfg[f.key]), fg, colors.black)
    y = y + 3
  end

  addButton("prev", 2, MH - 8, math.floor(MW * 0.18), MH - 6, "PREV", colors.gray, colors.white)
  addButton("next", math.floor(MW * 0.18) + 2, MH - 8, math.floor(MW * 0.36), MH - 6, "NEXT", colors.gray, colors.white)

  addButton("minusBig",  2, MH - 5, math.floor(MW * 0.22), MH - 3, "- BIG", colors.red, colors.white)
  addButton("minus",     math.floor(MW * 0.22) + 2, MH - 5, math.floor(MW * 0.42), MH - 3, "-", colors.orange, colors.black)
  addButton("plus",      math.floor(MW * 0.42) + 2, MH - 5, math.floor(MW * 0.62), MH - 3, "+", colors.lime, colors.black)
  addButton("plusBig",   math.floor(MW * 0.62) + 2, MH - 5, math.floor(MW * 0.82), MH - 3, "+ BIG", colors.green, colors.black)
  addButton("back",      math.floor(MW * 0.82) + 2, MH - 5, MW - 1, MH - 3, "BACK", colors.purple, colors.white)

  for _, b in ipairs(state.buttons) do drawButton(b) end
end

local function render()
  if state.page == "main" then
    renderMain()
  else
    renderTuning()
  end
end

local function handleButton(id)
  if state.page == "main" then
    if id == "charge" then
      engageCharge()
    elseif id == "activate" then
      engageActivate()
    elseif id == "scram" then
      engageScram("Manual SCRAM")
    elseif id == "tuning" then
      state.page = "tuning"
    end
  else
    if id == "prev" then
      state.tuneIndex = state.tuneIndex - 1
      if state.tuneIndex < 1 then state.tuneIndex = #tuneFields end
    elseif id == "next" then
      state.tuneIndex = state.tuneIndex + 1
      if state.tuneIndex > #tuneFields then state.tuneIndex = 1 end
    elseif id == "minusBig" then
      adjustTune(-1, true)
    elseif id == "minus" then
      adjustTune(-1, false)
    elseif id == "plus" then
      adjustTune(1, false)
    elseif id == "plusBig" then
      adjustTune(1, true)
    elseif id == "back" then
      state.page = "main"
    end
  end
end

-- =========================
-- ====== LOOPS ============
-- =========================

local function uiLoop()
  local interval = 1 / cfg.uiFps
  while true do
    render()
    sleep(interval)
  end
end

local function controlLoop()
  local interval = 1 / cfg.controlHz
  local last = now()
  while true do
    local t = now()
    local dt = math.max(0.01, t - last)
    last = t
    controlStep(dt)
    sleep(interval)
  end
end

local function inputLoop()
  while true do
    local e, side, x, y = os.pullEvent()
    if e == "monitor_touch" then
      local id = hitButton(x, y)
      if id then
        handleButton(id)
      end
    elseif e == "peripheral" or e == "peripheral_detach" then
      -- keep monitor clean on topology changes
      state.needsFullRedraw = true
    end
  end
end

