-- draconic_manager.lua
-- Production / unattended Draconic Evolution reactor controller for CC:Tweaked
-- Edit ONLY the CONFIG table below.

local CONFIG = {
  peripherals = {
    reactor = "draconic_reactor_0",
    inputGate = "flow_gate_0",
    outputGate = "flow_gate_1",
    monitor = "monitor_0", -- set to nil to disable monitor UI
  },

  loopDelay = 0.10,

  targets = {
    field = 0.48,
    emergencyField = 0.20,

    saturation = 0.78,
    saturationBand = 0.04,
    minSaturationRunning = 0.22,

    softTemp = 6500,
    hardTemp = 7800,

    startupTemp = 2050,
    startupSat = 0.92,
    startupField = 0.55,
  },

  startup = {
    chargeInput = 2000000,
    warmupMinInput = 600000,
    initialOutput = 50000,
  },

  output = {
    min = 0,
    max = 2147483647,

    minStep = 50000,
    maxStep = 25000000,
    gain = 0.12,
  },

  control = {
    inputMargin = 1.08,
  },

  safety = {
    latchEmergency = true,   -- requires manual reset after emergency
    quietLogs = false,       -- true = fewer console updates
  },

  ui = {
    textScale = 0.5,
    monitorTouch = true,
  },
}

local state = {
  running = true,
  autoMode = true,
  emergency = false,
  latched = false,
  latchReason = nil,
  startupComplete = false,
  page = "main",
  lastSummary = "",
}

local reactor
local inputGate
local outputGate
local monitor
local buttons = {}

local function clamp(x, lo, hi)
  if x < lo then return lo end
  if x > hi then return hi end
  return x
end

local function round(x)
  return math.floor(x + 0.5)
end

local function pct(v, max)
  if not max or max == 0 then return 0 end
  return v / max
end

local function safeNumber(v, fallback)
  if type(v) == "number" then return v end
  return fallback
end

local function log(msg, force)
  if force or (not CONFIG.safety.quietLogs and msg ~= state.lastSummary) then
    print(msg)
    state.lastSummary = msg
  end
end

local function failSafeOutput()
  pcall(function() if outputGate then outputGate.setSignalLowFlow(0) end end)
end

local function failSafeInput()
  pcall(function()
    if inputGate then
      inputGate.setSignalLowFlow(math.max(0, CONFIG.startup.chargeInput or 0))
    end
  end)
end

local function tryWrap(name, label)
  if not name then return nil end
  local p = peripheral.wrap(name)
  if not p then
    error("Missing " .. label .. " peripheral: " .. tostring(name))
  end
  return p
end

local function requireMethod(obj, objName, methodName)
  if not obj or type(obj[methodName]) ~= "function" then
    error(objName .. " is missing required method: " .. methodName)
  end
end

local function bindPeripherals()
  reactor = tryWrap(CONFIG.peripherals.reactor, "reactor")
  inputGate = tryWrap(CONFIG.peripherals.inputGate, "input gate")
  outputGate = tryWrap(CONFIG.peripherals.outputGate, "output gate")
  monitor = nil

  if CONFIG.peripherals.monitor then
    monitor = peripheral.wrap(CONFIG.peripherals.monitor)
    if not monitor then
      error("Missing monitor peripheral: " .. tostring(CONFIG.peripherals.monitor))
    end
    if type(monitor.setTextScale) == "function" then
      pcall(function() monitor.setTextScale(CONFIG.ui.textScale or 0.5) end)
    end
  end

  requireMethod(reactor, "reactor", "getReactorInfo")
  requireMethod(reactor, "reactor", "chargeReactor")
  requireMethod(reactor, "reactor", "activateReactor")
  requireMethod(reactor, "reactor", "stopReactor")

  requireMethod(inputGate, "input gate", "setSignalLowFlow")
  requireMethod(inputGate, "input gate", "getSignalLowFlow")
  requireMethod(outputGate, "output gate", "setSignalLowFlow")
  requireMethod(outputGate, "output gate", "getSignalLowFlow")
end

local function setInput(rate)
  rate = clamp(round(rate), 0, CONFIG.output.max)
  inputGate.setSignalLowFlow(rate)
  return rate
end

local function setOutput(rate)
  rate = clamp(round(rate), CONFIG.output.min, CONFIG.output.max)
  outputGate.setSignalLowFlow(rate)
  return rate
end

local function getInfo()
  return reactor.getReactorInfo()
end

local function getFieldPct(info)
  return pct(info.fieldStrength, info.maxFieldStrength)
end

local function getSatPct(info)
  return pct(info.energySaturation, info.maxEnergySaturation)
end

local function getFuelPct(info)
  return 1 - pct(info.fuelConversion, info.maxFuelConversion)
end

local function exactFieldInput(info, targetField)
  local denom = 1 - targetField
  if denom < 0.05 then denom = 0.05 end
  return safeNumber(info.fieldDrainRate, 0) / denom
end

local function summaryText(info)
  return string.format(
    "status=%s temp=%.0fC field=%.2f%% sat=%.2f%% gen=%d drain=%d in=%d out=%d fuel=%.2f%% auto=%s latched=%s",
    tostring(info.status),
    safeNumber(info.temperature, 0),
    getFieldPct(info) * 100,
    getSatPct(info) * 100,
    round(safeNumber(info.generationRate, 0)),
    round(safeNumber(info.fieldDrainRate, 0)),
    round(inputGate.getSignalLowFlow()),
    round(outputGate.getSignalLowFlow()),
    getFuelPct(info) * 100,
    tostring(state.autoMode),
    tostring(state.latched)
  )
end

local function emergencyStop(reason)
  state.emergency = true
  state.autoMode = false
  state.startupComplete = false

  if CONFIG.safety.latchEmergency then
    state.latched = true
    state.latchReason = reason
  end

  log("EMERGENCY STOP: " .. tostring(reason), true)

  pcall(function() setOutput(0) end)
  pcall(function() reactor.stopReactor() end)
  pcall(function() reactor.chargeReactor() end)
  pcall(function() setInput(CONFIG.startup.chargeInput) end)
end

local function resetLatch()
  state.latched = false
  state.latchReason = nil
  state.emergency = false
  log("Emergency latch reset.", true)
end

local function clearTerm(termObj)
  if not termObj then return end
  pcall(function()
    termObj.setBackgroundColor(colors.black)
    termObj.setTextColor(colors.white)
    termObj.clear()
  end)
end

local function writeLine(termObj, x, y, text, fg, bg)
  if not termObj then return end
  pcall(function()
    if bg then termObj.setBackgroundColor(bg) end
    if fg then termObj.setTextColor(fg) end
    termObj.setCursorPos(x, y)
    termObj.write(text)
  end)
end

local function makeButton(termObj, x1, y1, x2, y2, label, fg, bg)
  pcall(function()
    termObj.setBackgroundColor(bg)
    termObj.setTextColor(fg)
    for y = y1, y2 do
      termObj.setCursorPos(x1, y)
      termObj.write(string.rep(" ", x2 - x1 + 1))
    end
    local lx = math.floor((x1 + x2 - #label) / 2)
    local ly = math.floor((y1 + y2) / 2)
    termObj.setCursorPos(lx, ly)
    termObj.write(label)
  end)
  return {x1 = x1, y1 = y1, x2 = x2, y2 = y2}
end

local function addButton(name, btn)
  buttons[name] = btn
end

local function clearButtons()
  buttons = {}
end

local function buttonHit(btn, x, y)
  return x >= btn.x1 and x <= btn.x2 and y >= btn.y1 and y <= btn.y2
end

local function drawMain(info)
  if not monitor then return end
  clearTerm(monitor)
  clearButtons()

  local w, h = monitor.getSize()
  local field = getFieldPct(info) * 100
  local sat = getSatPct(info) * 100
  local fuel = getFuelPct(info) * 100

  writeLine(monitor, 2, 1, "Draconic Reactor Manager", colors.yellow)
  writeLine(monitor, 2, 2, "Main", colors.lightGray)

  writeLine(monitor, 2, 4, "Status:    " .. tostring(info.status))
  writeLine(monitor, 2, 5, "Auto:      " .. tostring(state.autoMode), state.autoMode and colors.lime or colors.orange)
  writeLine(monitor, 2, 6, "Emergency: " .. tostring(state.emergency), state.emergency and colors.red or colors.lime)
  writeLine(monitor, 2, 7, "Latched:   " .. tostring(state.latched), state.latched and colors.red or colors.lime)

  if state.latched and state.latchReason then
    writeLine(monitor, 2, 8, "Reason: " .. tostring(state.latchReason), colors.red)
  else
    writeLine(monitor, 2, 8, "Reason: none", colors.lightGray)
  end

  writeLine(monitor, 2, 10, "Temp:   " .. round(safeNumber(info.temperature, 0)) .. " C")
  writeLine(monitor, 2, 11, string.format("Field:  %.2f%%", field))
  writeLine(monitor, 2, 12, string.format("Sat:    %.2f%%", sat))
  writeLine(monitor, 2, 13, string.format("Fuel:   %.2f%%", fuel))
  writeLine(monitor, 2, 14, "Gen:    " .. round(safeNumber(info.generationRate, 0)) .. " rf/t")
  writeLine(monitor, 2, 15, "Drain:  " .. round(safeNumber(info.fieldDrainRate, 0)) .. " rf/t")
  writeLine(monitor, 2, 16, "Input:  " .. round(inputGate.getSignalLowFlow()) .. " rf/t")
  writeLine(monitor, 2, 17, "Output: " .. round(outputGate.getSignalLowFlow()) .. " rf/t")

  addButton("start", makeButton(monitor, w - 18, 3, w - 2, 5, "START", colors.black, colors.lime))
  addButton("stop", makeButton(monitor, w - 18, 6, w - 2, 8, "STOP", colors.white, colors.red))
  addButton("reset", makeButton(monitor, w - 18, 9, w - 2, 11, "RESET", colors.black, colors.yellow))
  addButton("auto", makeButton(monitor, w - 18, 12, w - 2, 14, state.autoMode and "AUTO ON" or "AUTO OFF", colors.black, colors.orange))
  addButton("tune", makeButton(monitor, w - 18, 15, w - 2, 17, "TUNE", colors.black, colors.cyan))

  writeLine(monitor, 2, h - 1, "Touch buttons or use terminal commands.", colors.lightGray)
end

local function drawTune(info)
  if not monitor then return end
  clearTerm(monitor)
  clearButtons()

  local w, h = monitor.getSize()

  writeLine(monitor, 2, 1, "Draconic Reactor Manager", colors.yellow)
  writeLine(monitor, 2, 2, "Tune", colors.lightGray)

  writeLine(monitor, 2, 4, string.format("Target Field: %.3f", CONFIG.targets.field))
  writeLine(monitor, 2, 5, string.format("Target Sat:   %.3f", CONFIG.targets.saturation))
  writeLine(monitor, 2, 6, string.format("Output Gain:  %.3f", CONFIG.output.gain))
  writeLine(monitor, 2, 7, string.format("Soft Temp:    %d", CONFIG.targets.softTemp))

  addButton("field_up", makeButton(monitor, 2, 9, 12, 11, "FIELD +", colors.black, colors.lime))
  addButton("field_dn", makeButton(monitor, 14, 9, 24, 11, "FIELD -", colors.black, colors.orange))
  addButton("sat_up", makeButton(monitor, 2, 12, 12, 14, "SAT +", colors.black, colors.lime))
  addButton("sat_dn", makeButton(monitor, 14, 12, 24, 14, "SAT -", colors.black, colors.orange))
  addButton("gain_up", makeButton(monitor, 2, 15, 12, 17, "GAIN +", colors.black, colors.lime))
  addButton("gain_dn", makeButton(monitor, 14, 15, 24, 17, "GAIN -", colors.black, colors.orange))

  addButton("main", makeButton(monitor, w - 18, 15, w - 2, 17, "BACK", colors.black, colors.gray))
  writeLine(monitor, 2, h - 1, "These changes apply live.", colors.lightGray)
end

local function drawMonitor(info)
  if not monitor then return end
  if state.page == "tune" then
    drawTune(info)
  else
    drawMain(info)
  end
end

local function handleColdOrWarming(info)
  state.emergency = false
  state.startupComplete = false
  setOutput(0)

  if state.latched then
    setInput(0)
    return
  end

  if info.status == "cold" then
    setInput(CONFIG.startup.chargeInput)
    reactor.chargeReactor()
  elseif info.status == "warming_up" then
    setInput(CONFIG.startup.chargeInput)
  end
end

local function handleStoppingOrCooling(info)
  setOutput(0)

  if state.latched then
    setInput(0)
    return
  end

  if safeNumber(info.temperature, 0) > 2000 then
    setInput(CONFIG.startup.chargeInput)
  else
    setInput(0)
  end
end

local function startupTransition(info)
  local field = getFieldPct(info)
  local sat = getSatPct(info)

  if info.status ~= "running" then
    state.startupComplete = false
    return false
  end

  if safeNumber(info.temperature, 0) < CONFIG.targets.startupTemp
    or sat < CONFIG.targets.startupSat
    or field < CONFIG.targets.startupField then

    local exactIn = exactFieldInput(info, CONFIG.targets.field) * CONFIG.control.inputMargin
    setInput(math.max(CONFIG.startup.warmupMinInput, exactIn))
    setOutput(CONFIG.startup.initialOutput)
    state.startupComplete = false
    return true
  end

  if not state.startupComplete then
    state.startupComplete = true
    log("Startup thresholds reached. Normal regulation enabled.", true)
  end

  return false
end

local function regulateRunning(info)
  local field = getFieldPct(info)
  local sat = getSatPct(info)
  local temp = safeNumber(info.temperature, 0)
  local gen = safeNumber(info.generationRate, 0)
  local drain = safeNumber(info.fieldDrainRate, 0)
  local currentOut = outputGate.getSignalLowFlow()

  local exactIn = exactFieldInput(info, CONFIG.targets.field)
  local commandedInput = exactIn * CONFIG.control.inputMargin

  if temp < CONFIG.targets.startupTemp then
    commandedInput = math.max(commandedInput, CONFIG.startup.warmupMinInput)
  end

  if field < CONFIG.targets.field - 0.08 then
    commandedInput = math.max(commandedInput, drain * 3)
  elseif field < CONFIG.targets.field - 0.03 then
    commandedInput = math.max(commandedInput, drain * 2)
  end

  setInput(commandedInput)

  if not state.autoMode then
    return
  end

  local satErr = sat - CONFIG.targets.saturation
  local tempOver = math.max(0, temp - CONFIG.targets.softTemp)
  local stepBase = clamp(gen * CONFIG.output.gain, CONFIG.output.minStep, CONFIG.output.maxStep)
  local newOut = currentOut

  if sat < CONFIG.targets.minSaturationRunning then
    newOut = math.max(CONFIG.output.min, currentOut - stepBase * 4)
  elseif temp > CONFIG.targets.softTemp then
    local tempFactor = 1 + (tempOver / 500)
    newOut = math.max(CONFIG.output.min, currentOut - stepBase * tempFactor)
  elseif field < CONFIG.targets.field - 0.05 then
    newOut = math.max(CONFIG.output.min, currentOut - stepBase * 2)
  else
    if satErr > CONFIG.targets.saturationBand then
      local gainFactor = 1 + (satErr * 5)
      newOut = currentOut + stepBase * gainFactor
    elseif satErr < -CONFIG.targets.saturationBand then
      local lossFactor = 1 + (math.abs(satErr) * 6)
      newOut = currentOut - stepBase * lossFactor
    else
      if temp < CONFIG.targets.softTemp - 800 and field > CONFIG.targets.field + 0.03 then
        newOut = currentOut + CONFIG.output.minStep
      elseif temp > CONFIG.targets.softTemp - 200 then
        newOut = currentOut - CONFIG.output.minStep
      end
    end
  end

  setOutput(clamp(newOut, CONFIG.output.min, CONFIG.output.max))
end

local function controllerTick()
  local ok, info = pcall(getInfo)
  if not ok or not info then
    failSafeOutput()
    failSafeInput()
    log("Read failure: reactor info unavailable. Holding safe state.", true)
    sleep(1)
    return
  end

  local field = getFieldPct(info)
  local sat = getSatPct(info)
  local temp = safeNumber(info.temperature, 0)

  if info.status == "running" then
    if field <= CONFIG.targets.emergencyField then
      emergencyStop(string.format("Field too low: %.2f%%", field * 100))
    elseif temp >= CONFIG.targets.hardTemp then
      emergencyStop(string.format("Temperature too high: %.0fC", temp))
    elseif sat <= 0.05 then
      emergencyStop(string.format("Saturation critically low: %.2f%%", sat * 100))
    else
      if state.autoMode and not state.latched then
        state.emergency = false
      end
    end
  end

  if state.latched then
    setOutput(0)
    if info.status == "cold" or info.status == "warming_up" or info.status == "cooling" or info.status == "stopping" then
      setInput(0)
    else
      setInput(CONFIG.startup.chargeInput)
    end
    drawMonitor(info)
    log(summaryText(info), false)
    return
  end

  if info.status == "cold" or info.status == "warming_up" then
    handleColdOrWarming(info)
  elseif info.status == "stopping" or info.status == "cooling" then
    handleStoppingOrCooling(info)
  elseif info.status == "running" then
    if not startupTransition(info) then
      regulateRunning(info)
    end
  else
    setOutput(0)
    setInput(CONFIG.startup.chargeInput)
  end

  drawMonitor(info)
  log(summaryText(info), false)
end

local function startupCheck()
  bindPeripherals()

  local ok, info = pcall(getInfo)
  if not ok or not info then
    error("Reactor peripheral did not return reactor info.")
  end

  pcall(function() inputGate.getSignalLowFlow() end)
  pcall(function() outputGate.getSignalLowFlow() end)

  print("Startup check OK")
  print(" Reactor:    " .. tostring(CONFIG.peripherals.reactor))
  print(" Input gate: " .. tostring(CONFIG.peripherals.inputGate))
  print(" Output gate:" .. tostring(CONFIG.peripherals.outputGate))
  print(" Monitor:    " .. tostring(CONFIG.peripherals.monitor))
end

local function showStatus()
  local info = getInfo()
  print(summaryText(info))
  if state.latched and state.latchReason then
    print("Latch reason: " .. tostring(state.latchReason))
  end
end

local function printHelp()
  print("Commands:")
  print("  help")
  print("  status")
  print("  start")
  print("  stop")
  print("  reset")
  print("  auto on")
  print("  auto off")
  print("  set field <0.10-0.80>")
  print("  set sat <0.10-0.99>")
  print("  set gain <number>")
  print("  set softtemp <number>")
  print("  set out <number>")
  print("  set charge <number>")
  print("  set warmup <number>")
  print("  set initialout <number>")
  print("  exit")
end

local function splitWords(s)
  local t = {}
  for w in s:gmatch("%S+") do
    t[#t + 1] = w
  end
  return t
end

local function doStart()
  if state.latched then
    print("Cannot start: emergency is latched. Use 'reset' first.")
    return
  end
  state.autoMode = true
  state.emergency = false
  pcall(function() reactor.chargeReactor() end)
  pcall(function() reactor.activateReactor() end)
  print("Start sequence issued.")
end

local function doStop()
  state.autoMode = false
  setOutput(0)
  pcall(function() reactor.stopReactor() end)
  print("Stop sequence issued.")
end

local function commandLoop()
  print("Production controller ready. Type 'help' for commands.")
  while state.running do
    write("> ")
    local line = read()
    if line then
      local args = splitWords(line)
      local cmd = args[1] and string.lower(args[1]) or ""

      if cmd == "help" then
        printHelp()

      elseif cmd == "status" then
        local ok, err = pcall(showStatus)
        if not ok then print("Status error: " .. tostring(err)) end

      elseif cmd == "start" then
        doStart()

      elseif cmd == "stop" then
        doStop()

      elseif cmd == "reset" then
        resetLatch()

      elseif cmd == "auto" and args[2] then
        if args[2] == "on" then
          if state.latched then
            print("Cannot enable auto: emergency is latched. Use 'reset' first.")
          else
            state.autoMode = true
            state.emergency = false
            print("Auto mode enabled.")
          end
        elseif args[2] == "off" then
          state.autoMode = false
          print("Auto mode disabled.")
        else
          print("Use: auto on | auto off")
        end

      elseif cmd == "set" and args[2] and args[3] then
        local key = string.lower(args[2])
        local value = tonumber(args[3])

        if not value then
          print("Numeric value required.")
        elseif key == "field" then
          CONFIG.targets.field = clamp(value, 0.10, 0.80)
          print("Target field set to " .. CONFIG.targets.field)

        elseif key == "sat" then
          CONFIG.targets.saturation = clamp(value, 0.10, 0.99)
          print("Target saturation set to " .. CONFIG.targets.saturation)

        elseif key == "gain" then
          CONFIG.output.gain = clamp(value, 0.001, 5.0)
          print("Output gain set to " .. CONFIG.output.gain)

        elseif key == "softtemp" then
          CONFIG.targets.softTemp = round(clamp(value, 2000, CONFIG.targets.hardTemp - 100))
          print("Soft temp set to " .. CONFIG.targets.softTemp)

        elseif key == "out" then
          state.autoMode = false
          setOutput(clamp(value, CONFIG.output.min, CONFIG.output.max))
          print("Manual output set to " .. outputGate.getSignalLowFlow())

        elseif key == "charge" then
          CONFIG.startup.chargeInput = round(math.max(0, value))
          print("Charge input set to " .. CONFIG.startup.chargeInput)

        elseif key == "warmup" then
          CONFIG.startup.warmupMinInput = round(math.max(0, value))
          print("Warmup input set to " .. CONFIG.startup.warmupMinInput)

        elseif key == "initialout" then
          CONFIG.startup.initialOutput = round(math.max(0, value))
          print("Initial output set to " .. CONFIG.startup.initialOutput)

        else
          print("Unknown set key.")
        end

      elseif cmd == "exit" then
        state.running = false
        print("Exiting controller...")

      elseif cmd ~= "" then
        print("Unknown command. Type 'help'.")
      end
    else
      sleep(0.1)
    end
  end
end

local function monitorTouchLoop()
  while state.running do
    local _, side, x, y = os.pullEvent("monitor_touch")
    if monitor and CONFIG.ui.monitorTouch and side == CONFIG.peripherals.monitor then
      for name, btn in pairs(buttons) do
        if buttonHit(btn, x, y) then
          if name == "start" then
            doStart()
          elseif name == "stop" then
            doStop()
          elseif name == "reset" then
            resetLatch()
          elseif name == "auto" then
            if state.latched then
              print("Cannot enable auto: emergency is latched.")
            else
              state.autoMode = not state.autoMode
              if state.autoMode then
                state.emergency = false
              end
            end
          elseif name == "tune" then
            state.page = "tune"
          elseif name == "main" then
            state.page = "main"
          elseif name == "field_up" then
            CONFIG.targets.field = clamp(CONFIG.targets.field + 0.01, 0.10, 0.80)
          elseif name == "field_dn" then
            CONFIG.targets.field = clamp(CONFIG.targets.field - 0.01, 0.10, 0.80)
          elseif name == "sat_up" then
            CONFIG.targets.saturation = clamp(CONFIG.targets.saturation + 0.01, 0.10, 0.99)
          elseif name == "sat_dn" then
            CONFIG.targets.saturation = clamp(CONFIG.targets.saturation - 0.01, 0.10, 0.99)
          elseif name == "gain_up" then
            CONFIG.output.gain = clamp(CONFIG.output.gain + 0.01, 0.001, 5.0)
          elseif name == "gain_dn" then
            CONFIG.output.gain = clamp(CONFIG.output.gain - 0.01, 0.001, 5.0)
          end
          break
        end
      end
    end
  end
end

local function controllerLoop()
  setOutput(0)
  setInput(0)

  while state.running do
    local ok, err = pcall(controllerTick)
    if not ok then
      print("Controller fault: " .. tostring(err))
      failSafeOutput()
      failSafeInput()
      sleep(1)
    else
      sleep(CONFIG.loopDelay)
    end
  end
end

local ok, err = pcall(startupCheck)
if not ok then
  print("Startup failed: " .. tostring(err))
  return
end

if monitor and CONFIG.ui.monitorTouch then
  parallel.waitForAny(controllerLoop, commandLoop, monitorTouchLoop)
else
  parallel.waitForAny(controllerLoop, commandLoop)
end

pcall(function() setOutput(0) end)
pcall(function() setInput(CONFIG.startup.chargeInput) end)
print("Controller stopped.")
