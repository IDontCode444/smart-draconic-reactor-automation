local function clearButtons()
  buttons = {}
end

local function cacheWrite(key, x, y, text, fg, bg)
  local sig = tostring(text) .. "|" .. tostring(fg or "") .. "|" .. tostring(bg or "")
  if screenCache[key] == sig then return end
  screenCache[key] = sig
  if bg then monitor.setBackgroundColor(bg) end
  if fg then monitor.setTextColor(fg) end
  monitor.setCursorPos(x, y)
  monitor.write(text)
end

local function clearCache()
  screenCache = {}
end

local function writeAt(x, y, text, fg, bg)
  cacheWrite(("T:%d:%d"):format(x, y), x, y, text, fg, bg)
end

local function fillRect(x1, y1, x2, y2, bg)
  for y = y1, y2 do
    cacheWrite(("F:%d:%d:%d"):format(x1, y, x2), x1, y, (" "):rep(x2 - x1 + 1), nil, bg)
  end
end

local function addButton(id, x1, y1, x2, y2, label, bg, fg, fn)
  buttons[id] = {
    x1 = x1, y1 = y1, x2 = x2, y2 = y2,
    label = label, bg = bg, fg = fg, fn = fn
  }
end

local function drawButton(b)
  fillRect(b.x1, b.y1, b.x2, b.y2, b.bg)
  local tx = math.floor((b.x1 + b.x2 - #b.label) / 2)
  local ty = math.floor((b.y1 + b.y2) / 2)
  writeAt(tx, ty, b.label, b.fg, b.bg)
end

local function drawBar(x, y, w, valuePct, fillColor, backColor, label)
  valuePct = clamp(valuePct or 0, 0, 100)
  local fillW = math.floor((w * valuePct) / 100)

  for i = 0, w - 1 do
    local bg = (i < fillW) and fillColor or backColor
    cacheWrite(("B:%d:%d:%d"):format(x + i, y, i), x + i, y, " ", colors.white, bg)
  end

  local txt = label .. " " .. string.format("%5.1f%%", valuePct)
  local tx = x + math.max(0, math.floor((w - #txt) / 2))
  writeAt(tx, y, txt, colors.white, colors.black)
end

