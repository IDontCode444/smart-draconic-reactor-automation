local function redraw()
  if uiPage == "tune" then
    drawTune()
  else
    drawMain(lastInfo)
  end
end

local function handleTouch(side, x, y)
  if side ~= peripheral.getName(monitor) then return end

  for _, b in pairs(buttons) do
    if x >= b.x1 and x <= b.x2 and y >= b.y1 and y <= b.y2 then
      if b.fn then b.fn() end
      redraw()
      return
    end
  end
end

--========================================================--
--  SAFETY / CONTROL
--========================================================--

local function emergencyCheck(info)
  if not info then
    scram("Lost reactor data")
    return true
  end

  local fp = fieldPct(info)
  local sp = saturationPct(info)
  local fup = fuelPct(info)

  if fup <= CONFIG.fuelCritical and (info.status == "running" or info.status == "online" or info.status == "warming_up") then
    state.lowFuelLatch = true
    scram("Critical fuel low")
    return true
  end

  if fup <= CONFIG.fuelSafeShutdown and (info.status == "running" or info.status == "online") then
    state.lowFuelLatch = true
    safeShutdown("Fuel low safe shutdown")
    return true
  end

  if (info.temperature or 0) >= CONFIG.tempEmergency then
    scram("Temperature emergency")
    return true
  end

  if fp <= CONFIG.fieldEmergency and (info.status == "running" or info.status == "online") then
    scram("Field emergency")
    return true
  end

  if sp <= CONFIG.saturationEmergency and (info.status == "running" or info.status == "online") then
    scram("Saturation emergency")
    return true
  end

  return false
end

local function applyControl(info, dt)
  if emergencyCheck(info) then return end
  if not state.autoEnabled then return end

  local status = info.status
  local temp = info.temperature or 0
  local fp = fieldPct(info)
  local sp = saturationPct(info)
  local fup = fuelPct(info)

  if state.lowFuelLatch and fup > (CONFIG.fuelSafeShutdown + 5) and (status == "cold" or status == "cooling") then
    state.lowFuelLatch = false
    setStatus("Fuel latch cleared", colors.lime)
  end

  if state.requestedScram then
    scram("Operator SCRAM")
    return
  end

  if state.requestedCharge then
    pcall(reactor.chargeReactor)
    state.requestedCharge = false
  end

  if state.requestedActivate then
    if not state.lowFuelLatch then
      pcall(reactor.activateReactor)
    end
    state.requestedActivate = false
  end

  if status == "warming_up" then
    local wantIn = math.max(CONFIG.minChargeRate, (info.fieldDrainRate or 0) * 4)
    gateSet(gateIn, wantIn)
    gateSet(gateOut, 0)
    state.lastInput = wantIn
    state.lastOutput = 0

    if temp >= 2000 and fp >= 45 and sp >= 45 and not state.lowFuelLatch then
      pcall(reactor.activateReactor)
      setStatus("Charge complete, auto-activating", colors.lime)
    else
      setStatus("Charging / warming up", colors.yellow)
    end
    return
  end

  if status == "stopping" or status == "cooling" then
    local tf = clamp(CONFIG.targetField / 100, 0.05, 0.95)
    local baseIn = (info.fieldDrainRate or 0) / math.max(0.05, (1 - tf))
    local wantIn = math.max(baseIn, CONFIG.minChargeRate * 0.5)

    gateSet(gateIn, wantIn)
    gateSet(gateOut, 0)

    state.lastInput = wantIn
    state.lastOutput = 0

    if state.safeStopLatch then
      setStatus("Safe shutdown in progress", colors.orange)
    else
      setStatus("Cooling reactor", colors.orange)
    end
    return
  end

  if status == "cold" then
    gateSet(gateIn, 0)
    gateSet(gateOut, 0)
    state.lastInput = 0
    state.lastOutput = 0

    if state.safeStopLatch then
      setStatus("Reactor offline (safe stop)", colors.orange)
    else
      setStatus("Reactor offline", colors.lightGray)
    end
    return
  end

  if status == "running" or status == "online" then
    local targetField = CONFIG.targetField
    local targetSat = CONFIG.targetSaturation
    local targetTemp = CONFIG.targetTemp

    -- feed-forward base injector rate
    local tf = clamp(targetField / 100, 0.05, 0.95)
    local baseIn = (info.fieldDrainRate or 0) / math.max(0.05, (1 - tf))
    local minSafeIn = baseIn * CONFIG.inputBaseFloorFactor

    -- INPUT control
    local inFieldTrim = pidUpdate(pidInField, targetField - fp, dt)
    local inTempTrim  = pidUpdate(pidInTemp, temp - targetTemp, dt)
    local wantIn = baseIn + inFieldTrim + inTempTrim
    wantIn = clamp(wantIn, minSafeIn, CONFIG.maxInput)

    -- OUTPUT control
    local outSatTrim  = pidUpdate(pidOutSat, sp - targetSat, dt)
    local outTempTrim = pidUpdate(pidOutTemp, targetTemp - temp, dt)
    local wantOut = state.lastOutput + outSatTrim + outTempTrim

    local dynamicOutMax = math.max((info.generationRate or 0) * 1.20, 100000)
    dynamicOutMax = clamp(dynamicOutMax, 100000, CONFIG.maxOutput)
    wantOut = clamp(wantOut, 0, dynamicOutMax)

    if sp < targetSat - 10 then
      wantOut = wantOut * 0.7
    end
    if temp > targetTemp + 80 then
      wantOut = wantOut * 0.6
      wantIn = math.max(wantIn, baseIn * 1.08)
    end
    if fp < targetField - 5 then
      wantOut = wantOut * 0.8
      wantIn = math.max(wantIn, baseIn * 1.06)
    end

    wantIn = clamp(wantIn, minSafeIn, CONFIG.maxInput)
    wantOut = clamp(wantOut, 0, dynamicOutMax)

    gateSet(gateIn, wantIn)
    gateSet(gateOut, wantOut)

    state.lastInput = wantIn
    state.lastOutput = wantOut
    state.safeStopLatch = false
    state.emergencyLatch = false
    state.scramReason = nil

    setStatus(
      ("Auto | T:%d F:%.1f%% S:%.1f%% Fuel:%.1f%%"):format(temp, fp, sp, fup),
      colors.lime
    )
    return
  end

  setStatus("Unhandled status: " .. tostring(status), colors.orange)
end

--========================================================--
--  LOOPS
--========================================================--

local function controlLoop()
  resetPIDs()

  while running do
    local now = os.clock()
    local dt = now - state.lastLoop
    if dt <= 0 then dt = CONFIG.controlRate end
    state.lastLoop = now

    local info = getInfo()
    lastInfo = info

    if not info then
      setStatus("No reactor info", colors.red)
      gateSet(gateOut, 0)
    else
      applyControl(info, dt)
    end

    sleep(CONFIG.controlRate)
  end
end

local function drawLoop()
  while running do
    redraw()
    sleep(CONFIG.drawRate)
  end
end

local function eventLoop()
  while running do
    local e = { os.pullEvent() }

    if e[1] == "monitor_touch" then
      handleTouch(e[2], e[3], e[4])
    elseif e[1] == "terminate" then
      running = false
      gateSet(gateOut, 0)
      error("Terminated")
    end
  end
end

