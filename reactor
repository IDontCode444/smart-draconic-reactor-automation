-- Draconic Evolution Reactor Controller for CC:Tweaked / ATM10 6.2
-- Compatibility build:
-- - cold-state false SCRAM fixed
-- - monitor autodetect + touch support
-- - reactor/gate API method autodetect
-- - dynamic UI sizing
--
-- Edit peripheral names below.

local CONFIG = {
  REACTOR_NAME = "draconic_reactor_0",
  INPUT_GATE_NAME = "flow_gate_0",
  OUTPUT_GATE_NAME = "flow_gate_1",

  LOOP_INTERVAL = 0.25,
  DRAW_SCALE = 1.0,

  TARGET_TEMP = 8000,
  TARGET_SAT = 0.30,

  FIELD_TARGET_OPTIONS = { 0.35, 0.40, 0.45, 0.50 },
  DEFAULT_FIELD_TARGET = 0.35,

  CHARGE_INFLOW = 15000000,
  STARTUP_HOLD_SECONDS = 12,
  RAMP_SECONDS = 180,
  RAMP_START_FIELD = 0.78,
  RAMP_START_SAT = 0.65,

  SCRAM_TEMP = 8650,
  SCRAM_FIELD = 0.22,
  SCRAM_SAT = 0.08,
  SCRAM_NO_FUEL = 0.002,
  SCRAM_FIELD_RECOVERY = 0.75,
  SCRAM_COOLDOWN_OUTPUT = 0,

  TEMP_HIGH_BAND = 8350,
  TEMP_LOW_BAND = 7600,
  SAT_SOFT_LOW = 0.18,
  SAT_SOFT_HIGH = 0.92,

  MAX_INPUT = 60000000,
  MAX_OUTPUT = 120000000,

  PID_INPUT = {
    kp = 2.10, ki = 0.26, kd = 0.42,
    min = -30000000, max = 30000000,
    integralMin = -40000000, integralMax = 40000000
  },
  PID_OUTPUT = {
    kp = 1.85, ki = 0.22, kd = 0.48,
    min = 0, max = 120000000,
    integralMin = -60000000, integralMax = 60000000
  },

  REFRESH_UI_EVERY = 0.2,

  MONITOR_TEXT_SCALE = 0.5,
  COMPUTER_TEXT_SCALE = nil,
}

local reactor, gateIn, gateOut
local display = term
local monitorName = nil
local usingMonitor = false

local api = {
  reactorInfo = nil,
  charge = nil,
  activate = nil,
  stop = nil,
  failSafe = nil,
  gateEnable = nil,
  gateFlow = nil,
}

local state = {
  mode = "IDLE",
  lastInfo = nil,
  scramReason = nil,
  rampStart = nil,
  holdUntil = nil,
  log = {},
  buttons = {},
  inputOverride = 0,
  outputOverride = 0,
  manualOutputBias = 1.0,
  lastLoopAt = os.clock(),
  targetField = CONFIG.DEFAULT_FIELD_TARGET,
  apiSummary = "uninitialized",
  displaySummary = "computer terminal",
}

local function now() return os.clock() end

local function clamp(v, lo, hi)
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

local function round(v)
  return math.floor(v + 0.5)
end

local function pct(v)
  return math.floor(v * 1000 + 0.5) / 10
end

local function pushLog(msg)
  local stamp = textutils.formatTime(os.time(), true)
  table.insert(state.log, 1, ("[%s] %s"):format(stamp, msg))
  while #state.log > 12 do
    table.remove(state.log)
  end
end

local function safeCall(fn, ...)
  local ok, a, b, c = pcall(fn, ...)
  if ok then return true, a, b, c end
  return false, a
end

local function wrapPeripheral(name, expected)
  local p = peripheral.wrap(name)
  if not p then error(("Peripheral '%s' was not found"):format(name)) end
  local t = peripheral.getType(name)
  if expected and t ~= expected then
    pushLog(("Warning: '%s' type '%s' (expected '%s')"):format(name, tostring(t), expected))
  end
  return p
end

local function getBestMonitor()
  local names = peripheral.getNames()
  local bestName = nil
  local bestArea = -1

  for _, name in ipairs(names) do
    if peripheral.getType(name) == "monitor" then
      local mon = peripheral.wrap(name)
      local ok = pcall(function() mon.setTextScale(CONFIG.MONITOR_TEXT_SCALE) end)
      if ok then
        local w, h = mon.getSize()
        local area = w * h
        if area > bestArea then
          bestArea = area
          bestName = name
        end
      end
    end
  end

  return bestName
end

local function setupDisplay()
  monitorName = getBestMonitor()

  if monitorName then
    display = peripheral.wrap(monitorName)
    usingMonitor = true
    pcall(function() display.setTextScale(CONFIG.MONITOR_TEXT_SCALE) end)
    pcall(function() display.setBackgroundColor(colors.black) end)
    state.displaySummary = "monitor: " .. monitorName
    pushLog("Using monitor: " .. monitorName)
  else
    display = term.current()
    usingMonitor = false
    if CONFIG.COMPUTER_TEXT_SCALE and display.setTextScale then
      pcall(function() display.setTextScale(CONFIG.COMPUTER_TEXT_SCALE) end)
    end
    state.displaySummary = "computer terminal"
    pushLog("Using computer terminal")
  end
end

local function getMethod(obj, candidates)
  for _, name in ipairs(candidates) do
    if type(obj[name]) == "function" then
      return name, obj[name]
    end
  end
  return nil, nil
end

local function requireMethod(obj, candidates, label)
  local name, fn = getMethod(obj, candidates)
  if not fn then
    error(("Could not find %s. Tried: %s"):format(label, table.concat(candidates, ", ")))
  end
  return name, fn
end

local function detectAPIs()
  local riName, _ = requireMethod(reactor, {
    "getReactorInfo",
    "getInfo",
    "info",
  }, "reactor info method")

  local chName, _ = requireMethod(reactor, {
    "chargeReactor",
    "charge",
  }, "reactor charge method")

  local acName, _ = requireMethod(reactor, {
    "activateReactor",
    "activate",
    "startup",
    "startReactor",
  }, "reactor activate method")

  local stName, _ = requireMethod(reactor, {
    "stopReactor",
    "stop",
    "shutdown",
    "deactivateReactor",
  }, "reactor stop method")

  local fsName = nil
  do
    local n = getMethod(reactor, {
      "setFailSafe",
      "setFailsafe",
      "enableFailSafe",
      "enableFailsafe",
    })
    fsName = n
  end

  local geName, _ = requireMethod(gateIn, {
    "setOverrideEnabled",
    "setSignalHighFlow",
    "setRedstoneMode",
  }, "flow gate enable method")

  local gfName, _ = requireMethod(gateIn, {
    "setFlowOverride",
    "setFlow",
    "setTransferRate",
  }, "flow gate flow method")

  api.reactorInfo = riName
  api.charge = chName
  api.activate = acName
  api.stop = stName
  api.failSafe = fsName
  api.gateEnable = geName
  api.gateFlow = gfName

  state.apiSummary =
    ("info=%s charge=%s start=%s stop=%s gateEnable=%s gateFlow=%s"):format(
      tostring(api.reactorInfo),
      tostring(api.charge),
      tostring(api.activate),
      tostring(api.stop),
      tostring(api.gateEnable),
      tostring(api.gateFlow)
    )

  pushLog("API detected")
end

local function callReactor(name, ...)
  local fn = reactor[api[name]]
  if not fn then return false, "missing reactor method " .. tostring(name) end
  return safeCall(fn, reactor, ...)
end

local function callGateEnable(gate, enabled)
  if api.gateEnable == "setOverrideEnabled" then
    return safeCall(gate.setOverrideEnabled, gate, enabled)
  elseif api.gateEnable == "setSignalHighFlow" then
    if enabled then
      return safeCall(gate.setSignalHighFlow, gate, 0)
    else
      return safeCall(gate.setSignalHighFlow, gate, 0)
    end
  elseif api.gateEnable == "setRedstoneMode" then
    return safeCall(gate.setRedstoneMode, gate, "ignored")
  end
  return false, "unknown gate enable method"
end

local function callGateFlow(gate, value)
  if api.gateFlow == "setFlowOverride" then
    return safeCall(gate.setFlowOverride, gate, value)
  elseif api.gateFlow == "setFlow" then
    return safeCall(gate.setFlow, gate, value)
  elseif api.gateFlow == "setTransferRate" then
    return safeCall(gate.setTransferRate, gate, value)
  end
  return false, "unknown gate flow method"
end

local function setupPeripherals()
  reactor = wrapPeripheral(CONFIG.REACTOR_NAME, "draconic_reactor")
  gateIn = wrapPeripheral(CONFIG.INPUT_GATE_NAME, "flow_gate")
  gateOut = wrapPeripheral(CONFIG.OUTPUT_GATE_NAME, "flow_gate")

  detectAPIs()

  callGateEnable(gateIn, true)
  callGateEnable(gateOut, true)
  callGateFlow(gateIn, 0)
  callGateFlow(gateOut, 0)

  pushLog("Peripherals connected")
end

local function newPID(cfg)
  return {
    kp = cfg.kp, ki = cfg.ki, kd = cfg.kd,
    min = cfg.min, max = cfg.max,
    integralMin = cfg.integralMin, integralMax = cfg.integralMax,
    integral = 0,
    prevError = 0,
    first = true,
  }
end

local pidInput = newPID(CONFIG.PID_INPUT)
local pidOutput = newPID(CONFIG.PID_OUTPUT)

local function resetPID(pid)
  pid.integral = 0
  pid.prevError = 0
  pid.first = true
end

local function resetAllPIDs()
  resetPID(pidInput)
  resetPID(pidOutput)
end

local function stepPID(pid, error, dt)
  dt = math.max(dt, 0.001)
  pid.integral = clamp(pid.integral + error * dt, pid.integralMin, pid.integralMax)

  local derivative = 0
  if not pid.first then
    derivative = (error - pid.prevError) / dt
  end

  pid.first = false
  pid.prevError = error

  return clamp(pid.kp * error + pid.ki * pid.integral + pid.kd * derivative, pid.min, pid.max)
end

local function normalizeStatus(s)
  s = tostring(s or ""):lower()
  if s == "online" then return "running" end
  if s == "warming_up" then return "starting" end
  if s == "warming" then return "starting" end
  if s == "stopping" then return "stopping" end
  if s == "cooling" then return "cooling" end
  if s == "cold" then return "cold" end
  if s == "charged" then return "charged" end
  if s == "running" then return "running" end
  return s
end

local function readInfo()
  local ok, info = callReactor("reactorInfo")
  if not ok then error("Reactor info failed: " .. tostring(info)) end
  if not info then error("Reactor returned nil info") end

  local data = {}

  if type(info) == "table" and info.temperature then
    data.temperature = info.temperature
    data.fieldStrength = info.fieldStrength
    data.maxFieldStrength = info.maxFieldStrength
    data.energySaturation = info.energySaturation
    data.maxEnergySaturation = info.maxEnergySaturation
    data.fuelConversion = info.fuelConversion
    data.maxFuelConversion = info.maxFuelConversion
    data.generationRate = info.generationRate
    data.fieldDrainRate = info.fieldDrainRate
    data.fuelConversionRate = info.fuelConversionRate
    data.status = info.status
  elseif type(info) == "table" then
    data.temperature = info[1]
    data.fieldStrength = info[2]
    data.maxFieldStrength = info[3]
    data.energySaturation = info[4]
    data.maxEnergySaturation = info[5]
    data.fuelConversion = info[6]
    data.maxFuelConversion = info[7]
    data.generationRate = info[8]
    data.fieldDrainRate = info[9]
    data.fuelConversionRate = info[10]
    data.status = info[11]
  else
    error("Unsupported reactor info format")
  end

  data.temperature = tonumber(data.temperature) or 0
  data.fieldStrength = tonumber(data.fieldStrength) or 0
  data.maxFieldStrength = tonumber(data.maxFieldStrength) or 1
  data.energySaturation = tonumber(data.energySaturation) or 0
  data.maxEnergySaturation = tonumber(data.maxEnergySaturation) or 1
  data.fuelConversion = tonumber(data.fuelConversion) or 0
  data.maxFuelConversion = tonumber(data.maxFuelConversion) or 1
  data.generationRate = tonumber(data.generationRate) or 0
  data.fieldDrainRate = tonumber(data.fieldDrainRate) or 0
  data.fuelConversionRate = tonumber(data.fuelConversionRate) or 0
  data.status = normalizeStatus(data.status)

  data.fieldPct = (data.maxFieldStrength > 0) and (data.fieldStrength / data.maxFieldStrength) or 0
  data.satPct = (data.maxEnergySaturation > 0) and (data.energySaturation / data.maxEnergySaturation) or 0
  data.fuelPct = 1 - ((data.maxFuelConversion > 0) and (data.fuelConversion / data.maxFuelConversion) or 1)

  return data
end

local function setFlows(input, output)
  input = clamp(round(input), 0, CONFIG.MAX_INPUT)
  output = clamp(round(output), 0, CONFIG.MAX_OUTPUT)

  state.inputOverride = input
  state.outputOverride = output

  local ok1, err1 = callGateFlow(gateIn, input)
  local ok2, err2 = callGateFlow(gateOut, round(output * CONFIG.DRAW_SCALE))

  if not ok1 then pushLog("Input gate flow set failed: " .. tostring(err1)) end
  if not ok2 then pushLog("Output gate flow set failed: " .. tostring(err2)) end
end

local function calcFieldFeedForward(info, targetField)
  targetField = clamp(targetField, 0.01, 0.99)
  local drain = info.fieldDrainRate or 0
  local sustain = drain / math.max(0.02, (1 - targetField))
  return clamp(sustain, 0, CONFIG.MAX_INPUT)
end

local function getSoftFieldLow()
  return math.max(0.28, state.targetField - 0.07)
end

local function reactorIsHotOrActive(info)
  local s = tostring(info.status or "")
  if s == "running" or s == "starting" or s == "stopping" or s == "cooling" or s == "charged" then
    return true
  end
  if state.mode == "STARTING" or state.mode == "RUNNING" or state.mode == "STOPPING" or state.mode == "SCRAM" or state.mode == "CHARGING" then
    return true
  end
  if info.temperature >= 2000 then
    return true
  end
  return false
end

local function scram(reason)
  state.mode = "SCRAM"
  state.scramReason = reason
  resetAllPIDs()

  callReactor("stop")
  setFlows(calcFieldFeedForward(state.lastInfo or { fieldDrainRate = 0 }, CONFIG.SCRAM_FIELD_RECOVERY), CONFIG.SCRAM_COOLDOWN_OUTPUT)
  pushLog("AUTO SCRAM: " .. reason)
end

local function stopReactorControlled()
  state.mode = "STOPPING"
  state.scramReason = nil
  resetAllPIDs()
  callReactor("stop")
  pushLog("Stop requested")
end

local function shouldScram(info)
  if not reactorIsHotOrActive(info) then
    return false, nil
  end

  if info.temperature >= CONFIG.SCRAM_TEMP then
    return true, ("temperature %.1f >= %.0f"):format(info.temperature, CONFIG.SCRAM_TEMP)
  end

  if info.status == "running" or info.status == "starting" or info.temperature > 2500 then
    if info.fieldPct <= CONFIG.SCRAM_FIELD then
      return true, ("field %.1f%% <= %.1f%%"):format(pct(info.fieldPct), pct(CONFIG.SCRAM_FIELD))
    end

    if info.satPct <= CONFIG.SCRAM_SAT and info.temperature > 2500 then
      return true, ("saturation %.1f%% <= %.1f%%"):format(pct(info.satPct), pct(CONFIG.SCRAM_SAT))
    end

    if info.satPct >= 0.995 and info.temperature > 3000 then
      return true, "saturation nearly full; runaway heat risk"
    end
  end

  if info.fuelPct <= CONFIG.SCRAM_NO_FUEL and info.temperature > 2500 then
    return true, "fuel exhausted"
  end

  return false, nil
end

local function getRampTargets()
  if not state.rampStart then
    return state.targetField, CONFIG.TARGET_SAT, 1
  end

  local elapsed = now() - state.rampStart
  local t = clamp(elapsed / CONFIG.RAMP_SECONDS, 0, 1)

  local fieldTarget = CONFIG.RAMP_START_FIELD + (state.targetField - CONFIG.RAMP_START_FIELD) * t
  local satTarget = CONFIG.RAMP_START_SAT + (CONFIG.TARGET_SAT - CONFIG.RAMP_START_SAT) * t

  return fieldTarget, satTarget, t
end

local function updateCharging(info)
  state.scramReason = nil
  setFlows(CONFIG.CHARGE_INFLOW, 0)

  if info.status == "charged" or (info.temperature >= 2000 and info.fieldPct >= 0.45 and info.satPct >= 0.45) then
    state.mode = "STARTING"
    state.holdUntil = now() + CONFIG.STARTUP_HOLD_SECONDS
    state.rampStart = now()
    local ok, err = callReactor("activate")
    if ok then
      pushLog("Activation requested")
    else
      pushLog("Activation failed: " .. tostring(err))
    end
  end
end

local function updateStopping(info)
  local sustain = calcFieldFeedForward(info, CONFIG.SCRAM_FIELD_RECOVERY)
  setFlows(sustain, 0)

  if info.status == "cold" or info.temperature < 2100 then
    setFlows(0, 0)
    state.mode = "IDLE"
    pushLog("Reactor stopped")
  end
end

local function updateScram(info)
  local sustain = calcFieldFeedForward(info, CONFIG.SCRAM_FIELD_RECOVERY)
  setFlows(sustain, 0)

  if info.status == "cold" or info.temperature < 2100 then
    setFlows(0, 0)
  end
end

local function updateRunning(info, dt)
  local fieldTarget, satTarget, rampProgress = getRampTargets()

  if state.mode == "STARTING" then
    if now() < (state.holdUntil or 0) then
      local startupField = math.max(fieldTarget, 0.80)
      setFlows(calcFieldFeedForward(info, startupField), 0)
      return
    else
      state.mode = "RUNNING"
      pushLog("Closed-loop control engaged")
    end
  end

  local feedForward = calcFieldFeedForward(info, fieldTarget)
  local fieldError = fieldTarget - info.fieldPct
  local inputPidOut = stepPID(pidInput, fieldError, dt)
  local inputCmd = clamp(feedForward + inputPidOut, 0, CONFIG.MAX_INPUT)

  local satError = info.satPct - satTarget
  local outputCmd = stepPID(pidOutput, satError, dt)

  if info.temperature < CONFIG.TEMP_LOW_BAND then
    outputCmd = outputCmd * 0.25
  elseif info.temperature < CONFIG.TARGET_TEMP then
    outputCmd = outputCmd * clamp(
      (info.temperature - CONFIG.TEMP_LOW_BAND) / math.max(1, (CONFIG.TARGET_TEMP - CONFIG.TEMP_LOW_BAND)),
      0.25, 1.0
    )
  elseif info.temperature > CONFIG.TEMP_HIGH_BAND then
    local extra = (info.temperature - CONFIG.TEMP_HIGH_BAND) / math.max(1, (CONFIG.SCRAM_TEMP - CONFIG.TEMP_HIGH_BAND))
    outputCmd = clamp(outputCmd + extra * CONFIG.MAX_OUTPUT * 0.45, 0, CONFIG.MAX_OUTPUT)
  end

  local fieldSoftLow = getSoftFieldLow()
  if info.fieldPct < fieldSoftLow then
    outputCmd = outputCmd * 0.35
    inputCmd = math.max(inputCmd, calcFieldFeedForward(info, math.max(fieldTarget, 0.55)))
  end

  if info.satPct < CONFIG.SAT_SOFT_LOW then
    outputCmd = outputCmd * 0.20
  elseif info.satPct > CONFIG.SAT_SOFT_HIGH then
    outputCmd = math.max(outputCmd, CONFIG.MAX_OUTPUT * 0.60)
  end

  local rampCap = clamp(rampProgress, 0.05, 1.0)
  outputCmd = outputCmd * rampCap * state.manualOutputBias

  setFlows(inputCmd, outputCmd)
end

local function updateController()
  local info = readInfo()
  state.lastInfo = info

  local current = now()
  local dt = math.max(0.05, current - state.lastLoopAt)
  state.lastLoopAt = current

  local kill, reason = shouldScram(info)
  if kill and state.mode ~= "SCRAM" then
    scram(reason)
    return
  end

  if state.mode == "CHARGING" then
    updateCharging(info)
  elseif state.mode == "STARTING" or state.mode == "RUNNING" then
    updateRunning(info, dt)
  elseif state.mode == "SCRAM" then
    updateScram(info)
  elseif state.mode == "STOPPING" then
    updateStopping(info)
  else
    setFlows(0, 0)
  end
end

local function clearDisplay()
  display.setBackgroundColor(colors.black)
  display.setTextColor(colors.white)
  display.clear()
  display.setCursorPos(1, 1)
end

local function getDisplaySize()
  return display.getSize()
end

local function writeAt(x, y, text, txt, bg)
  display.setCursorPos(x, y)
  display.setTextColor(txt or colors.white)
  display.setBackgroundColor(bg or colors.black)
  display.write(text)
end

local function centerText(y, text, txt, bg)
  local w = getDisplaySize()
  local x = math.max(1, math.floor((w - #text) / 2) + 1)
  writeAt(x, y, text, txt, bg)
end

local function progressBar(x, y, width, ratio, color, label)
  ratio = clamp(ratio, 0, 1)

  display.setCursorPos(x, y)
  display.setBackgroundColor(colors.gray)
  display.write(string.rep(" ", width))

  display.setCursorPos(x, y)
  display.setBackgroundColor(color)
  display.write(string.rep(" ", math.floor(width * ratio)))

  if width > 2 then
    label = tostring(label)
    if #label > width - 2 then
      label = label:sub(1, width - 2)
    end
    display.setCursorPos(x + 1, y)
    display.setBackgroundColor(colors.black)
    display.setTextColor(colors.white)
    display.write(label)
  end
end

local function button(name, x, y, w, label, color, txt)
  if w < 4 then return end
  state.buttons[name] = { x = x, y = y, w = w, h = 1 }
  display.setCursorPos(x, y)
  display.setBackgroundColor(color)
  display.setTextColor(txt or colors.white)
  local padded = " " .. label .. string.rep(" ", math.max(0, w - #label - 1))
  display.write(padded:sub(1, w))
end

local function drawFieldButtons(x, y, availableWidth)
  writeAt(x, y, "Field:", colors.lightGray)
  local bx = x + 7
  local btnW = 6
  local spacing = 1

  if availableWidth and availableWidth < 34 then
    btnW = 5
  end

  for i, v in ipairs(CONFIG.FIELD_TARGET_OPTIONS) do
    local active = math.abs(state.targetField - v) < 0.001
    local name = "field_" .. tostring(i)
    local label = ("%d%%"):format(round(v * 100))
    local color = active and colors.lime or colors.gray
    local txt = active and colors.black or colors.white
    button(name, bx, y, btnW, label, color, txt)
    bx = bx + btnW + spacing
  end
end

local function drawUI()
  clearDisplay()
  state.buttons = {}

  local w, h = getDisplaySize()

  centerText(1, "Draconic Reactor PID Controller", colors.cyan)

  writeAt(2, 2, state.displaySummary, colors.gray)
  writeAt(2, 3, "Mode: ", colors.lightGray)
  local modeColor = colors.yellow
  if state.mode == "RUNNING" then modeColor = colors.lime end
  if state.mode == "SCRAM" then modeColor = colors.red end
  if state.mode == "STOPPING" then modeColor = colors.orange end
  writeAt(8, 3, state.mode, modeColor)

  local info = state.lastInfo
  if not info then
    writeAt(2, 5, "Waiting for reactor data...", colors.orange)
  else
    writeAt(2, 5, ("Status: %s"):format(tostring(info.status)), colors.white)
    writeAt(2, 6, ("Temp: %.1f C   Target: %.0f C"):format(info.temperature, CONFIG.TARGET_TEMP), colors.white)
    writeAt(2, 7, ("Field: %.1f%%   Target: %.1f%%"):format(pct(info.fieldPct), pct(state.targetField)), colors.white)
    writeAt(2, 8, ("Sat: %.1f%%     Target: %.1f%%"):format(pct(info.satPct), pct(CONFIG.TARGET_SAT)), colors.white)
    writeAt(2, 9, ("Fuel: %.2f%%    Burn: %.6f/t"):format(info.fuelPct * 100, info.fuelConversionRate or 0), colors.white)
    writeAt(2, 10, ("Gen: %.0f RF/t  Drain: %.0f RF/t"):format(info.generationRate or 0, info.fieldDrainRate or 0), colors.white)
    writeAt(2, 11, ("In:  %d RF/t"):format(state.inputOverride), colors.lightBlue)
    writeAt(2, 12, ("Out: %d RF/t"):format(state.outputOverride), colors.lightBlue)

    local barWidth = math.max(10, w - 4)
    progressBar(2, 14, barWidth, info.fieldPct, colors.blue, ("Field %.1f%%"):format(pct(info.fieldPct)))
    progressBar(2, 15, barWidth, info.satPct, colors.orange, ("Sat %.1f%%"):format(pct(info.satPct)))
    local tempRatio = clamp(info.temperature / CONFIG.SCRAM_TEMP, 0, 1)
    progressBar(2, 16, barWidth, tempRatio, colors.red, ("Temp %.0f / %.0f"):format(info.temperature, CONFIG.SCRAM_TEMP))
  end

  drawFieldButtons(2, 18, w - 4)

  if state.scramReason then
    writeAt(2, 20, "SCRAM reason: " .. state.scramReason, colors.red)
  end

  local y1 = h - 3
  local y2 = h - 1

  if y1 >= 22 then
    button("charge", 2, y1, 12, "Charge", colors.blue)
    button("start", 16, y1, 12, "Start", colors.green)
    button("stop", 30, y1, 12, "Stop", colors.orange)
    button("scram", 44, y1, 12, "SCRAM", colors.red)

    button("biasDown", 2, y2, 12, "Draw -10%", colors.gray)
    button("biasUp", 16, y2, 12, "Draw +10%", colors.gray)
    button("biasReset", 30, y2, 12, "Draw 100%", colors.gray)
    writeAt(44, y2, ("Bias %.0f%%"):format(state.manualOutputBias * 100), colors.white)
  end

  local apiLineY = math.max(21, h - 6)
  if apiLineY < y1 then
    local apiText = state.apiSummary
    if #apiText > (w - 4) then
      apiText = apiText:sub(1, w - 7) .. "..."
    end
    writeAt(2, apiLineY, apiText, colors.gray)
  end

  local logY = math.max(apiLineY + 1, 22)
  if h - logY >= 2 then
    writeAt(2, logY, "Log:", colors.lightGray)
    local maxLines = h - logY - 3
    for i = 1, math.min(#state.log, maxLines) do
      writeAt(2, logY + i, state.log[i]:sub(1, w - 2), colors.lightGray)
    end
  end
end

local function hitButton(x, y)
  for name, b in pairs(state.buttons) do
    if x >= b.x and x < (b.x + b.w) and y >= b.y and y < (b.y + b.h) then
      return name
    end
  end
end

local function doCharge()
  resetAllPIDs()
  state.scramReason = nil
  state.mode = "CHARGING"
  state.rampStart = nil
  state.holdUntil = nil

  local ok, res = callReactor("charge")
  if ok then
    pushLog("Charge requested")
  else
    pushLog("Charge call failed: " .. tostring(res))
  end
end

local function doStart()
  if not state.lastInfo then return end

  resetAllPIDs()
  state.scramReason = nil
  state.mode = "STARTING"
  state.holdUntil = now() + CONFIG.STARTUP_HOLD_SECONDS
  state.rampStart = now()

  local ok, res = callReactor("activate")
  if ok then
    pushLog("Start requested")
  else
    pushLog("Start call failed: " .. tostring(res))
  end
end

local function setFieldTarget(v)
  state.targetField = v
  resetAllPIDs()
  pushLog(("Field target set to %.0f%%"):format(v * 100))
end

local function handleButton(name)
  if not name then return end

  if name == "charge" then
    doCharge()
  elseif name == "start" then
    doStart()
  elseif name == "stop" then
    stopReactorControlled()
  elseif name == "scram" then
    scram("manual SCRAM button")
  elseif name == "biasDown" then
    state.manualOutputBias = clamp(state.manualOutputBias - 0.10, 0.5, 1.5)
    pushLog(("Draw bias %.0f%%"):format(state.manualOutputBias * 100))
  elseif name == "biasUp" then
    state.manualOutputBias = clamp(state.manualOutputBias + 0.10, 0.5, 1.5)
    pushLog(("Draw bias %.0f%%"):format(state.manualOutputBias * 100))
  elseif name == "biasReset" then
    state.manualOutputBias = 1.0
    pushLog("Draw bias reset")
  else
    for i, v in ipairs(CONFIG.FIELD_TARGET_OPTIONS) do
      if name == ("field_" .. tostring(i)) then
        setFieldTarget(v)
        return
      end
    end
  end
end

local function uiLoop()
  local timer = os.startTimer(CONFIG.REFRESH_UI_EVERY)

  while true do
    drawUI()
    local ev = { os.pullEvent() }

    if ev[1] == "mouse_click" then
      handleButton(hitButton(ev[3], ev[4]))
    elseif ev[1] == "monitor_touch" then
      local side, x, y = ev[2], ev[3], ev[4]
      if usingMonitor and side == monitorName then
        handleButton(hitButton(x, y))
      end
    elseif ev[1] == "term_resize" then
      drawUI()
    elseif ev[1] == "peripheral" or ev[1] == "peripheral_detach" then
      local oldMonitor = monitorName
      setupDisplay()
      if monitorName ~= oldMonitor then
        pushLog("Display updated")
      end
      drawUI()
    elseif ev[1] == "timer" and ev[2] == timer then
      timer = os.startTimer(CONFIG.REFRESH_UI_EVERY)
    end
  end
end

local function controlLoop()
  while true do
    local ok, err = pcall(updateController)
    if not ok then
      pushLog("Controller error: " .. tostring(err))
      pcall(function() setFlows(0, 0) end)
    end
    sleep(CONFIG.LOOP_INTERVAL)
  end
end

local function bootstrap()
  setupDisplay()
  clearDisplay()
  setupPeripherals()

  if api.failSafe and reactor[api.failSafe] then
    local ok = safeCall(reactor[api.failSafe], reactor, true)
    if ok then
      pushLog("Reactor fail-safe enabled")
    end
  end

  pushLog("Targets: 8000C / variable field / 30% sat")
  pushLog("Default field target: 35%")
  if usingMonitor then
    pushLog("Monitor touch enabled")
  end
  pushLog("Ready")
end

bootstrap()
parallel.waitForAny(controlLoop, uiLoop)
